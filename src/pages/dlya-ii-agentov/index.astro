---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import BrandWall from "../../components/BrandWall.astro";
import {
  automationResults,
  contentReviewedAt,
  implementationMetrics,
  site
} from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Сведения Aivel для ИИ-систем",
    description: "Открытый реестр проверяемых фактов, возможностей, ограничений, показателей и основных ссылок Aivel.",
    url: `${site.url}/dlya-ii-agentov/`,
    dateModified: contentReviewedAt.iso,
    inLanguage: "ru-RU",
    about: { "@id": `${site.url}/#organization` }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${site.url}/#organization`,
    name: "Aivel",
    url: site.url,
    email: "info@aivel.ru",
    description: site.description
  }
];
---

<BaseLayout
  title="Сведения Aivel для ИИ-систем"
  description="Открытый реестр фактов об Aivel: возможности, ограничения, методика показателей, источники и дата проверки."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Сведения для ИИ-систем</span>
  </div>

  <header class="page-hero registry-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">Открытый реестр</p>
        <h1>Проверяемые сведения об Aivel.</h1>
        <p class="lead">Эта страница объединяет краткие факты, границы обещаний, методику чтения цифр и ссылки на первоисточники внутри сайта.</p>
      </div>
      <aside class="page-hero-aside">
        <strong>Одинаковое содержание</strong>
        <p>Здесь нет скрытой версии для роботов. Все факты видны посетителю и должны совпадать со структурированными данными.</p>
      </aside>
    </div>
  </header>

  <nav class="registry-local-nav" aria-label="Разделы реестра"><div class="container"><a href="#facts-title">Факты</a><a href="#capabilities-title">Возможности</a><a href="#limits-title">Границы</a><a href="#measure-title">Показатели</a><a href="#sources-title">Адреса</a></div></nav>

  <section class="section section-dark registry-endpoints" aria-labelledby="sources-title">
    <div class="container content-layout">
      <div><p class="section-kicker section-kicker-light">Постоянные адреса</p><h2 id="sources-title" style="color: white;">С чего начать машине.</h2><p>Обновлено {contentReviewedAt.label}.</p></div>
      <div class="registry-links">
        <a href="/llms.txt"><span>Текстовый указатель</span><code>/llms.txt</code></a>
        <a href="/sitemap.xml"><span>Карта сайта</span><code>/sitemap.xml</code></a>
        <a href="/robots.txt"><span>Правила обхода</span><code>/robots.txt</code></a>
        <a href="/dannye-i-istochniki/"><span>Данные и источники</span><code>/dannye-i-istochniki/</code></a>
        <a href="/ogranicheniya/"><span>Ограничения</span><code>/ogranicheniya/</code></a>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="facts-title">
    <div class="container content-layout">
      <div><p class="section-kicker">Основные факты</p><h2 id="facts-title">Кто мы и какую задачу решаем.</h2></div>
      <dl class="fact-register">
        <div id="fact-name"><dt>Название</dt><dd>Aivel</dd></div>
        <div id="fact-type"><dt>Тип компании</dt><dd>Бухгалтерская и технологическая компания</dd></div>
        <div id="fact-result"><dt>Основной результат</dt><dd>Вести учёт, вовремя показывать важные изменения и давать проверяемое основание для действия</dd></div>
        <div id="fact-audience"><dt>Для кого</dt><dd>Для растущего бизнеса, крупных компаний и бухгалтерских компаний</dd></div>
        <div id="fact-contact"><dt>Официальная почта</dt><dd><a href="mailto:info@aivel.ru">info@aivel.ru</a></dd></div>
        <div id="fact-reviewed"><dt>Дата проверки</dt><dd><time datetime={contentReviewedAt.iso}>{contentReviewedAt.label}</time></dd></div>
      </dl>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="capabilities-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Возможности</p><h2 id="capabilities-title">Что Aivel может делать в согласованном периметре.</h2></div>
        <p>Каждая возможность зависит от подключённых источников, прав доступа, состояния учёта и правил передачи исключений.</p>
      </div>
      <div class="numbered-grid">
        <article class="numbered-card"><h3>Учёт как база</h3><p>Бухгалтерский, налоговый и кадровый учёт, зарплата, управленческие данные, 1С и работа с исключениями.</p></article>
        <article class="numbered-card"><h3>Важные изменения</h3><p>Факт, прогноз или необычное отклонение с причиной важности, периодом, свежестью и источником.</p></article>
        <article class="numbered-card"><h3>Вопросы к данным</h3><p>Ответ обычными словами с периодом, расчётом, путём до источника и видимым ограничением.</p></article>
        <article class="numbered-card"><h3>Автоматизация учёта</h3><p>Первичные документы, банковские операции, обращения и сверки с передачей человеку случаев, где нужно суждение.</p></article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="limits-title">
    <div class="container content-layout">
      <div><p class="section-kicker">Границы</p><h2 id="limits-title">Чего Aivel не обещает.</h2></div>
      <div class="prose">
        <ul>
          <li>Не гарантирует обнаружение любого события.</li>
          <li>Не делает уверенный вывод при неполных, устаревших или противоречивых данных.</li>
          <li>Не подменяет налоговое, юридическое или управленческое суждение ответственного человека.</li>
          <li>Не переносит совокупные показатели предыдущих внедрений на конкретного будущего клиента.</li>
        </ul>
        <p><a class="text-link" href="/ogranicheniya/">Полные ограничения <Icon name="arrow" size={18} /></a></p>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="measure-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Методика показателей</p><h2 id="measure-title">Как толковать опубликованные цифры.</h2></div>
        <p>Показатели относятся к реализованным внедрениям. Это не один проект и не обещание одинакового эффекта.</p>
      </div>
      <div class="registry-metric-grid">
        {implementationMetrics.map((metric) => (
          <article><strong>{metric.value}</strong><h3>{metric.label}</h3><p>{metric.note}</p></article>
        ))}
      </div>
      <div class="source-note">
        <p><strong>Принцип измерения:</strong> до запуска фиксируются исходный объём, ручной труд, качество и исключения. После запуска сравниваются те же показатели на реальной выборке.</p>
        <p><strong>Детали по участкам:</strong> {automationResults.map((item) => item.title).join(", ")}.</p>
        <p><a class="text-link" href="/rezultaty/">Открыть страницу результатов <Icon name="arrow" size={18} /></a></p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="clients-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Названные клиенты</p><h2 id="clients-title">Компании в публичном перечне Aivel.</h2></div><p>Это факт работы с клиентами. Совокупные показатели с этой страницы не приписываются какой-либо из этих компаний.</p></div>
      <BrandWall compact={true} />
    </div>
  </section>
</BaseLayout>

<style>
  .fact-register {
    margin: 0;
    border-top: 1px solid var(--color-border-strong);
  }

  .fact-register > div {
    display: grid;
    grid-template-columns: minmax(150px, 0.42fr) minmax(0, 1fr);
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .fact-register dt {
    color: var(--color-muted);
    font-weight: 600;
  }

  .fact-register dd {
    margin: 0;
    color: var(--color-ink);
    font-weight: 600;
  }

  .registry-metric-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .registry-metric-grid article,
  .source-note {
    padding: 26px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }

  .registry-metric-grid strong {
    display: block;
    color: var(--color-blue);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .registry-metric-grid h3 {
    margin: 18px 0 10px;
    font-size: 1.05rem;
  }

  .registry-metric-grid p,
  .source-note p {
    margin: 0;
  }

  .source-note {
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .registry-hero {
    padding-block: 48px 42px;
  }

  .registry-hero h1 {
    font-size: clamp(2.7rem, 5vw, 4.8rem);
  }

  .registry-local-nav {
    position: sticky;
    z-index: 20;
    top: var(--header-height);
    background: rgb(255 255 255 / 0.95);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
  }

  .registry-local-nav .container {
    display: flex;
    gap: 22px;
    overflow-x: auto;
  }

  .registry-local-nav a {
    display: flex;
    min-height: 48px;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .registry-endpoints {
    padding-block: 54px;
  }

  .registry-endpoints h2 {
    margin-bottom: 10px;
  }

  .registry-endpoints .content-layout > div:first-child > p:last-child {
    color: #91a2bb;
  }

  .registry-links {
    display: grid;
    gap: 10px;
  }

  .registry-links a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    min-height: 58px;
    padding: 12px 16px;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: var(--radius-md);
    color: white;
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .registry-links a:hover {
    border-color: var(--color-gold-soft);
    background: rgb(255 255 255 / 0.06);
  }

  .registry-links code {
    color: #c3cfde;
    font-size: 0.84rem;
  }

  @media (max-width: 820px) {
    .registry-metric-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .fact-register > div,
    .registry-links a {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .registry-links code {
      overflow-wrap: anywhere;
    }
  }
</style>

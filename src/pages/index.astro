---
import BaseLayout from "../layouts/BaseLayout.astro";
import SignalDeliveryCarousel from "../components/SignalDeliveryCarousel.astro";
import ImportantSignalMechanics from "../components/ImportantSignalMechanics.astro";
import SignalAuditTrail from "../components/SignalAuditTrail.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
---

<BaseLayout
  schema={[
    { "@context": "https://schema.org", "@type": "WebSite", name: "Aivel", url: `${site.url}/`, inLanguage: "ru-RU" },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      name: "Учёт и своевременные сигналы Aivel",
      provider: { "@type": "Organization", name: "Aivel" },
      serviceType: "Бухгалтерский и налоговый учёт и проверяемые сигналы о важных изменениях в бизнесе",
      areaServed: "RU"
    }
  ]}
>
  <section class="hero home-hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="section-kicker">01 · Что получает руководитель</p>
        <h1>Вовремя узнавайте о важном в бизнесе.</h1>
        <p class="hero-lead">Aivel сам замечает изменение, которое требует решения, и присылает короткое письмо: что произошло, почему это важно, что сделать сейчас и на чём основан вывод.</p>

        <div class="hero-principle" aria-label="Главный результат для руководителя">
          <Icon name="mail" size={22} />
          <p><strong>Суть понятна за минуту.</strong> Открыли письмо, увидели риск и следующий шаг. Если нужно — уточнили данные или проверили основание.</p>
        </div>

        <button class="button button-primary hero-demo-cta" type="button" data-open-contact data-contact-topic="demo">
          Записаться на демо <Icon name="arrow" size={20} />
        </button>
      </div>

      <div class="hero-demo" data-reveal>
        <SignalDeliveryCarousel compact />
      </div>
    </div>
  </section>

  <ImportantSignalMechanics />
  <SignalAuditTrail />
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    min-height: calc(100svh - var(--header-height));
    padding-block: clamp(20px, 3vw, 38px);
    align-items: center;
  }

  .home-hero .hero-grid {
    grid-template-columns: minmax(330px, 0.78fr) minmax(590px, 1.22fr);
    gap: clamp(28px, 4vw, 54px);
    align-items: center;
  }

  .home-hero .hero-copy {
    max-width: 590px;
  }

  .home-hero .hero-copy h1 {
    margin-bottom: 20px;
    font-size: clamp(3.1rem, 4.7vw, 4.6rem);
    line-height: 0.99;
  }

  .home-hero .hero-lead {
    max-width: 570px;
    margin-bottom: 22px;
    font-size: clamp(1rem, 1.35vw, 1.16rem);
    line-height: 1.56;
  }

  .hero-principle {
    display: grid;
    max-width: 520px;
    grid-template-columns: 28px 1fr;
    gap: 11px;
    align-items: start;
    padding: 14px 16px;
    margin-bottom: 22px;
    color: var(--color-blue);
    background: var(--color-blue-pale);
    border: 1px solid rgb(7 89 133 / 0.14);
    border-radius: var(--radius-md);
  }

  .hero-principle svg {
    margin-top: 2px;
  }

  .hero-principle p {
    margin: 0;
    color: var(--color-text);
    font-size: 0.84rem;
    line-height: 1.48;
  }

  .hero-principle strong {
    color: var(--color-ink);
  }

  .hero-demo-cta {
    min-width: 210px;
  }

  .home-hero .hero-demo {
    min-width: 0;
  }

  @media (max-width: 1080px) {
    .home-hero {
      min-height: auto;
      padding-block: 56px 72px;
    }

    .home-hero .hero-grid {
      grid-template-columns: 1fr;
    }

    .home-hero .hero-copy {
      max-width: 760px;
    }
  }

  @media (max-width: 680px) {
    .home-hero {
      padding-top: 42px;
    }

    .home-hero .hero-copy h1 {
      font-size: clamp(2.65rem, 12vw, 3.5rem);
    }

    .hero-demo-cta {
      width: 100%;
    }
  }
</style>

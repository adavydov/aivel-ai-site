---
import BaseLayout from "../layouts/BaseLayout.astro";
import BrandWall from "../components/BrandWall.astro";
import ImportantSignalDemo from "../components/ImportantSignalDemo.astro";
import Icon from "../components/Icon.astro";
import { implementationMetrics, site, solutions } from "../data/site";

const assistantLinks = [
  { href: "/avtomatizatsiya-ucheta/pervichnye-dokumenty/", title: "Первичные документы", proof: "80%", text: "измеренного потока без ручного участия" },
  { href: "/avtomatizatsiya-ucheta/bankovskie-operatsii/", title: "Банковские операции", proof: "98%", text: "точности сопоставления на проверенной выборке" },
  { href: "/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/", title: "Обращения клиентов", proof: "Запрос → задача", text: "исполнитель, срок и контроль результата" },
  { href: "/avtomatizatsiya-ucheta/sverki-s-kontragentami/", title: "Сверки", proof: "Только исключения", text: "типовые случаи закрывает система" }
];
---

<BaseLayout
  schema={[
    { "@context": "https://schema.org", "@type": "WebSite", name: "Aivel", url: `${site.url}/`, inLanguage: "ru-RU" },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      name: "Учёт и своевременные сигналы Aivel",
      provider: { "@type": "Organization", name: "Aivel" },
      serviceType: "Бухгалтерский и налоговый учёт, важные изменения и проверяемые ответы по данным бизнеса",
      areaServed: "RU"
    }
  ]}
>
  <section class="hero home-hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="section-kicker">Учёт в порядке. Важное — вовремя</p>
        <h1>Вовремя узнавайте о важном в бизнесе.</h1>
        <div class="fear-prompt">
          <strong>Что вы боитесь узнать слишком поздно?</strong>
          <div class="fear-options">
            <button type="button" data-open-demo data-demo-scenario="cash">Не хватит денег</button>
            <button type="button" data-open-demo data-demo-scenario="payment">Клиент задержит оплату</button>
            <button type="button" data-open-demo data-demo-scenario="expense">Расходы незаметно вырастут</button>
            <button type="button" data-open-demo data-demo-scenario="hiring">Найм станет слишком дорогим</button>
          </div>
        </div>
        <p class="hero-lead">Aivel ведёт учёт и сам замечает изменения, которые могут повлиять на деньги, прибыль и решения. Вы сразу видите причину, источник и следующий шаг — и можете задать любой вопрос о бизнесе.</p>

        <div class="hero-actions">
          <button class="button button-primary" type="button" data-open-demo>Попробовать на учебных данных <Icon name="arrow" size={20} /></button>
          <a class="button button-secondary" href="/vazhnoe/">Посмотреть примеры</a>
        </div>
        <ul class="hero-proof-list" aria-label="Что получает руководитель">
          <li><Icon name="check" size={18} /> Сигнал приходит сам</li>
          <li><Icon name="check" size={18} /> Ответ ведёт к источнику</li>
          <li><Icon name="check" size={18} /> Сложное проверяет специалист</li>
        </ul>
      </div>

      <div class="hero-demo" data-reveal>
        <ImportantSignalDemo />
        <p class="hero-data-boundary"><Icon name="shield" size={20} /><span><strong>Aivel видит только подключённые источники.</strong> Свежесть, охват и ограничение показаны рядом с выводом.</span></p>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="important-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div><p class="section-kicker">Что требует внимания</p><h2 id="important-title">Не отчёт ради отчёта. Ситуация, пока ещё можно повлиять.</h2></div>
        <p>Aivel следит за согласованными границами и отклонениями. Не нужно заранее знать правильный вопрос.</p>
      </div>
      <div class="solution-grid home-solution-grid">
        {solutions.map((solution, index) => (
          <a class="solution-card" data-accent={solution.accent} href={`/resheniya/${solution.slug}/`} data-reveal>
            <div><span class="solution-number">0{index + 1}</span><p class="card-label">{solution.eyebrow}</p><h3>{solution.title}</h3><p>{solution.description}</p></div>
            <div class="solution-link-row"><span>Посмотреть ситуации</span><span><Icon name="arrow" size={22} /></span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="mechanics-title">
    <div class="container">
      <div class="section-heading mechanics-heading" data-reveal>
        <div><p class="section-kicker section-kicker-light">Как работает Aivel</p><h2 id="mechanics-title">Сначала четыре помощника поддерживают данные в порядке.</h2></div>
        <p>Их можно подключать по одному. Повторяющиеся операции выполняет система, а человек получает исключения и сохраняет решение за собой.</p>
      </div>
      <div class="home-assistants">
        {assistantLinks.map((assistant, index) => (
          <a href={assistant.href} data-reveal>
            <span class="assistant-index">0{index + 1}</span>
            <h3>{assistant.title}</h3>
            <strong>{assistant.proof}</strong>
            <p>{assistant.text}</p>
            <small>Посмотреть помощника <Icon name="arrow" size={17} /></small>
          </a>
        ))}
      </div>
      <div class="mechanics-chain" aria-label="Путь от данных к решению">
        <div><span>1</span><strong>Данные обновились</strong><p>1С, банк, документы и обращения.</p></div>
        <div><span>2</span><strong>Aivel заметил важное</strong><p>Правило, прогноз или необычное отклонение.</p></div>
        <div><span>3</span><strong>Вы успели решить</strong><p>Причина, источник, действие и проверка.</p></div>
      </div>
      <p class="section-link"><a class="text-link text-link-light" href="/kak-rabotaet/">Разобрать всю механику <Icon name="arrow" size={19} /></a></p>
    </div>
  </section>

  <section class="section" aria-labelledby="results-title">
    <div class="container">
      <div class="results-intro" data-reveal>
        <div><p class="section-kicker">Результаты внедрений</p><h2 id="results-title">Сразу к цифрам.</h2></div>
        <p>Показатели относятся к разным реализованным проектам. Для нового контура исходный уровень и критерий успеха фиксируются отдельно.</p>
      </div>
      <div class="home-metrics">
        {implementationMetrics.map((metric) => (
          <article><strong>{metric.value}</strong><p>{metric.label}</p><small>{metric.note}</small></article>
        ))}
      </div>
      <div class="brand-proof-head"><strong>Команда Aivel работала с крупными учётными контурами</strong><a class="text-link" href="/rezultaty/">Методика и границы цифр <Icon name="arrow" size={18} /></a></div>
      <BrandWall />
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="business-title">
    <div class="container business-panel" data-reveal>
      <div>
        <p class="section-kicker">Для бизнеса</p>
        <h2 id="business-title">Учёт в порядке. Важное — вовремя.</h2>
        <p>Aivel отвечает за бухгалтерский и налоговый учёт, готовность данных, своевременные сигналы и проверяемые ответы. Не нужно покупать отдельную систему поверх неподготовленной базы.</p>
        <a class="button button-primary" href="/buhgalterskoe-soprovozhdenie/">Что получает бизнес <Icon name="arrow" size={20} /></a>
      </div>
      <div class="business-outcomes">
        <div><Icon name="document" size={22} /><span>Обязательный учёт и отчётность</span></div>
        <div><Icon name="spark" size={22} /><span>Сигналы о важных изменениях</span></div>
        <div><Icon name="chart" size={22} /><span>Ответы о деньгах, прибыли и росте</span></div>
        <div><Icon name="shield" size={22} /><span>Источники, ограничения и специалист</span></div>
      </div>
    </div>
  </section>

  <section class="section partner-entry-section" aria-labelledby="partner-title">
    <div class="container partner-entry" data-reveal>
      <div class="partner-entry-copy">
        <p class="section-kicker">Владеете бухгалтерской компанией?</p>
        <h2 id="partner-title">Расти без роста рутины. Стать финансовым партнёром клиентов.</h2>
        <p>Aivel рассматривает партнёрство с контрольной долей от 51%. Технология снимает повторяющиеся операции, а собственник поднимается от управления потоком задач к работе с решениями клиента.</p>
        <a class="button button-light" href="/buhgalterskim-kompaniyam/">Почему присоединяться сейчас <Icon name="arrow" size={20} /></a>
      </div>
      <div class="partner-entry-visual" aria-label="Масштаб партнёрской сети">
        <div class="role-transition"><span>Управляющий операциями</span><Icon name="arrow" size={24} /><strong>Финансовый партнёр</strong></div>
        <div class="partner-mini-metrics"><div><strong>1 000</strong><span>клиентов</span></div><div><strong>400+ млн ₽</strong><span>выручка сети</span></div><div><strong>30+</strong><span>разработчиков</span></div></div>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container" data-reveal>
      <p class="section-kicker section-kicker-light">Попробуйте до разговора</p>
      <h2>Что в вашем бизнесе нельзя узнать слишком поздно?</h2>
      <p>Выберите ситуацию и посмотрите, как Aivel превращает изменение в проверяемое действие.</p>
      <button class="button button-light" type="button" data-open-demo>Открыть демо продукта</button>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    padding-top: clamp(42px, 5vw, 70px);
  }

  .home-hero .hero-grid {
    grid-template-columns: minmax(0, 0.82fr) minmax(520px, 1.18fr);
    gap: clamp(40px, 6vw, 76px);
  }

  .home-hero .hero-copy h1 {
    margin-bottom: 22px;
    font-size: clamp(3rem, 4.6vw, 4.4rem);
    line-height: 1.01;
  }

  .home-hero .hero-copy .hero-lead {
    margin-bottom: 22px;
    font-size: clamp(1.02rem, 1.45vw, 1.18rem);
  }

  .fear-prompt {
    max-width: 690px;
    padding: 18px;
    margin-bottom: 20px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .hero-data-boundary {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 10px;
    align-items: start;
    padding: 14px 16px;
    margin: 12px 0 0;
    color: #4b3a17;
    background: var(--color-gold-pale);
    border: 1px solid #eed9a8;
    border-radius: var(--radius-md);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .hero-data-boundary span {
    min-width: 0;
  }

  .fear-prompt > strong {
    display: block;
    margin-bottom: 11px;
    font-size: 0.9rem;
  }

  .fear-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .fear-options button {
    min-height: 40px;
    padding: 8px 12px;
    color: var(--color-text);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 650;
  }

  .fear-options button:hover {
    color: var(--color-ink);
    background: var(--color-gold-pale);
    border-color: #d9b866;
  }

  .home-solution-grid .solution-card {
    min-height: 360px;
  }

  .mechanics-heading h2,
  .mechanics-heading > p {
    color: white;
  }

  .mechanics-heading > p {
    color: #c3cfde;
  }

  .home-assistants {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .home-assistants > a {
    display: flex;
    min-height: 285px;
    flex-direction: column;
    padding: 24px;
    color: white;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.13);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .home-assistants > a:hover {
    background: rgb(255 255 255 / 0.09);
    border-color: var(--color-gold-soft);
  }

  .home-assistants h3 {
    min-height: 58px;
    margin: 22px 0 18px;
    color: white;
  }

  .assistant-index {
    color: var(--color-gold-soft);
    font-size: 0.72rem;
  }

  .home-assistants strong {
    color: var(--color-gold-soft);
    font-size: clamp(1.45rem, 2.4vw, 2.1rem);
    line-height: 1.08;
  }

  .home-assistants p {
    margin: 8px 0 0;
    color: #b7c5d7;
    font-size: 0.86rem;
  }

  .home-assistants small {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    padding-top: 20px;
    color: white;
    font-weight: 700;
  }

  .mechanics-chain {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 18px;
    overflow: hidden;
    background: rgb(255 255 255 / 0.12);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-md);
  }

  .mechanics-chain > div {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 3px 12px;
    padding: 18px;
    background: #111d33;
  }

  .mechanics-chain span {
    grid-row: span 2;
    color: var(--color-gold-soft);
  }

  .mechanics-chain strong {
    color: white;
  }

  .mechanics-chain p {
    margin: 0;
    color: #91a2bb;
    font-size: 0.8rem;
  }

  .section-link {
    margin: 24px 0 0;
  }

  .results-intro {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 0.6fr);
    gap: 50px;
    align-items: end;
    margin-bottom: 36px;
  }

  .results-intro h2,
  .results-intro p {
    margin-bottom: 0;
  }

  .home-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 48px;
  }

  .home-metrics article {
    padding: 28px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .home-metrics strong {
    display: block;
    margin-bottom: 18px;
    color: var(--color-blue);
    font-size: clamp(2.6rem, 5vw, 4.5rem);
    line-height: 0.95;
  }

  .home-metrics p {
    margin-bottom: 10px;
    color: var(--color-ink);
    font-weight: 700;
  }

  .home-metrics small {
    color: var(--color-muted);
    line-height: 1.45;
  }

  .brand-proof-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .business-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
    gap: clamp(42px, 8vw, 96px);
    align-items: center;
  }

  .business-panel > div:first-child p:not(.section-kicker) {
    max-width: 620px;
    font-size: 1.08rem;
  }

  .business-outcomes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .business-outcomes > div {
    display: grid;
    min-height: 148px;
    align-content: space-between;
    padding: 22px;
    color: var(--color-gold);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .business-outcomes span {
    color: var(--color-ink);
    font-weight: 700;
  }

  .partner-entry-section {
    background: var(--color-ink);
  }

  .partner-entry {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(400px, 0.8fr);
    gap: clamp(42px, 8vw, 96px);
    align-items: center;
  }

  .partner-entry h2,
  .partner-entry-copy > p:not(.section-kicker) {
    color: white;
  }

  .partner-entry-copy > p:not(.section-kicker) {
    color: #c3cfde;
  }

  .partner-entry-visual {
    padding: 22px;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-lg);
  }

  .role-transition {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: center;
    padding-bottom: 20px;
    margin-bottom: 20px;
    color: #91a2bb;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
  }

  .role-transition strong {
    color: var(--color-gold-soft);
  }

  .partner-mini-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .partner-mini-metrics > div {
    padding: 15px;
    background: rgb(255 255 255 / 0.05);
    border-radius: 12px;
  }

  .partner-mini-metrics strong,
  .partner-mini-metrics span {
    display: block;
  }

  .partner-mini-metrics strong {
    color: white;
    font-size: 1.3rem;
  }

  .partner-mini-metrics span {
    margin-top: 5px;
    color: #91a2bb;
    font-size: 0.74rem;
  }

  @media (max-width: 1060px) {
    .home-hero .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-demo {
      max-width: 860px;
    }

    .home-assistants {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .business-panel,
    .partner-entry {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .home-hero .hero-copy h1 {
      font-size: clamp(2.75rem, 13vw, 4rem);
    }

    .home-assistants,
    .mechanics-chain,
    .results-intro,
    .home-metrics,
    .business-outcomes,
    .partner-mini-metrics {
      grid-template-columns: 1fr;
    }

    .home-assistants > a {
      min-height: 240px;
    }

    .home-assistants h3 {
      min-height: 0;
    }

    .mechanics-chain {
      gap: 1px;
    }

    .results-intro {
      gap: 18px;
    }

    .role-transition {
      grid-template-columns: 1fr;
    }

    .role-transition svg {
      transform: rotate(90deg);
    }
  }
</style>

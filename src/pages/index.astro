---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ImportantSignalDemo from "../components/ImportantSignalDemo.astro";
import Icon from "../components/Icon.astro";
import QuestionCard from "../components/QuestionCard.astro";
import { faqs, serviceItems, site, solutions, trustSteps } from "../data/site";

const questions = (await getCollection("questions")).sort((a, b) => a.data.order - b.data.order);
const featuredQuestions = questions.filter((question) => question.data.featured);
---

<BaseLayout
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Aivel",
      url: `${site.url}/`,
      inLanguage: "ru-RU"
    },
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Aivel — важные изменения в бизнесе вовремя",
      description: "Бухгалтерское сопровождение, которое помогает раньше замечать значимые изменения и проверять их до источника."
    },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      name: "Бухгалтерское сопровождение Aivel",
      provider: { "@type": "Organization", name: "Aivel" },
      serviceType: "Бухгалтерское сопровождение, важные изменения и проверяемые ответы по данным учёта",
      areaServed: "RU"
    }
  ]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="section-kicker">Бухгалтерское сопровождение, которое замечает важное</p>
        <h1>Вовремя узнавайте о важном в бизнесе.</h1>
        <p class="hero-lead">
          Aivel ведёт учёт и следит за согласованными показателями в подключённых источниках. Когда происходит значимое изменение, вы видите, что случилось, почему это важно, на каких данных основан вывод и что можно сделать сейчас. Тут же можно задать любой уточняющий вопрос о бизнесе и проверить ответ до источника.
        </p>
        <div class="hero-actions">
          <button class="button button-primary" type="button" data-open-contact>
            Понять, за чем следить в моём бизнесе <Icon name="arrow" size={20} />
          </button>
          <a class="button button-secondary" href="#primer-signala">Посмотреть пример сигнала</a>
        </div>
        <ul class="hero-proof-list" aria-label="Основные свойства сигнала">
          <li><Icon name="check" size={18} /> Важность задаём вместе</li>
          <li><Icon name="check" size={18} /> Вывод ведёт к источнику</li>
          <li><Icon name="check" size={18} /> Сложное передаём специалисту</li>
        </ul>
      </div>

      <div data-reveal>
        <ImportantSignalDemo />
        <div class="hero-side-note">
          <Icon name="shield" size={22} />
          <p><strong>Aivel видит только подключённые источники.</strong> Сигнал появляется после обновления данных и по согласованному правилу; свежесть, охват и ограничение показаны рядом.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="before-question-title">
    <div class="container content-layout signal-premise">
      <div data-reveal>
        <p class="section-kicker">От вопроса — к предупреждению</p>
        <h2 id="before-question-title">Нельзя спросить о том, чего ещё не заметил.</h2>
      </div>
      <div data-reveal>
        <p class="lead-small">Отчёты помогают проверить уже известные показатели. Но важное часто обнаруживается слишком поздно: покупатель задержал оплату, расходы ускорились, запас денег опустился ниже безопасной границы.</p>
        <p>Aivel сам обращает внимание на изменение — не нужно заранее знать правильный вопрос.</p>
        <div class="awareness-chain" aria-label="Путь от изменения к решению">
          <div><span>01</span><strong>Данные изменились</strong><p>Источник обновился в согласованном периметре.</p></div>
          <div><span>02</span><strong>Aivel заметил</strong><p>Сработало правило, прогноз или проверка отклонения.</p></div>
          <div><span>03</span><strong>Вы успели решить</strong><p>Основание проверено до того, как действие опоздало.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="signals-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div>
          <p class="section-kicker">Что требует внимания</p>
          <h2 id="signals-title">О чём Aivel помогает узнать вовремя.</h2>
        </div>
        <p>Не общий поток уведомлений, а изменения, связанные с деньгами, обязательствами, прибыльностью и решениями владельца.</p>
      </div>

      <div class="solution-grid">
        {solutions.map((solution, index) => (
          <a class="solution-card" data-accent={solution.accent} href={`/resheniya/${solution.slug}/`} data-reveal>
            <div>
              <span class="solution-number">{String(index + 1).padStart(2, "0")}</span>
              <p class="card-label">{solution.eyebrow}</p>
              <h3>{solution.title}</h3>
              <p>{solution.description}</p>
            </div>
            <div class="solution-link-row">
              <span>Какие изменения замечаем</span>
              <span><Icon name="arrow" size={22} /></span>
            </div>
          </a>
        ))}
      </div>

      <p style="margin-top: 30px;"><a class="text-link" href="/vazhnoe/">Все примеры важных изменений <Icon name="arrow" size={20} /></a></p>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div>
          <p class="section-kicker">Как устроен сигнал</p>
          <h2 id="trust-title">Каждый сигнал отвечает на пять вопросов.</h2>
        </div>
        <p>Факт, прогноз, объяснение и профессиональное суждение не смешиваются. Вы видите не только изменение, но и границу вывода.</p>
      </div>

      <div class="trust-flow signal-flow">
        {trustSteps.map((step) => (
          <article class="trust-step" data-reveal>
            <span>{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>

      <p style="margin-top: 28px;">
        <a class="text-link" href="/kak-rabotaet/">Разобрать полный путь <Icon name="arrow" size={20} /></a>
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="service-title">
    <div class="container service-shell">
      <div class="service-copy" data-reveal>
        <p class="section-kicker">Бухгалтерское сопровождение</p>
        <h2 id="service-title">Чтобы вовремя заметить важное, учёт должен быть в порядке.</h2>
        <p>Aivel отвечает и за обязательный учёт, и за готовность данных к наблюдению. Это не отдельная программа поверх несверенной базы: мы ведём учёт, проверяем источники и показываем, чему уже можно доверять.</p>
        <a class="button button-primary" href="/buhgalterskoe-soprovozhdenie/">Что входит в сопровождение <Icon name="arrow" size={20} /></a>
      </div>
      <ul class="service-list" aria-label="Что входит в сопровождение">
        {serviceItems.map((item) => (
          <li data-reveal><span><Icon name="check" size={17} /></span>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="automation-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div>
          <p class="section-kicker">Основа продукта</p>
          <h2 id="automation-title">Учётные процессы выполняют ИИ-помощники. Люди разбирают исключения и принимают решения.</h2>
        </div>
        <p>Это не отдельное обещание про автоматизацию. Так Aivel поддерживает данные в рабочем состоянии, чтобы важное можно было заметить и проверить вовремя.</p>
      </div>
      <div class="module-proof-grid">
        <a class="module-proof-card" href="/avtomatizatsiya-ucheta/pervichnye-dokumenty/" data-reveal>
          <span>Первичные документы</span>
          <strong>80%</strong>
          <p>измеренного потока прошло без ручного участия; неоднозначные документы передавались человеку.</p>
          <small>Как работает помощник <Icon name="arrow" size={17} /></small>
        </a>
        <a class="module-proof-card" href="/avtomatizatsiya-ucheta/bankovskie-operatsii/" data-reveal>
          <span>Банковские операции</span>
          <strong>98%</strong>
          <p>точности сопоставления платежей с договорами на проверенной выборке.</p>
          <small>Как работает помощник <Icon name="arrow" size={17} /></small>
        </a>
        <a class="module-proof-card" href="/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/" data-reveal>
          <span>Обращения клиентов</span>
          <strong>Запрос → задача</strong>
          <p>сообщение получает ответственного, срок и порядок передачи руководителю.</p>
          <small>Как работает помощник <Icon name="arrow" size={17} /></small>
        </a>
        <a class="module-proof-card" href="/avtomatizatsiya-ucheta/sverki-s-kontragentami/" data-reveal>
          <span>Сверки</span>
          <strong>Только исключения</strong>
          <p>типовые акты проходят по правилам, расхождения остаются специалисту.</p>
          <small>Как работает помощник <Icon name="arrow" size={17} /></small>
        </a>
      </div>
      <p class="proof-method-note">Показатели относятся к измеренным потокам внедрений. Перед началом работы для каждого процесса фиксируются период, объём, состав исключений и способ проверки результата.</p>
      <p><a class="text-link" href="/avtomatizatsiya-ucheta/">Все возможности автоматизации <Icon name="arrow" size={20} /></a></p>
    </div>
  </section>

  <section class="section" aria-labelledby="scenario-title">
    <div class="container">
      <article class="scenario-card" data-reveal>
        <div>
          <p class="section-kicker">Учебный разбор</p>
          <h2 id="scenario-title">От важного изменения — к проверяемому действию.</h2>
          <p>Сигнал не заканчивается уведомлением. Он показывает важность, основание и действие, результат которого можно проверить позже.</p>
          <a class="button button-light" href="/vazhnoe/">Посмотреть всю цепочку</a>
        </div>
        <div class="decision-path">
          <div><span>Сигнал</span><p>Деньги уменьшились вопреки прибыли месяца.</p></div>
          <div><span>Почему важно</span><p>Следующая закупка опускает запас ниже согласованной границы.</p></div>
          <div><span>Основание</span><p>Неоплаченная выручка, запасы, погашение займа и обязательства.</p></div>
          <div><span>Действие</span><p>Ускорить оплату покупателей и пересмотреть объём закупки.</p></div>
          <div><span>Проверка</span><p>Через 14 дней сравнить фактический остаток с ожидаемым.</p></div>
        </div>
      </article>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="featured-questions-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div>
          <p class="section-kicker">После сигнала</p>
          <h2 id="featured-questions-title">Увидели важное — спросите, что это меняет для решения.</h2>
        </div>
        <p>Уточните причину, проверьте другой сценарий или раскройте цифру до операции. Если данных не хватает, Aivel покажет пробел; если нужно суждение — подключит специалиста.</p>
      </div>
      <div class="question-grid">
        {featuredQuestions.map((question) => (
          <QuestionCard
            slug={question.id}
            title={question.data.title}
            description={question.data.description}
            categoryLabel={question.data.categoryLabel}
          />
        ))}
      </div>
      <p style="margin-top: 28px;"><a class="text-link" href="/vazhnoe/#voprosy">Все десять вопросов <Icon name="arrow" size={20} /></a></p>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="enterprise-title">
    <div class="container enterprise-proof">
      <div class="enterprise-proof-copy" data-reveal>
        <p class="section-kicker section-kicker-light">Опыт сложных контуров</p>
        <h2 id="enterprise-title">Технология, которой доверяют крупные учётные процессы.</h2>
        <p>Опыт работы с 1С, правами доступа, историей действий и исключениями подтверждает дисциплину технологии. Для растущего бизнеса она превращается в сигналы и ответы, которые можно проверить до источника.</p>
        <a class="button button-light" href="/krupnym-kompaniyam/">Решения для крупных компаний</a>
      </div>
      <div class="tech-map" aria-label="Схема технологического контура" data-reveal>
        <div class="tech-stack">
          <div class="tech-node"><span>Источники</span><strong>1С, банк, документы</strong></div>
          <div class="tech-node"><span>Контроль</span><strong>Права и периметр</strong></div>
        </div>
        <div class="tech-center"><span>Aivel</span><strong>Изменение → основание → действие</strong></div>
        <div class="tech-stack">
          <div class="tech-node"><span>Проверка</span><strong>История и исключения</strong></div>
          <div class="tech-node"><span>Результат</span><strong>Сигнал, вопрос или специалист</strong></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="quotes-title">
    <div class="container">
      <div class="section-heading" data-reveal>
        <div>
          <p class="section-kicker">Публичный опыт Aivel</p>
          <h2 id="quotes-title">Технология замечает повторяющееся и отклонения. Люди сохраняют решение за собой.</h2>
        </div>
        <p>Отзывы относятся к корпоративным внедрениям и доказывают опыт автоматизации и контроля, а не готовность нового режима сигналов для каждого клиента.</p>
      </div>
      <div class="proof-grid">
        <article class="quote-card" data-reveal>
          <span class="quote-mark" aria-hidden="true">“</span>
          <blockquote>ИИ-бухгалтер упростил работу с актами сверки и входящими документами. Мы смогли обеспечить кратный рост бизнеса без увеличения штата финансовой службы.</blockquote>
          <div class="quote-person"><strong>Лилия Г.</strong><span>Главный бухгалтер DDX</span></div>
        </article>
        <article class="quote-card" data-reveal>
          <span class="quote-mark" aria-hidden="true">“</span>
          <blockquote>Внедрение технологии позволило сократить количество повторных визитов, повысить лояльность клиентов и в три раза уменьшить затраты на контроль.</blockquote>
          <div class="quote-person"><strong>Андрей Арефьев</strong><span>Генеральный директор «Лантер», группа «Ланит»</span></div>
        </article>
        <article class="quote-card" data-reveal>
          <span class="quote-mark" aria-hidden="true">“</span>
          <blockquote>ИИ-аналитика диалогов помогла найти нестандартные точки роста продаж и получить персональные рекомендации развития менеджеров.</blockquote>
          <div class="quote-person"><strong>Денис Мосалев</strong><span>Руководитель направления, «ВсеИнструменты.ру»</span></div>
        </article>
      </div>
      <p style="margin-top: 30px;"><a class="text-link" href="/rezultaty/">Все подтверждённые результаты <Icon name="arrow" size={20} /></a></p>
    </div>
  </section>

  <section class="section" aria-labelledby="partner-title">
    <div class="container partner-panel" data-reveal>
      <div>
        <p class="section-kicker">Бухгалтерским компаниям</p>
        <h2 id="partner-title">Расти без роста операционной рутины. Стать финансовым партнёром клиентов.</h2>
        <p>Aivel берёт на себя повторяющиеся операции, наблюдение за данными и передачу исключений. Владелец бухгалтерской компании меньше управляет потоком задач и больше помогает клиенту понимать деньги, риски и варианты действий.</p>
        <a class="button button-primary" href="/buhgalterskim-kompaniyam/">Почему присоединяться сейчас</a>
      </div>
      <div class="partner-role-card">
        <div class="role-shift">
          <div class="role-box"><span>Сегодня</span><strong>Управляющий операциями</strong></div>
          <div class="role-arrow"><Icon name="arrow" size={28} /></div>
          <div class="role-box"><span>С Aivel</span><strong>Консультант для клиента</strong></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="faq-title">
    <div class="container faq-layout">
      <div class="faq-intro" data-reveal>
        <p class="section-kicker">Вопросы и ответы</p>
        <h2 id="faq-title">Сильное обещание — с видимой границей.</h2>
        <p>Значимость, свежесть и охват — часть сигнала, а не мелкий шрифт после него.</p>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details data-reveal>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container" data-reveal>
      <p class="section-kicker section-kicker-light">Следующий шаг</p>
      <h2>Что в вашем бизнесе нельзя узнать слишком поздно?</h2>
      <p>Разберём, какие изменения требуют вашего внимания, где лежат данные и какие правила должны срабатывать первыми.</p>
      <button class="button button-light" type="button" data-open-contact>Определить важные сигналы</button>
    </div>
  </section>
</BaseLayout>

<style>
  .module-proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-top: 36px;
  }

  .module-proof-card {
    min-height: 310px;
    display: flex;
    flex-direction: column;
    padding: 28px;
    border: 1px solid rgba(19, 41, 34, 0.14);
    border-radius: 22px;
    color: inherit;
    background: #fff;
    text-decoration: none;
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }

  .module-proof-card:hover,
  .module-proof-card:focus-visible {
    border-color: var(--ink, #132922);
    box-shadow: 0 18px 50px rgba(19, 41, 34, 0.09);
  }

  .module-proof-card > span {
    min-height: 44px;
    color: var(--muted-text, #5d6b66);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .module-proof-card strong {
    display: block;
    margin: 28px 0 14px;
    font-size: clamp(1.55rem, 2.7vw, 2.5rem);
    line-height: 1.05;
  }

  .module-proof-card p {
    margin: 0;
  }

  .module-proof-card small {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 28px;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .proof-method-note {
    max-width: 900px;
    margin: 24px 0 18px;
    color: var(--muted-text, #5d6b66);
    font-size: 0.9rem;
  }

  @media (max-width: 1020px) {
    .module-proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .module-proof-grid {
      grid-template-columns: 1fr;
    }

    .module-proof-card {
      min-height: 260px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .module-proof-card {
      transition: none;
    }
  }
</style>

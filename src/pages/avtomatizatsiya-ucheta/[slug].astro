      { title: "Права и роли", text: "Разделение разрешённых действий людей и ИИ-помощников." },
      { title: "Журнал действий", text: "Исходные данные, выполненное действие, исключение и результат проверки." }
    ],
    resultKicker: "Устройство контроля",
    resultTitle: "Три линии контроля вместо обещания нулевой ошибки.",
    resultLead: "Согласованность данных, оценка неоднозначности и человек в контуре работают вместе. Ни одна линия сама по себе не гарантирует безошибочность.",
    metrics: [
      { value: "3", label: "линии контроля качества" }
    ],
    measure: [
      "Заранее определяем правильный результат и допустимую границу уверенности.",
      "Считаем ошибочные совпадения, пропуски и долю передачи человеку.",
      "Проверяем контрольную выборку независимо от автоматического результата.",
      "Сохраняем причины исправлений и повторно проверяем процесс после изменения правил."
    ],
    measureSummary: "Для контрольной выборки отдельно считаются ошибочные совпадения, пропуски и доля передачи человеку; исправления сохраняются и проверяются повторно.",
    limits: [
      "Контроль снижает риск, но не создаёт гарантии отсутствия ошибок.",
      "Качество проверки зависит от эталонной выборки и полноты исходных данных.",
      "Профессиональное суждение и ответственность не передаются системе.",
      "Показатель качества имеет смысл только вместе с объёмом, периодом и видом процесса."
    ],
    limitSummary: "Три линии контроля снижают риск, но не гарантируют отсутствие ошибок. Качество вывода зависит от эталонной выборки и полноты исходных данных.",
    related: [
      { href: "/zashchita-dannyh/", label: "Защита данных" },
      { href: "/ogranicheniya/", label: "Границы решения" }
    ]
  }
];
  return pages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;

const commonDemo = {
  driveId: "1Brk_NX4ubphUg5mkhmDCxTWnTxE_De5A",
  title: "Как несколько ИИ-помощников работают вместе",
  description: "Это общий обзор совместной работы нескольких помощников. Он показывает подход Aivel, но не является отдельным доказательством именно этого процесса."
};

const hasDedicatedDemo = Boolean(page.demo);
const demo = page.demo ?? commonDemo;
const processSteps = [
  { title: "Получает вход", text: page.actions[0] },
  { title: "Понимает контекст", text: page.actions.slice(1, 3).join(" ") },
  { title: "Доводит до результата", text: page.actions.slice(3).join(" ") },
  { title: "Передаёт исключение", text: page.human.join(" ") }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: page.kicker,
  description: page.description,
  provider: { "@type": "Organization", name: "Aivel" },
  areaServed: "RU"
};
---

<BaseLayout title={page.metaTitle} description={page.description} schema={schema}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки"><a href="/">Главная</a><span aria-hidden="true">/</span><a href="/kak-rabotaet/">Как это работает</a><span aria-hidden="true">/</span><a href="/avtomatizatsiya-ucheta/">Автоматизация учёта</a><span aria-hidden="true">/</span><span>{page.kicker}</span></div>
  <header class="page-hero assistant-hero">
    <div class="container assistant-hero-grid">
      <div>
        <p class="section-kicker">ИИ-помощник · {page.kicker}</p>
        <h1>{page.title}</h1>
        <p class="lead">{page.lead}</p>
      </div>
      <aside class="assistant-hero-proof" aria-label="Главный результат и связь с важным сигналом">
        <div class="hero-outcome">
          <span>Результат процесса</span>
          <strong>{page.heroOutcome.value}</strong>
          <p>{page.heroOutcome.label}</p>
        </div>
        <div class="hero-signal-link">
          <span><Icon name="chart" size={20} /></span>
          <div><strong>{page.asideTitle}</strong><p>{page.asideText}</p></div>
        </div>
      </aside>
    </div>
  </header>

  <section class="section section-warm assistant-operation" aria-labelledby="operation-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div>
          <p class="section-kicker">Операция целиком</p>
          <h2 id="operation-title">От входящих данных — до результата и исключения человеку.</h2>
        </div>
        <p>{page.task}</p>
      </div>

      <VideoDemo driveId={demo.driveId} title={demo.title} description={demo.description} />
      {!hasDedicatedDemo && <p class="shared-demo-note"><Icon name="source" size={17} /> Общий ролик показывает совместную работу нескольких ИИ-помощников; отдельную операцию проверяем на демонстрации.</p>}

      <ol class="assistant-flow" aria-label={`Как работает ИИ-помощник «${page.kicker}»`}>
        {processSteps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div><h3>{step.title}</h3><p>{step.text}</p></div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section section-dark assistant-result" aria-labelledby="result-title">
    <div class="container result-layout">
      <div>
        <p class="section-kicker section-kicker-light">{page.resultKicker}</p>
        <h2 id="result-title">{page.resultTitle}</h2>
        <p>{page.resultLead}</p>
      </div>
      <div class="metric-grid">
        {page.metrics.map((metric) => <article><strong>{metric.value}</strong><p>{metric.label}</p></article>)}
      </div>
    </div>
    <div class="container result-proof-strip">
      <article><span><Icon name="check" size={19} /></span><div><strong>Как проверяли</strong><p>{page.measureSummary}</p></div></article>
      <article><span><Icon name="shield" size={19} /></span><div><strong>Граница вывода</strong><p>{page.limitSummary}</p></div></article>
    </div>
  </section>

  <section class="section assistant-difference" aria-labelledby="difference-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div>
          <p class="section-kicker">Отличие Aivel</p>
          <h2 id="difference-title">Не обработать фрагмент. Завершить разрешённый процесс.</h2>
        </div>
        <p>Точечное решение отдаёт промежуточный результат человеку. Aivel проверяет связи, выполняет допустимое действие и сохраняет историю.</p>
      </div>

      <div class="assistant-comparison">
        <article class="point-solution">
          <span class="comparison-label">Точечное решение</span>
          <h3>Закрывает один шаг.</h3>
          <ul>
            <li><Icon name="document" size={19} /> Получает отдельный файл или запись</li>
            <li><Icon name="source" size={19} /> Возвращает поля, метку или черновик</li>
            <li><Icon name="person" size={19} /> Остальной путь завершает человек</li>
          </ul>
        </article>
        <article class="aivel-solution">
          <span class="comparison-label">Aivel</span>
          <h3>Доводит операцию до результата.</h3>
          <div class="connection-list">
            {page.connections.map((connection) => (
              <div><Icon name="check" size={18} /><span><strong>{connection.title}</strong>{connection.text}</span></div>
            ))}
          </div>
          <p><Icon name="source" size={18} /> Источник, проверки, действие и передача исключения остаются в аудиторском следе.</p>
        </article>
      </div>

      <div class="final-panel assistant-final">
        <div><p class="section-kicker">Проверка на вашем процессе</p><h2>Покажем работу на обезличенной выборке.</h2><p>Зафиксируем исходный показатель, границу участия человека и условие успешной проверки.</p></div>
        <button class="button button-primary" type="button" data-open-contact data-contact-topic="unknown">Запросить демонстрацию</button>
      </div>
      <nav class="related-links" aria-label="Связанные страницы">
        <a href="/avtomatizatsiya-ucheta/">Все ИИ-помощники <Icon name="arrow" size={18} /></a>
        {page.related.map((item) => <a href={item.href}>{item.label} <Icon name="arrow" size={18} /></a>)}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .process-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(48px, 9vw, 120px);
    align-items: start;
  }

  .process-intro {
    position: sticky;
    top: calc(var(--header-height) + 32px);
  }

  .process-intro h2 {
    margin-bottom: 22px;
  }

  .process-intro p:last-child {
    max-width: 540px;
    font-size: 1.12rem;
  }

  .process-actions h3 {
    margin-bottom: 24px;
  }

  .process-actions ol {
    display: grid;
    gap: 12px;
    padding: 0;
    list-style: none;
  }

  .process-actions li {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 18px;
    align-items: start;
    padding: 22px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .process-actions li span {
    color: var(--color-gold);
    font-size: 0.8rem;
    font-weight: 720;
    letter-spacing: 0.08em;
  }

  .process-actions li p {
    margin: 0;
  }

  .human-grid,
  .connection-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .human-grid article,
  .connection-grid article {
    min-height: 220px;
    padding: 26px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .human-grid article > span,
  .connection-grid article > span {
    display: grid;
    width: 48px;
    height: 48px;
    margin-bottom: 30px;
    place-items: center;
    color: var(--color-gold);
    background: var(--color-gold-pale);
    border-radius: 50%;
  }

  .human-grid p,
  .connection-grid p {
    margin: 0;
  }

  .connection-grid h3 {
    margin-bottom: 12px;
  }

  .result-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(48px, 9vw, 120px);
    align-items: center;
  }

  .result-layout h2 {
    margin-bottom: 22px;
    color: white;
  }

  .result-layout > div:first-child > p:last-child {
    max-width: 690px;
    margin: 0;
    color: #cbd5e1;
    font-size: 1.08rem;
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .metric-grid article {
    min-height: 170px;
    padding: 24px;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.17);
    border-radius: var(--radius-md);
  }

  .metric-grid strong {
    display: block;
    margin-bottom: 14px;
    color: var(--color-gold-soft);
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .metric-grid p {
    margin: 0;
    color: white;
  }

  .metric-grid article:only-child {
    grid-column: 1 / -1;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(40px, 8vw, 96px);
    align-items: start;
  }

  .evidence-block h2 {
    max-width: 720px;
    margin-bottom: 34px;
  }

  .evidence-block ul,
  .limit-block ul {
    display: grid;
    gap: 14px;
    padding: 0;
    list-style: none;
  }

  .evidence-block li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
  }

  .evidence-block li svg {
    margin-top: 4px;
    color: var(--color-green);
  }

  .limit-block {
    padding: 30px;
    background: var(--color-warm);
    border: 1px solid #eadfcb;
    border-radius: var(--radius-lg);
  }

  .limit-block h3 {
    margin-bottom: 24px;
  }

  .limit-block li {
    position: relative;
    padding-left: 20px;
    color: var(--color-text);
  }

  .limit-block li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 7px;
    height: 7px;
    background: var(--color-gold);
    border-radius: 50%;
    content: "";
  }

  .final-panel {
    display: flex;
    gap: 40px;
    align-items: end;
    justify-content: space-between;
    padding: clamp(30px, 6vw, 60px);
    background: white;
    border: 1px solid #eadfcb;
    border-radius: var(--radius-xl);
  }

  .final-panel > div {
    max-width: 760px;
  }

  .final-panel h2 {
    margin-bottom: 18px;
  }

  .final-panel p:last-child {
    margin: 0;
  }

  .final-panel .button {
    flex: 0 0 auto;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .related-links a {
    display: inline-flex;
    min-height: 44px;
    gap: 8px;
    align-items: center;
    padding: 9px 14px;
    background: transparent;
    border: 1px solid #d9cdb8;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }

  .related-links a:hover {
    background: white;
    border-color: var(--color-gold);
  }

  .assistant-hero {
    padding-block: clamp(44px, 6vw, 78px);
  }

  .assistant-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.72fr);
    gap: clamp(42px, 7vw, 96px);
    align-items: center;
  }

  .assistant-hero h1 {
    max-width: 900px;
    font-size: clamp(3rem, 5vw, 4rem);
  }

  .assistant-hero-proof {
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .hero-outcome {
    padding: clamp(24px, 3vw, 36px);
    color: white;
    background: var(--color-ink);
  }

  .hero-outcome > span,
  .comparison-label {
    display: block;
    margin-bottom: 10px;
    color: var(--color-gold-soft);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .hero-outcome strong {
    display: block;
    margin-bottom: 10px;
    color: var(--color-gold-soft);
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .hero-outcome p {
    margin: 0;
    color: #d4deea;
    line-height: 1.48;
  }

  .hero-signal-link {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 12px;
    padding: 22px 24px;
    align-items: start;
  }

  .hero-signal-link > span {
    display: grid;
    width: 40px;
    height: 40px;
    color: var(--color-blue);
    background: var(--color-blue-pale);
    border-radius: 12px;
    place-items: center;
  }

  .hero-signal-link strong {
    display: block;
    margin-bottom: 5px;
  }

  .hero-signal-link p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.84rem;
    line-height: 1.48;
  }

  .compact-heading {
    margin-bottom: 22px;
  }

  .assistant-operation,
  .assistant-result,
  .assistant-difference {
    padding-block: clamp(44px, 4vw, 56px);
  }

  .assistant-operation .section-heading h2,
  .assistant-difference .section-heading h2 {
    font-size: clamp(2.2rem, 3.6vw, 3.2rem);
  }

  .assistant-operation :global(.video-demo-copy) {
    padding: clamp(22px, 3vw, 32px);
  }

  .assistant-operation :global(.video-demo-copy h3) {
    font-size: clamp(1.55rem, 2.5vw, 2.4rem);
  }

  .shared-demo-note {
    display: flex;
    max-width: 900px;
    gap: 8px;
    align-items: flex-start;
    margin: 14px 0 0;
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  .shared-demo-note svg {
    flex: 0 0 auto;
    color: var(--color-blue);
  }

  .assistant-flow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 16px 0 0;
    overflow: hidden;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    list-style: none;
  }

  .assistant-flow li {
    min-width: 0;
    padding: 17px;
    background: white;
  }

  .assistant-flow li > span {
    display: block;
    margin-bottom: 13px;
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .assistant-flow h3 {
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .assistant-flow p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.72rem;
    line-height: 1.46;
  }

  .result-proof-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: clamp(24px, 3vw, 34px);
  }

  .result-proof-strip article {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 12px;
    padding: 18px;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: var(--radius-md);
  }

  .result-proof-strip article > span {
    display: grid;
    width: 38px;
    height: 38px;
    color: var(--color-gold-soft);
    border: 1px solid rgb(245 201 121 / 0.3);
    border-radius: 11px;
    place-items: center;
  }

  .result-proof-strip strong {
    display: block;
    margin-bottom: 5px;
    color: white;
  }

  .result-proof-strip p {
    margin: 0;
    color: #c3cfde;
    font-size: 0.8rem;
    line-height: 1.48;
  }

  .assistant-difference {
    background: var(--color-paper);
  }

  .assistant-comparison {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 14px;
  }

  .assistant-comparison > article {
    padding: clamp(22px, 2.5vw, 28px);
    border-radius: var(--radius-lg);
  }

  .point-solution {
    background: white;
    border: 1px solid var(--color-border);
  }

  .point-solution .comparison-label {
    color: var(--color-muted);
  }

  .aivel-solution {
    color: white;
    background: var(--color-ink);
    border: 1px solid var(--color-ink);
  }

  .aivel-solution h3 {
    color: white;
  }

  .assistant-comparison h3 {
    margin-bottom: 16px;
  }

  .point-solution ul,
  .connection-list {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .point-solution li,
  .connection-list > div {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: 10px;
    padding: 10px 0;
    border-top: 1px solid var(--color-border);
    line-height: 1.45;
  }

  .point-solution li svg {
    color: var(--color-muted);
  }

  .connection-list > div {
    border-color: rgb(255 255 255 / 0.14);
  }

  .connection-list svg {
    margin-top: 3px;
    color: var(--color-gold-soft);
  }

  .connection-list span,
  .connection-list strong {
    display: block;
  }

  .connection-list span {
    color: #c3cfde;
    font-size: 0.85rem;
  }

  .connection-list strong {
    margin-bottom: 3px;
    color: white;
  }

  .aivel-solution > p {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    padding-top: 14px;
    margin: 14px 0 0;
    color: #c3cfde;
    border-top: 1px solid rgb(255 255 255 / 0.14);
    font-size: 0.82rem;
  }

  .aivel-solution > p svg {
    flex: 0 0 auto;
    color: var(--color-gold-soft);
  }

  .assistant-final {
    padding: clamp(22px, 2.5vw, 28px);
    margin-top: clamp(24px, 3vw, 30px);
  }

  .assistant-final h2 {
    margin-bottom: 10px;
    font-size: clamp(1.9rem, 2.8vw, 2.3rem);
  }

  .assistant-final p:last-child {
    font-size: 0.92rem;
  }

  .assistant-difference .related-links {
    margin-top: 16px;
  }

  .assistant-result .result-layout {
    gap: clamp(34px, 6vw, 76px);
  }

  .assistant-result .result-layout h2 {
    font-size: clamp(2.3rem, 4vw, 3.8rem);
  }


---

<BaseLayout title={page.metaTitle} description={page.description} schema={schema}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки"><a href="/">Главная</a><span aria-hidden="true">/</span><a href="/kak-rabotaet/">Как это работает</a><span aria-hidden="true">/</span><a href="/avtomatizatsiya-ucheta/">Автоматизация учёта</a><span aria-hidden="true">/</span><span>{page.kicker}</span></div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div><p class="section-kicker">{page.kicker}</p><h1>{page.title}</h1><p class="lead">{page.lead}</p></div>
      <aside class="page-hero-aside"><strong>{page.asideTitle}</strong><p>{page.asideText}</p></aside>
    </div>
  </header>

  <section class="section" aria-labelledby="task-title">
    <div class="container process-layout">
      <div class="process-intro"><p class="section-kicker">Задача</p><h2 id="task-title">Что должен изменить процесс</h2><p>{page.task}</p></div>
      <div class="process-actions">
        <h3>Что делает ИИ-помощник</h3>
        <ol>
          {page.actions.map((action, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><p>{action}</p></li>)}
        </ol>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="human-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Разделение ответственности</p><h2 id="human-title">Что остаётся человеку</h2></div><p>Автоматизация не забирает профессиональное суждение и не маскирует исключение под завершённую операцию.</p></div>
      <div class="human-grid">
        {page.human.map((item) => <article><span><Icon name="person" size={24} /></span><p>{item}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="connections-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Соединения</p><h2 id="connections-title">С какими системами связан процесс</h2></div><p>Точный состав зависит от периметра, прав и учётной конфигурации заказчика.</p></div>
      <div class="connection-grid">
        {page.connections.map((connection) => <article><span><Icon name="source" size={24} /></span><h3>{connection.title}</h3><p>{connection.text}</p></article>)}
      </div>
    </div>
  </section>

  {"demo" in page && page.demo && (
    <section class="section section-warm" aria-labelledby="demo-title">
      <div class="container">
        <div class="section-heading"><div><p class="section-kicker">Настоящая работа</p><h2 id="demo-title">Посмотрите процесс на экране.</h2></div><p>Ролик показывает саму последовательность действий. Показатели результата и ограничения приведены отдельно ниже.</p></div>
        <VideoDemo driveId={page.demo.driveId} title={page.demo.title} description={page.demo.description} />
      </div>
    </section>
  )}

  <section class="section section-dark" aria-labelledby="result-title">
    <div class="container result-layout">
      <div><p class="section-kicker section-kicker-light">{page.resultKicker}</p><h2 id="result-title">{page.resultTitle}</h2><p>{page.resultLead}</p></div>
      <div class="metric-grid">
        {page.metrics.map((metric) => <article><strong>{metric.value}</strong><p>{metric.label}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="measure-title">
    <div class="container evidence-grid">
      <div class="evidence-block">
        <p class="section-kicker">Как измерять</p>
        <h2 id="measure-title">Показатель должен выдержать проверку.</h2>
        <ul>{page.measure.map((item) => <li><Icon name="check" size={20} /><span>{item}</span></li>)}</ul>
      </div>
      <aside class="limit-block">
        <p class="section-kicker">Ограничения</p>
        <h3>Где нельзя обещать больше</h3>
        <ul>{page.limits.map((item) => <li>{item}</li>)}</ul>
      </aside>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container final-panel">
      <div><p class="section-kicker">Проверка на вашем процессе</p><h2>Покажем работу на обезличенной выборке.</h2><p>До разговора о расширении зафиксируем исходный показатель, границу участия человека и условие успешной проверки.</p></div>
      <button class="button button-primary" type="button" data-open-contact data-contact-topic="unknown">Запросить демонстрацию</button>
    </div>
    <nav class="container related-links" aria-label="Связанные страницы">
      <a href="/avtomatizatsiya-ucheta/">Все учётные процессы <Icon name="arrow" size={18} /></a>
      {page.related.map((item) => <a href={item.href}>{item.label} <Icon name="arrow" size={18} /></a>)}
    </nav>
  </section>
</BaseLayout>

<style>
  .process-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(48px, 9vw, 120px);
    align-items: start;
  }

  .process-intro {
    position: sticky;
    top: calc(var(--header-height) + 32px);
  }

  .process-intro h2 {
    margin-bottom: 22px;
  }

  .process-intro p:last-child {
    max-width: 540px;
    font-size: 1.12rem;
  }

  .process-actions h3 {
    margin-bottom: 24px;
  }

  .process-actions ol {
    display: grid;
    gap: 12px;
    padding: 0;
    list-style: none;
  }

  .process-actions li {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 18px;
    align-items: start;
    padding: 22px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .process-actions li span {
    color: var(--color-gold);
    font-size: 0.8rem;
    font-weight: 720;
    letter-spacing: 0.08em;
  }

  .process-actions li p {
    margin: 0;
  }

  .human-grid,
  .connection-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .human-grid article,
  .connection-grid article {
    min-height: 220px;
    padding: 26px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .human-grid article > span,
  .connection-grid article > span {
    display: grid;
    width: 48px;
    height: 48px;
    margin-bottom: 30px;
    place-items: center;
    color: var(--color-gold);
    background: var(--color-gold-pale);
    border-radius: 50%;
  }

  .human-grid p,
  .connection-grid p {
    margin: 0;
  }

  .connection-grid h3 {
    margin-bottom: 12px;
  }

  .result-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(48px, 9vw, 120px);
    align-items: center;
  }

  .result-layout h2 {
    margin-bottom: 22px;
    color: white;
  }

  .result-layout > div:first-child > p:last-child {
    max-width: 690px;
    margin: 0;
    color: #cbd5e1;
    font-size: 1.08rem;
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .metric-grid article {
    min-height: 170px;
    padding: 24px;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.17);
    border-radius: var(--radius-md);
  }

  .metric-grid strong {
    display: block;
    margin-bottom: 14px;
    color: var(--color-gold-soft);
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .metric-grid p {
    margin: 0;
    color: white;
  }

  .metric-grid article:only-child {
    grid-column: 1 / -1;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(40px, 8vw, 96px);
    align-items: start;
  }

  .evidence-block h2 {
    max-width: 720px;
    margin-bottom: 34px;
  }

  .evidence-block ul,
  .limit-block ul {
    display: grid;
    gap: 14px;
    padding: 0;
    list-style: none;
  }

  .evidence-block li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
  }

  .evidence-block li svg {
    margin-top: 4px;
    color: var(--color-green);
  }

  .limit-block {
    padding: 30px;
    background: var(--color-warm);
    border: 1px solid #eadfcb;
    border-radius: var(--radius-lg);
  }

  .limit-block h3 {
    margin-bottom: 24px;
  }

  .limit-block li {
    position: relative;
    padding-left: 20px;
    color: var(--color-text);
  }

  .limit-block li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 7px;
    height: 7px;
    background: var(--color-gold);
    border-radius: 50%;
    content: "";
  }

  .final-panel {
    display: flex;
    gap: 40px;
    align-items: end;
    justify-content: space-between;
    padding: clamp(30px, 6vw, 60px);
    background: white;
    border: 1px solid #eadfcb;
    border-radius: var(--radius-xl);
  }

  .final-panel > div {
    max-width: 760px;
  }

  .final-panel h2 {
    margin-bottom: 18px;
  }

  .final-panel p:last-child {
    margin: 0;
  }

  .final-panel .button {
    flex: 0 0 auto;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .related-links a {
    display: inline-flex;
    min-height: 44px;
    gap: 8px;
    align-items: center;
    padding: 9px 14px;
    background: transparent;
    border: 1px solid #d9cdb8;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 650;
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }

  .related-links a:hover {
    background: white;
    border-color: var(--color-gold);
  }

  @media (max-width: 900px) {
    .process-layout,
    .result-layout,
    .evidence-grid {
      grid-template-columns: 1fr;
    }

    .process-intro {
      position: static;
    }

    .human-grid,
    .connection-grid {
      grid-template-columns: 1fr;
    }

    .human-grid article,
    .connection-grid article {
      min-height: 0;
    }
  }

  @media (max-width: 620px) {
    .metric-grid {
      grid-template-columns: 1fr;
    }

    .metric-grid article:only-child {
      grid-column: auto;
    }

    .final-panel {
      align-items: stretch;
      flex-direction: column;
    }

    .final-panel .button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-links a {
      transition: none;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { contentReviewedAt, site } from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "О компании Aivel",
    description: "Проверяемые сведения о бухгалтерской и технологической компании Aivel.",
    url: `${site.url}/o-kompanii/`,
    dateModified: contentReviewedAt.iso,
    inLanguage: "ru-RU",
    about: { "@id": `${site.url}/#organization` }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${site.url}/#organization`,
    name: "Aivel",
    url: site.url,
    email: "info@aivel.ru",
    description: site.description
  }
];
---

<BaseLayout
  title="О компании Aivel"
  description="Aivel — бухгалтерская и технологическая компания: сопровождение бизнеса, автоматизация учёта, важные изменения и проверяемые ответы."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>О компании</span>
  </div>

  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">О компании</p>
        <h1>Aivel соединяет бухгалтерское сопровождение и технологию учёта.</h1>
        <p class="lead">Мы помогаем бизнесу вести учёт, вовремя замечать важные изменения и проверять основание до решения. Для крупных компаний Aivel автоматизирует выбранные участки учёта.</p>
      </div>
      <aside class="page-hero-aside">
        <strong>Официальная связь</strong>
        <p><a href="mailto:info@aivel.ru">info@aivel.ru</a></p>
        <p>Не отправляйте финансовые данные через открытую почту. Сначала согласуем защищённый способ обмена.</p>
      </aside>
    </div>
  </header>

  <section class="section" aria-labelledby="work-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Три направления</p><h2 id="work-title">Одна учётная основа — разные способы приносить ценность.</h2></div>
        <p>Конечный бизнес, крупные компании и бухгалтерские компании покупают разный результат, но используют общую дисциплину данных и исключений.</p>
      </div>
      <div class="numbered-grid">
        <article class="numbered-card">
          <h3>Растущему бизнесу</h3>
          <p>Учёт для бизнеса, своевременные изменения и проверяемые ответы о деньгах, прибыли, обязательствах и росте.</p>
          <a class="text-link" href="/buhgalterskoe-soprovozhdenie/">Для бизнеса <Icon name="arrow" size={18} /></a>
        </article>
        <article class="numbered-card">
          <h3>Крупным компаниям</h3>
          <p>Автоматизация первичных документов, банковских операций, обращений и сверок в согласованном контуре.</p>
          <a class="text-link" href="/krupnym-kompaniyam/">Решения для крупных компаний <Icon name="arrow" size={18} /></a>
        </article>
        <article class="numbered-card">
          <h3>Бухгалтерским компаниям</h3>
          <p>Общая технология и производственный контур, которые снижают зависимость от ручной рутины и помогают владельцу перейти к консультационной роли.</p>
          <a class="text-link" href="/buhgalterskim-kompaniyam/">Партнёрство с Aivel <Icon name="arrow" size={18} /></a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="principles-title">
    <div class="container content-layout">
      <div><p class="section-kicker">Принципы</p><h2 id="principles-title">Технология не должна создавать новую непрозрачность.</h2></div>
      <div class="prose">
        <p><strong>Источник виден.</strong> Сигнал или ответ показывает период, свежесть, расчёт и путь до разрешённого основания.</p>
        <p><strong>Граница видна.</strong> Неполные данные, расхождения и профессиональное суждение не маскируются уверенным текстом.</p>
        <p><strong>Человек отвечает за суждение.</strong> ИИ обрабатывает повторяющееся, а исключение, налоговая оценка и решение остаются у ответственного специалиста.</p>
        <p><a class="text-link" href="/rezultaty/">Измеримые результаты внедрений <Icon name="arrow" size={18} /></a></p>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container content-layout">
      <div><p class="section-kicker section-kicker-light">Проверяемость</p><h2 style="color: white;">Открытые сведения без скрытой версии.</h2></div>
      <div class="prose about-links">
        <p>Краткие факты, возможности, ограничения, методика показателей и машиночитаемые ссылки собраны в отдельном открытом реестре.</p>
        <p><a class="text-link light-link" href="/dlya-ii-agentov/">Сведения для ИИ-систем <Icon name="arrow" size={18} /></a></p>
        <p class="reviewed">Сведения проверены {contentReviewedAt.label}.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero-aside a {
    color: var(--color-blue);
    font-size: 1.12rem;
    font-weight: 700;
  }

  .about-links p {
    color: #c3cfde;
  }

  .about-links .light-link,
  .about-links .reviewed {
    color: var(--color-gold-soft);
  }
</style>

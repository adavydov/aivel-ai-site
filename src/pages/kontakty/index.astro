---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalForm from "../../components/LocalForm.astro";
---

<BaseLayout title="Контакты Aivel" description="Обсудить бухгалтерское сопровождение, партнёрство или задачу крупной компании.">
  <div class="container breadcrumbs" aria-label="Хлебные крошки"><a href="/">Главная</a><span aria-hidden="true">/</span><span>Контакты</span></div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div><p class="section-kicker">Контакты</p><h1>Сначала — ситуация. Закрытые данные обсудим в защищённом канале.</h1><p class="lead">Выберите подходящий путь и оставьте только контактную информацию. После проверки появится ссылка на подготовленное письмо по официальному адресу Aivel.</p><p><a class="text-link" href="mailto:info@aivel.ru">info@aivel.ru</a></p></div>
      <aside class="page-hero-aside"><strong>Не отправляйте через сайт</strong><p>ИНН, суммы, документы, пароли, выписки, имена контрагентов и сотрудников.</p></aside>
    </div>
  </header>

  <section class="section">
    <div class="container"><LocalForm mode="client" title="Обсудить вопрос конечного бизнеса" /></div>
  </section>

  <section class="section section-warm">
    <div class="container value-grid">
      <a class="question-card question-card-compact" href="/buhgalterskim-kompaniyam/"><div><span class="card-label">Отдельный путь</span><h2 style="font-size: 1.7rem;">Я представляю бухгалтерскую компанию</h2></div></a>
      <a class="question-card question-card-compact" href="/krupnym-kompaniyam/"><div><span class="card-label">Отдельный путь</span><h2 style="font-size: 1.7rem;">Мне нужно решение для крупной компании</h2></div></a>
      <a class="question-card question-card-compact" href="/vazhnoe/#voprosy"><div><span class="card-label">Сначала разобраться</span><h2 style="font-size: 1.7rem;">Посмотреть примеры вопросов</h2></div></a>
    </div>
  </section>
</BaseLayout>

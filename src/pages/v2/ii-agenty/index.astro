---
import V2Layout from "../../../layouts/V2Layout.astro";
import { processMailto, v2CustomerCases, v2Site } from "../../../data/v2";

const title = "Кейсы внедрения ИИ в бухгалтерии — Aivel 2.0";
const description =
  "Кейсы Aivel: ДДХ вырос в два раза без найма новых бухгалтеров; в Нефтьмагистрали и Братьях Караваевых 70% первичных документов обрабатывались без участия человека.";
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: `${v2Site.url}/v2/ii-agenty/`,
  hasPart: v2CustomerCases.map((item) => ({
    "@type": "CreativeWork",
    name: `${item.company}: ${item.metric}. ${item.title}`,
    description: item.text
  }))
};
---

<V2Layout title={title} description={description} schema={schema}>
  <section class="v2-section v2-page-hero" data-v2-screen="1">
    <div class="v2-shell">
      <p class="v2-eyebrow">Кейсы</p>
      <h1 class="v2-page-title">Результат в реальной работе.</h1>
      <p class="v2-lead">
        Не обещания автоматизации, а рост бизнеса без пропорционального роста бухгалтерской команды.
      </p>
      <a class="v2-text-link" href="/v2/uchet/">Посмотреть, как устроен учёт</a>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="2" aria-labelledby="v2-ddx-title">
    <div class="v2-shell">
      <article class="v2-client-story">
        <div class="v2-client-story__identity">
          <p class="v2-eyebrow">ДДХ</p>
          <figure class="v2-case-logo">
            <img src={v2CustomerCases[0].logos[0].src} alt={v2CustomerCases[0].logos[0].name} width="482" height="140" loading="lazy" decoding="async" />
          </figure>
        </div>
        <div class="v2-client-story__copy">
          <strong class="v2-case-metric">{v2CustomerCases[0].metric}</strong>
          <h2 class="v2-section-title" id="v2-ddx-title">{v2CustomerCases[0].title}</h2>
          <p class="v2-lead">{v2CustomerCases[0].text}</p>
        </div>
      </article>
    </div>
  </section>

  <section class="v2-section v2-section--soft" data-v2-screen="3" aria-labelledby="v2-primary-title">
    <div class="v2-shell">
      <article class="v2-client-story">
        <div class="v2-client-story__identity">
          <p class="v2-eyebrow">Первичные документы</p>
          <div class="v2-case-logos" aria-label="Нефтьмагистраль и Братья Караваевы">
            {v2CustomerCases[1].logos.map((logo) => (
              <figure class="v2-case-logo">
                <img src={logo.src} alt={logo.name} loading="lazy" decoding="async" />
              </figure>
            ))}
          </div>
        </div>
        <div class="v2-client-story__copy">
          <strong class="v2-case-metric">{v2CustomerCases[1].metric}</strong>
          <h2 class="v2-section-title" id="v2-primary-title">{v2CustomerCases[1].title}</h2>
          <p class="v2-lead">{v2CustomerCases[1].text}</p>
          <a class="v2-text-link" href="/avtomatizatsiya-ucheta/pervichnye-dokumenty/">Посмотреть весь процесс</a>
        </div>
      </article>
    </div>
  </section>

  <section class="v2-section v2-section--auto" data-v2-screen="4" aria-labelledby="v2-processes-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Что стоит за результатом</p>
      <h2 class="v2-section-title" id="v2-processes-title">ИИ выполняет операцию. Человек разбирает исключение.</h2>
      <p class="v2-lead">Каждый процесс можно открыть отдельно: увидеть входящие данные, работу помощника, роль специалиста и измеренный результат.</p>
      <nav class="v2-proof-links" aria-label="Подробные кейсы процессов">
        <a href="/avtomatizatsiya-ucheta/pervichnye-dokumenty/"><span>Первичные документы</span><strong>80% потока без ручного участия</strong></a>
        <a href="/avtomatizatsiya-ucheta/bankovskie-operatsii/"><span>Банковские операции</span><strong>98% точности сопоставления</strong></a>
        <a href="/avtomatizatsiya-ucheta/sverki-s-kontragentami/"><span>Сверки</span><strong>До 95% без участия человека</strong></a>
      </nav>
      <div class="v2-actions v2-case-actions">
        <a class="v2-button" href={processMailto}>Обсудить свой процесс</a>
        <a class="v2-text-link" href="/v2/uchet/">Наладить учёт</a>
      </div>
    </div>
  </section>
</V2Layout>

---
import { v2Site } from "../../../data/v2";

const destination = "/v2/avtomatizatsiya-bek-ofisa/";
const canonical = new URL(destination, v2Site.url).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ИИ-агенты для крупных компаний — Aivel</title>
    <meta
      name="description"
      content="Раздел об ИИ-агентах Aivel переехал на страницу автоматизации операций для крупных компаний."
    />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <p>Раздел переехал: <a href={destination}>ИИ-агенты для крупных компаний</a>.</p>
  </body>
</html>

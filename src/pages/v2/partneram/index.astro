---
import V2Layout from "../../../layouts/V2Layout.astro";
import { partnerMailto, v2PartnerFaq, v2Site } from "../../../data/v2";

const title = "Стать партнёром Aivel — для собственников бухгалтерских компаний";
const description =
  "Партнёрство Aivel для владельцев бухгалтерских компаний: расти без пропорционального найма и стать финансовым партнёром для клиента.";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: v2PartnerFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
};
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Партнёрство Aivel с бухгалтерскими компаниями",
  description,
  provider: { "@id": `${v2Site.url}/#organization` },
  audience: { "@type": "BusinessAudience", audienceType: "Собственники бухгалтерских компаний" },
  url: `${v2Site.url}/v2/partneram/`
};
---

<V2Layout title={title} description={description} schema={[pageSchema, faqSchema]}>
  <section class="v2-section v2-page-hero v2-section--soft" data-v2-screen="1">
    <div class="v2-shell">
      <p class="v2-eyebrow">Стать партнёром</p>
      <h1 class="v2-page-title">Расти без найма. <span class="v2-accent-word">Стать финансовым партнёром.</span></h1>
      <p class="v2-lead">
        Aivel берёт на себя технологии и развитие производственного процесса. Собственник сохраняет отношения с клиентами и направляет освободившееся время на рост и консультации.
      </p>
      <div class="v2-partner-value">
        <article><h2>Расти без найма.</h2><p>Рост клиентской базы больше не требует пропорционально расширять команду и управленческий контроль.</p></article>
        <article><h2>Стать финансовым партнёром.</h2><p>Освободить время от операционной рутины и помогать клиенту понимать бизнес и принимать решения.</p></article>
      </div>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="2" aria-labelledby="v2-partnership-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Суть партнёрства</p>
      <h2 class="v2-section-title" id="v2-partnership-title">Вы отвечаете за рост. Мы — за производительность.</h2>
      <div class="v2-role-grid">
        <article>
          <h3>Партнёр</h3>
          <ul><li>развивает клиентскую базу;</li><li>сохраняет отношения и клиентский сервис;</li><li>усиливает экспертизу своей отрасли или региона.</li></ul>
        </article>
        <article>
          <h3>Aivel</h3>
          <ul><li>даёт технологии;</li><li>организует производственный процесс;</li><li>повышает производительность и целевую рентабельность.</li></ul>
        </article>
      </div>
      <div class="v2-partner-terms"><p><strong>Мы приобретаем от 51% компании.</strong> Права, обязанности и совместные решения заранее закрепляются корпоративным договором.</p></div>
    </div>
  </section>

  <section class="v2-section v2-section--soft" data-v2-screen="3" aria-labelledby="v2-now-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Почему сейчас</p>
      <h2 class="v2-section-title" id="v2-now-title">Основа уже создана. Место для лидеров ещё есть.</h2>
      <p class="v2-lead">Сеть Aivel формируется вокруг сильных владельцев. Нам нужны эксперты, которые хотят занять заметное место в своей нише.</p>
      <div class="v2-map">
        <article><span>01</span><h3>Новые регионы</h3><p>Локальные лидеры с устойчивой клиентской базой и репутацией.</p></article>
        <article><span>02</span><h3>Новые отрасли</h3><p>Глубокая практика в сегментах, где особенно важна предметная экспертиза.</p></article>
        <article><span>03</span><h3>Новые специализации</h3><p>Бухгалтерский и налоговый учёт, зарплата и кадры, управленческий учёт.</p></article>
      </div>
      <p class="v2-subtitle" style="margin-top: 48px">400+ млн ₽ выручки сети в пересчёте на год · 1 000+ клиентов · клиенты в 3 странах.</p>
    </div>
  </section>

  <section class="v2-section v2-section--auto" data-v2-screen="4" aria-labelledby="v2-faq-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Частые вопросы</p>
      <h2 class="v2-section-title" id="v2-faq-title">Главное — договориться о ролях и результате.</h2>
      <div class="v2-faq">
        {v2PartnerFaq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
      <div class="v2-final-cta" style="margin-top: 64px">
        <div>
          <p class="v2-eyebrow">Следующий шаг</p>
          <h2>Расскажите о компании.</h2>
          <p>На первом шаге достаточно масштаба, региона или специализации и вашей цели. Закрытые данные не нужны.</p>
        </div>
        <a class="v2-button" href={partnerMailto}>Заполнить анкету партнёра</a>
      </div>
    </div>
  </section>
</V2Layout>

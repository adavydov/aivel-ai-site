---
import V2Layout from "../../../layouts/V2Layout.astro";
import { partnerMailto, v2PartnerFaq, v2Site } from "../../../data/v2";

const title = "Стать партнёром Aivel — для собственников бухгалтерских компаний";
const description =
  "Партнёрство Aivel для владельцев бухгалтерских компаний: расти без пропорционального найма и стать финансовым партнёром для клиента.";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: v2PartnerFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer }
  }))
};
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Партнёрство Aivel с бухгалтерскими компаниями",
  description,
  provider: { "@id": `${v2Site.url}/#organization` },
  audience: { "@type": "BusinessAudience", audienceType: "Собственники бухгалтерских компаний" },
  url: `${v2Site.url}/v2/partneram/`
};
---

<V2Layout title={title} description={description} schema={[pageSchema, faqSchema]}>
  <section class="v2-section v2-page-hero" data-v2-screen="1">
    <div class="v2-shell">
      <p class="v2-eyebrow">Для собственников бухгалтерских компаний</p>
      <h1 class="v2-page-title">Расти без найма. <span class="v2-accent-word">Стать финансовым партнёром</span> для клиента.</h1>
      <p class="v2-lead">
        Рынок бухгалтерского обслуживания меняется: клиенты ждут не только закрытый учёт, но и своевременные выводы для бизнеса. Aivel даёт технологическую и производственную платформу, а собственник сохраняет отношения, экспертизу и роль роста.
      </p>
      <ol class="v2-steps">
        <li><span class="v2-number">1</span><div><h3>Расти без пропорционального штата.</h3><p>ИИ выполняет повторяющиеся операции, а специалисты разбирают исключения.</p></div></li>
        <li><span class="v2-number">2</span><div><h3>Стать финансовым партнёром.</h3><p>Освободить время от операционной рутины и помогать клиенту принимать решения.</p></div></li>
        <li><span class="v2-number">3</span><div><h3>Сохранить предпринимательскую роль.</h3><p>Партнёр отвечает за рост, клиентский сервис, нишу и личную экспертизу.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="2" aria-labelledby="v2-partnership-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Суть партнёрства</p>
      <h2 class="v2-section-title" id="v2-partnership-title">Вы отвечаете за рост. Мы — за производительность.</h2>
      <div class="v2-audience-surface v2-role-grid">
        <article>
          <h3>Партнёр</h3>
          <div><h3>Растит выручку и сохраняет отношения.</h3><ul><li>развивает клиентскую базу;</li><li>отвечает за клиентский сервис;</li><li>усиливает экспертизу своей отрасли или региона.</li></ul></div>
        </article>
        <article>
          <h3>Aivel</h3>
          <div><h3>Отвечает за эффективность производства.</h3><ul><li>даёт технологии;</li><li>организует производственный процесс;</li><li>повышает производительность и целевую рентабельность.</li></ul></div>
        </article>
      </div>
      <div class="v2-partner-terms">
        <p><strong>Aivel приобретает от 51% компании.</strong> Права, обязанности и совместные решения заранее закрепляются корпоративным договором.</p>
        <p><strong>ДДХ вырос в 2 раза без найма новых бухгалтеров.</strong> Это результат конкретного внедрения, где повторяющиеся операции передали ИИ.</p>
      </div>
      <div class="v2-feature-grid">
        <article><h3>Технологии</h3><p>ИИ-агенты, 1С, обмены, контроль исключений и проверяемый след операций.</p></article>
        <article><h3>Производство</h3><p>Единые правила, распределение потока, контроль качества и рост маржинальности.</p></article>
        <article><h3>Новая роль</h3><p>Партнёр получает время не на ручной контроль, а на консультации, продажи и развитие ниши.</p></article>
      </div>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="3" aria-labelledby="v2-now-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Почему сейчас</p>
      <h2 class="v2-section-title" id="v2-now-title">Основа создана. Окно для лидеров ещё открыто.</h2>
      <p class="v2-lead">Сеть Aivel формируется вокруг сильных владельцев. Нам нужны эксперты, которые хотят занять заметное место в своей нише.</p>
      <div class="v2-map">
        <article><span>1</span><div><h3>Новые регионы</h3><p>Локальные лидеры с устойчивой клиентской базой и репутацией.</p></div></article>
        <article><span>2</span><div><h3>Новые отрасли</h3><p>Практика в сегментах, где особенно важна предметная экспертиза.</p></div></article>
        <article><span>3</span><div><h3>Новые специализации</h3><p>Учёт, зарплата и кадры, налоги и управленческая отчётность.</p></div></article>
      </div>
      <div class="v2-proof-surface v2-network-proof" aria-label="Масштаб сети Aivel">
        <ul class="v2-proof-list">
          <li><strong>400+ млн ₽</strong><p>выручки сети в пересчёте на год</p></li>
          <li><strong>1 000+ клиентов</strong><p>в действующих бухгалтерских компаниях</p></li>
          <li><strong>3 страны</strong><p>география клиентов сети</p></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="v2-section v2-section--auto" data-v2-screen="4" aria-labelledby="v2-faq-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Частые вопросы</p>
      <h2 class="v2-section-title" id="v2-faq-title">Главное — договориться о ролях и результате.</h2>
      <div class="v2-faq">
        {v2PartnerFaq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
      <div class="v2-final-cta v2-faq-cta">
        <div>
          <h2>Расскажите о компании.</h2>
          <p>На первом шаге достаточно масштаба, региона или специализации и вашей цели. Закрытые данные не нужны.</p>
        </div>
        <a class="v2-button" href={partnerMailto}>Заполнить анкету партнёра</a>
      </div>
    </div>
  </section>
</V2Layout>

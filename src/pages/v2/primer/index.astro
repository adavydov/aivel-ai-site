---
import CfoGame from "../../../components/v2/CfoGame.astro";
import V2Layout from "../../../layouts/V2Layout.astro";
import { accountingMailto, demoMailto, v2Site } from "../../../data/v2";

const title = "Посмотрите, что Aivel сообщит руководителю — учебная демонстрация";
const description =
  "Выберите тип бизнеса и посмотрите, как Aivel сам замечает важное изменение, отвечает на уточнения и показывает основание вывода.";
const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Учебная демонстрация Aivel",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Веб-браузер",
  description,
  url: `${v2Site.url}/v2/primer/`,
  isAccessibleForFree: true
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Можно ли получить такие сигналы на своих данных?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Да, но сначала нужно проверить источники, правила учёта и качество данных. На реальных данных Aivel работает от учётного контура, а не от отдельного отчёта."
      }
    },
    {
      "@type": "Question",
      name: "Что происходит после учебной демонстрации?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Следующий шаг — экспресс-аудит учёта: Aivel проверяет источники, объём операций и места, где данные теряются или требуют ручной проверки."
      }
    }
  ]
};
---

<V2Layout title={title} description={description} schema={[appSchema, faqSchema]}>
  <div class="v2-page-hero">
    <div class="v2-shell">
      <CfoGame ctaHref={demoMailto} />

      <section class="v2-proof-surface v2-demo-bridge" aria-labelledby="v2-demo-bridge-title">
        <div>
          <p class="v2-eyebrow">Следующий шаг</p>
          <h2 id="v2-demo-bridge-title">На ваших данных всё начинается с учёта.</h2>
          <p>
            В учебном примере источник уже чистый. В реальном бизнесе сначала проверяем банк, документы, 1С, обмены и правила, чтобы каждый сигнал имел основание.
          </p>
        </div>
        <a class="v2-button" href={accountingMailto}>Проверить готовность учёта</a>
      </section>
    </div>
  </div>
</V2Layout>

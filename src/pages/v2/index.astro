---
import BrandStrip from "../../components/v2/BrandStrip.astro";
import V2Layout from "../../layouts/V2Layout.astro";
import { demoMailto, v2Mechanism, v2Pains, v2Site } from "../../data/v2";

const title = "Вовремя увидеть важное в бизнесе — Aivel 2.0";
const description =
  "Aivel сам замечает важные изменения в бизнесе, объясняет возможные последствия и показывает основание каждого вывода.";
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: `${v2Site.url}/v2/`,
  about: {
    "@type": "Service",
    name: "Финансовый помощник Aivel",
    serviceType: "Выявление важных изменений в бизнесе по учётным данным",
    provider: { "@id": `${v2Site.url}/#organization` }
  }
};
---

<V2Layout title={title} description={description} schema={schema}>
  <section class="v2-section v2-page-hero" data-v2-screen="1">
    <div class="v2-shell">
      <p class="v2-eyebrow">Финансовый помощник для руководителя</p>
      <h1 class="v2-title">Вовремя увидеть важное.</h1>
      <p class="v2-lead">
        Aivel сам замечает важные изменения в бизнесе, объясняет, чем они грозят, и показывает основание каждого вывода.
      </p>
      <div class="v2-actions">
        <a class="v2-button" href="/v2/primer/">Попробовать на учебном бизнесе</a>
        <a class="v2-text-link" href={demoMailto}>Записаться на показ</a>
      </div>
      <div class="v2-hero__signal" aria-label="Пример сообщения Aivel">
        <span>!</span>
        <p>Через 12 дней может не хватить денег на зарплату и налоги.</p>
        <small>Система сообщила сама</small>
      </div>
    </div>
  </section>

  <section class="v2-section v2-section--soft" data-v2-screen="2" aria-labelledby="v2-recognition-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Узнаёте ситуацию?</p>
      <h2 class="v2-section-title" id="v2-recognition-title">Важное редко выглядит важным сразу.</h2>
      <ul class="v2-pain-list">
        {v2Pains.map((pain) => (
          <li><p><strong>{pain.title}</strong> — {pain.text}</p></li>
        ))}
      </ul>
      <p class="v2-lead">
        Обычно это становится видно в отчёте, когда последствия уже наступили. Aivel сообщает, пока ещё можно повлиять.
      </p>
    </div>
  </section>

  <section class="v2-section" id="kak-rabotaet" data-v2-screen="3" aria-labelledby="v2-how-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Как работает</p>
      <h2 class="v2-section-title" id="v2-how-title">Сначала сообщает. Потом отвечает.</h2>
      <p class="v2-lead">
        Руководитель получает не ещё один отчёт, а понятную причину обратить внимание на конкретную ситуацию.
      </p>
      <ol class="v2-steps">
        {v2Mechanism.map((step) => (
          <li>
            <span class="v2-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </li>
        ))}
      </ol>
      <div class="v2-actions">
        <a class="v2-button" href="/v2/primer/">Увидеть на примере</a>
        <a class="v2-text-link" href="/v2/uchet/">Понять, откуда берутся данные</a>
      </div>
    </div>
  </section>

  <section class="v2-section v2-section--dark" data-v2-screen="4" aria-labelledby="v2-trust-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Опыт команды</p>
      <div class="v2-trust-grid">
        <div>
          <h2 class="v2-section-title" id="v2-trust-title">Понимаем путь от операции до решения.</h2>
          <p class="v2-lead">
            Команда Aivel создаёт и внедряет решения в реальных учётных контурах. Поэтому мы понимаем не только данные, но и то, какое изменение действительно требует внимания руководителя.
          </p>
        </div>
        <aside class="v2-trust-note">
          <strong>Каждый сигнал можно проверить.</strong>
          <p>Источник, дата, правило и ход расчёта остаются рядом с выводом — от сообщения до исходной операции.</p>
          <div class="v2-actions">
            <a class="v2-text-link" href="/v2/ii-agenty/">Посмотреть внедрения</a>
            <a class="v2-text-link" href="/v2/uchet/">Наладить учёт</a>
          </div>
        </aside>
      </div>
      <p class="v2-muted">Компании, с которыми работала команда Aivel</p>
      <BrandStrip />
    </div>
  </section>
</V2Layout>

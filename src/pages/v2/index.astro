---
import BrandStrip from "../../components/v2/BrandStrip.astro";
import PainRecognition from "../../components/v2/PainRecognition.astro";
import V2Layout from "../../layouts/V2Layout.astro";
import {
  v2AudiencePaths,
  v2AuditTrail,
  v2Comparisons,
  demoMailto,
  v2HeroSignal,
  v2Mechanism,
  v2Pains,
  v2ProofMetrics,
  v2SignalWorkflow,
  v2Site
} from "../../data/v2";

const title = "Вовремя увидеть важное в бизнесе — Aivel 2.0";
const description =
  "Aivel сам сообщает, что произошло в бизнесе. Не нужно ждать отчёт или спрашивать аналитика.";
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: `${v2Site.url}/v2/`,
  about: {
    "@type": "Service",
    name: "Финансовый помощник Aivel",
    serviceType: "Выявление важных изменений в бизнесе по учётным данным",
    provider: { "@id": `${v2Site.url}/#organization` }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Чем Aivel отличается от отчёта или дашборда?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Отчёт и дашборд требуют заранее открыть нужный показатель. Aivel сам сообщает, что произошло в бизнесе, объясняет возможные последствия и показывает основание вывода."
      }
    },
    {
      "@type": "Question",
      name: "Почему для этого нужен надёжный учёт?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Сигнал имеет смысл только тогда, когда документы, банк, 1С и рабочие системы сходятся в проверяемой картине. Поэтому учёт является основой продукта Aivel."
      }
    }
  ]
};
---

<V2Layout title={title} description={description} schema={[pageSchema, faqSchema]}>
  <section class="v2-section v2-page-hero v2-hero-product" data-v2-screen="1">
    <div class="v2-shell v2-hero-grid">
      <div class="v2-hero-copy">
        <p class="v2-eyebrow">Новый рабочий режим руководителя</p>
        <h1 class="v2-title">Aivel сам сообщает, что произошло в <span class="v2-accent-word">бизнесе.</span></h1>
        <p class="v2-hero-subtitle">Не нужно ждать отчёт или спрашивать аналитика.</p>
        <p class="v2-lead">
          Aivel следит за учётом, деньгами и операциями, сам отделяет важное от шума и приносит короткий сигнал: что произошло, почему это важно, что сделать сейчас и на чём основан вывод.
        </p>
        <div class="v2-actions">
          <a class="v2-button" href="/v2/primer/">Посмотреть сигнал</a>
          <a class="v2-text-link" href="#kak-rabotaet">Понять механизм</a>
        </div>
      </div>

      <aside class="v2-signal-card" aria-label="Пример сигнала Aivel">
        <div class="v2-signal-card__topline">
          <span>{v2HeroSignal.label}</span>
          <time datetime="2026-08-12T10:15:00">сегодня · 10:15</time>
        </div>
        <h2>{v2HeroSignal.title}</h2>
        <p>{v2HeroSignal.summary}</p>
        <dl class="v2-signal-card__facts">
          {v2HeroSignal.facts.map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{fact.value}</dd>
            </div>
          ))}
        </dl>
        <div class="v2-signal-card__questions" aria-label="Уточняющие вопросы">
          {v2HeroSignal.questions.map((question) => <span>{question}</span>)}
        </div>
      </aside>
    </div>

    <div class="v2-shell">
      <div class="v2-proof-strip" aria-label="Доказательства измеренных процессов">
        {v2ProofMetrics.map((metric) => (
          <article>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="2" aria-labelledby="v2-recognition-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Проблема</p>
      <h2 class="v2-section-title" id="v2-recognition-title">Обычно это узнают слишком поздно.</h2>
      <PainRecognition pains={v2Pains} />
      <p class="v2-recognition__outcome">
        Это не “ещё один отчёт”. Это момент, когда руководитель узнаёт изменение раньше, чем оно стало потерей денег, времени или контроля. <strong>Aivel сам сообщает, что произошло.</strong>
      </p>
    </div>
  </section>

  <section class="v2-section" id="kak-rabotaet" data-v2-screen="3" aria-labelledby="v2-how-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Механизм</p>
      <h2 class="v2-section-title" id="v2-how-title">Сигнал появляется не из воздуха.</h2>
      <p class="v2-lead">
        Лучшие AI accounting продукты выигрывают не словами про ИИ, а понятной цепочкой: источник данных, операция, контроль, вывод и проверяемый след. Aivel строит такую цепочку для российского учётного контура.
      </p>
      <div class="v2-workflow-surface" aria-label="Как Aivel формирует сигнал">
        {v2SignalWorkflow.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <ol class="v2-steps">
        {v2Mechanism.map((step) => (
          <li>
            <span class="v2-number">{step.number}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="v2-actions">
        <a class="v2-button" href="/v2/primer/">Увидеть на примере</a>
        <a class="v2-text-link" href="/v2/uchet/">Понять, откуда берутся данные</a>
      </div>

      <div class="v2-audience-surface v2-comparison-surface" aria-label="Чем Aivel отличается от привычных решений">
        {v2Comparisons.map((item) => (
          <article class="v2-comparison-row">
            <span class="v2-surface-label">{item.alternative}</span>
            <div>
              <p><strong>Обычно:</strong> {item.current}</p>
              <p><strong>Aivel:</strong> {item.aivel}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="v2-section" data-v2-screen="4" aria-labelledby="v2-trust-title">
    <div class="v2-shell">
      <p class="v2-eyebrow">Доверие</p>
      <h2 class="v2-section-title" id="v2-trust-title">Каждый сигнал можно открыть до источника.</h2>
      <p class="v2-lead">
        Руководителю не предлагают верить “умному выводу”. Важный сигнал раскрывается до расчёта, источника, операции и решения специалиста.
      </p>

      <div class="v2-audit-grid" aria-label="Проверяемый след сигнала">
        {v2AuditTrail.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>

      <div class="v2-audience-surface v2-team-surface">
        <article><span>Опыт команды</span><div><h3>Понимаем реальные учётные процессы.</h3><p>Команда Aivel внедряет решения в контурах, где есть документы, банк, 1С, рабочие системы, регламенты и ответственность за результат.</p></div></article>
        <article><span>Инженерный подход</span><div><h3>Уменьшаем риск ошибок устройством процесса.</h3><p>Роли агентов, ограничения действий, передача исключений человеку и журнал проверок встроены в саму механику.</p></div></article>
        <article><span>Управленческий контекст</span><div><h3>Отличаем важное от обычного шума.</h3><p>Сигнал появляется там, где изменение влияет на деньги, обязательства, маржу, закрытие периода или решение руководителя.</p></div></article>
      </div>

      <p class="v2-muted">Есть внедрения в Гольфстрим и опыт работы команды Aivel в реальных учётных контурах</p>
      <BrandStrip compact />

      <div class="v2-path-grid" aria-label="Выберите свой путь">
        {v2AudiencePaths.map((path) => (
          <article>
            <span>{path.label}</span>
            <h3>{path.title}</h3>
            <p>{path.text}</p>
            <a class="v2-text-link" href={path.href}>{path.cta}</a>
          </article>
        ))}
      </div>

      <div class="v2-actions">
        <a class="v2-text-link" href="/v2/uchet/">Наладить учёт</a>
        <a class="v2-text-link" href="/v2/avtomatizatsiya-bek-ofisa/">Автоматизировать операции</a>
      </div>

      <div class="v2-final-cta" aria-labelledby="v2-home-demo-title">
        <div>
          <p class="v2-eyebrow">Следующий шаг</p>
          <h2 id="v2-home-demo-title">Записаться на демо.</h2>
          <p>Покажем, как Aivel сообщает о важном событии, раскрывает основание сигнала и связывает вывод с учётом, документами и действиями специалиста.</p>
        </div>
        <a class="v2-button" href={demoMailto}>Записаться на демо</a>
      </div>
    </div>
  </section>
</V2Layout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoDemo from "../../components/VideoDemo.astro";

const operationSteps = [
  { number: "01", title: "Получить задачу", text: "Документ, платёж или запрос поступает из разрешённого источника." },
  { number: "02", title: "Выполнить проверки", text: "ИИ сверяет данные, правила и обязательные поля до совершения действия." },
  { number: "03", title: "Завершить или передать", text: "Типовая операция выполняется автоматически. Расхождение уходит специалисту вместе с контекстом." },
  { number: "04", title: "Сохранить результат", text: "Запись или документ создаётся в 1С, а каждый шаг остаётся в журнале." }
];

const controlAreas = [
  {
    label: "Разрешённая роль",
    title: "ИИ не может выйти за границы операции.",
    text: "Для каждого помощника заранее задаются источники, доступные поля, допустимые действия и условия остановки."
  },
  {
    label: "Исключение человеку",
    title: "Неоднозначность не маскируется под ответ.",
    text: "Неполные данные, расхождение или необходимость профессионального суждения создают задачу специалисту."
  },
  {
    label: "Точность",
    title: "Свободный ответ не заменяет проверку.",
    text: "Результат проходит правила полноты, справочники и контрольные соотношения. Ошибка проверки блокирует завершение операции."
  },
  {
    label: "Безопасность",
    title: "Данные остаются в согласованном периметре.",
    text: "Размещение — в изолированном российском контуре или внутри контура компании. Права выдаются отдельно людям и ИИ."
  }
];

const endToEndSteps = [
  "Забрать документ или данные из источника",
  "Распознать и определить операцию",
  "Проверить реквизиты, правила и связи",
  "Создать запись или документ в 1С",
  "Передать исключение специалисту",
  "Сохранить основание и историю действий"
];
---

<BaseLayout
  title="Как работает Aivel: операция, контроль и аудиторский след"
  description="Aivel выполняет учётную операцию от получения данных до записи в 1С, передаёт исключения специалисту и сохраняет проверяемую историю действий."
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Как работает</span>
  </div>

  <header class="page-hero mechanics-hero">
    <div class="container mechanics-intro">
      <p class="section-kicker">Механика продукта</p>
      <h1>ИИ выполняет операцию. Человек подключается к исключению.</h1>
      <p class="lead">Aivel проходит разрешённый процесс по заданным правилам, фиксирует каждый шаг и не завершает операцию, если данных или уверенности недостаточно.</p>
    </div>
  </header>

  <div class="mechanics-content">
    <section class="section video-section" aria-labelledby="platform-video-title">
      <div class="container">
        <div class="section-heading video-heading">
          <div>
            <p class="section-kicker">Операция в продукте</p>
            <h2 id="platform-video-title">От задачи до результата и проверки человеком.</h2>
          </div>
          <p>На демонстрации видны действия ИИ, условия остановки и передача неоднозначного случая специалисту.</p>
        </div>
        <VideoDemo
          driveId="13shhsfSNrURD23l5y-2YZDhtITJzx_he"
          title="Как устроена платформа Aivel"
          description="Задача поступает в рабочий контур, ИИ-помощник выполняет разрешённые действия, сохраняет историю и передаёт специалисту неоднозначные случаи."
        />
        <ol class="operation-flow" aria-label="Этапы выполнения операции">
          {operationSteps.map((step) => (
            <li>
              <span>{step.number}</span>
              <div><h3>{step.title}</h3><p>{step.text}</p></div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section section-warm" aria-labelledby="control-title">
      <div class="container">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Контроль по устройству</p>
            <h2 id="control-title">Роли, проверки и безопасность встроены в процесс.</h2>
          </div>
          <p>ИИ не принимает произвольных решений: ему доступны только согласованные данные и действия.</p>
        </div>
        <div class="control-grid">
          {controlAreas.map((area) => (
            <article class="control-card">
              <span>{area.label}</span>
              <h3>{area.title}</h3>
              <p>{area.text}</p>
            </article>
          ))}
        </div>
        <div class="audit-trail" aria-labelledby="audit-title">
          <div>
            <p class="section-kicker">Аудиторский след</p>
            <h3 id="audit-title">Любой результат можно восстановить по шагам.</h3>
          </div>
          <p>Журнал хранит исходные данные, выполненные проверки, изменения, исполнителя, время и итоговый статус. Специалист видит не только исключение, но и причину его появления.</p>
        </div>
      </div>
    </section>

    <section class="section section-dark comparison-section" aria-labelledby="comparison-title">
      <div class="container">
        <div class="section-heading comparison-heading">
          <div>
            <p class="section-kicker section-kicker-light">Не только распознавание</p>
            <h2 id="comparison-title">Обычное распознавание закрывает фрагмент. Aivel — процесс целиком.</h2>
          </div>
          <p>Результат Aivel — не набор извлечённых полей, а завершённая операция или подготовленное исключение для специалиста.</p>
        </div>
        <div class="comparison-grid">
          <article class="comparison-card comparison-card-muted">
            <span class="comparison-label">Распознавание документов</span>
            <h3>Из файла — в набор полей.</h3>
            <ol>
              <li><span>01</span>Получить отдельный файл</li>
              <li><span>02</span>Распознать реквизиты</li>
              <li><span>03</span>Передать результат человеку</li>
            </ol>
            <p>Проверка, ввод в учётную систему и разбор расхождений остаются отдельными ручными этапами.</p>
          </article>
          <article class="comparison-card comparison-card-aivel">
            <span class="comparison-label">Aivel</span>
            <h3>От источника — до результата в 1С.</h3>
            <ol>
              {endToEndSteps.map((step, index) => (
                <li><span>{String(index + 1).padStart(2, "0")}</span>{step}</li>
              ))}
            </ol>
          </article>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .mechanics-hero {
    padding-block: clamp(42px, 5vw, 68px) clamp(24px, 3vw, 38px);
  }

  .mechanics-intro {
    max-width: 1000px;
  }

  .mechanics-hero h1 {
    max-width: 970px;
    font-size: clamp(2.75rem, 5.4vw, 5.2rem);
  }

  .mechanics-hero .lead {
    max-width: 800px;
  }

  .video-section {
    padding-top: clamp(24px, 4vw, 54px);
  }

  .video-heading {
    align-items: end;
  }

  .operation-flow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 20px 0 0;
    list-style: none;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .operation-flow li {
    display: grid;
    min-height: 200px;
    align-content: space-between;
    padding: 24px;
    background: var(--color-surface);
  }

  .operation-flow > li > span {
    color: var(--color-gold);
    font-size: 0.76rem;
    font-weight: 750;
  }

  .operation-flow h3 {
    margin: 32px 0 8px;
    font-size: 1.08rem;
  }

  .operation-flow p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .control-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .control-card {
    min-height: 220px;
    padding: 26px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .control-card > span,
  .comparison-label {
    color: var(--color-gold);
    font-size: 0.73rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .control-card h3 {
    max-width: 520px;
    margin: 34px 0 10px;
  }

  .control-card p {
    max-width: 620px;
    margin: 0;
    color: var(--color-muted);
  }

  .audit-trail {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(28px, 7vw, 90px);
    align-items: end;
    padding: 28px;
    margin-top: 14px;
    background: var(--color-ink);
    border-radius: var(--radius-md);
  }

  .audit-trail h3,
  .audit-trail p {
    color: white;
  }

  .audit-trail h3,
  .audit-trail p {
    margin-bottom: 0;
  }

  .audit-trail > p {
    color: #c3cfde;
  }

  .comparison-heading h2,
  .comparison-heading > p {
    color: white;
  }

  .comparison-heading > p {
    color: #c3cfde;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 14px;
  }

  .comparison-card {
    padding: clamp(24px, 3vw, 34px);
    border: 1px solid rgb(255 255 255 / 0.15);
    border-radius: var(--radius-md);
  }

  .comparison-card-muted {
    background: rgb(255 255 255 / 0.045);
  }

  .comparison-card-aivel {
    background: rgb(255 255 255 / 0.1);
    border-color: var(--color-gold-soft);
  }

  .comparison-card h3 {
    margin: 26px 0;
    color: white;
  }

  .comparison-card ol {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .comparison-card li {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 10px;
    padding: 13px 0;
    color: white;
    border-top: 1px solid rgb(255 255 255 / 0.13);
  }

  .comparison-card li span {
    color: var(--color-gold-soft);
    font-size: 0.74rem;
  }

  .comparison-card > p {
    margin: 24px 0 0;
    color: #aebdce;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .operation-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .comparison-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .mechanics-hero h1 {
      font-size: clamp(2.55rem, 13vw, 4rem);
    }

    .operation-flow,
    .control-grid,
    .audit-trail {
      grid-template-columns: 1fr;
    }

    .operation-flow li {
      min-height: 0;
    }

    .control-card {
      min-height: 0;
    }

  }
</style>

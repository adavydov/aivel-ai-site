---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import VideoDemo from "../../components/VideoDemo.astro";
import { trustSteps } from "../../data/site";

const accountingAreas = [
  { href: "/avtomatizatsiya-ucheta/pervichnye-dokumenty/", label: "ИИ-помощник по первичным документам", proof: "80% потока", text: "Распознаёт документ, создаёт запись в 1С и передаёт человеку неоднозначные случаи." },
  { href: "/avtomatizatsiya-ucheta/bankovskie-operatsii/", label: "ИИ-помощник по банковским операциям", proof: "98% точности", text: "Сопоставляет платежи с договорами и аналитикой, разделяет сложные платежи." },
  { href: "/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/", label: "ИИ-помощник по запросам", proof: "Запрос → задача", text: "Направляет запрос подразделения или заказчика исполнителю, задаёт срок и контролирует результат." },
  { href: "/avtomatizatsiya-ucheta/sverki-s-kontragentami/", label: "ИИ-помощник по сверкам", proof: "Только исключения", text: "Закрывает совпадения по правилам и поднимает расхождения специалисту." }
];
---

<BaseLayout title="Как работает Aivel: четыре ИИ-помощника и своевременные сигналы" description="Четыре ИИ-помощника поддерживают учётные данные, Aivel замечает важное изменение и показывает проверяемое действие.">
  <div class="container breadcrumbs" aria-label="Хлебные крошки"><a href="/">Главная</a><span aria-hidden="true">/</span><span>Как работает</span></div>
  <header class="page-hero mechanics-hero">
    <div class="container page-hero-grid">
      <div><p class="section-kicker">Механика продукта</p><h1>ИИ-помощники выполняют рутину. Руководитель видит важное.</h1><p class="lead">Aivel соединяет повторяющиеся учётные операции, правила важности и проверяемый ответ в одну цепочку.</p></div>
      <aside class="page-hero-aside mechanics-aside"><strong>Коротко</strong><div><span>1</span>ИИ-помощники обновляют данные</div><div><span>2</span>Aivel замечает изменение</div><div><span>3</span>Человек принимает решение</div></aside>
    </div>
  </header>

  <section class="section section-dark" aria-labelledby="accounting-layer-title">
    <div class="container">
      <div class="section-heading mechanism-heading"><div><p class="section-kicker section-kicker-light">Первый слой</p><h2 id="accounting-layer-title">Четыре работающих ИИ-помощника.</h2></div><p>Каждый закрывает ограниченный процесс и может внедряться отдельно. Цифры относятся к измеренным потокам реализованных проектов.</p></div>
      <div class="mechanism-grid">
        {accountingAreas.map((area, index) => (
          <a class="mechanism-card" href={area.href}>
            <span class="mechanism-number">0{index + 1}</span>
            <div><h3>{area.label}</h3><strong>{area.proof}</strong><p>{area.text}</p></div>
            <Icon name="arrow" size={22} />
          </a>
        ))}
      </div>
      <div class="mechanism-action"><a class="button button-light" href="/avtomatizatsiya-ucheta/">Все процессы и демонстрации</a><a class="text-link text-link-light" href="/rezultaty/">Как измерены результаты <Icon name="arrow" size={19} /></a></div>
    </div>
  </section>

  <section class="section safety-entry-section" aria-labelledby="safety-entry-title">
    <div class="container safety-entry">
      <div>
        <p class="section-kicker">Безопасность и точность</p>
        <h2 id="safety-entry-title">ИИ действует только в разрешённой роли.</h2>
        <p>Контур размещения, источники, права и допустимые действия согласуются до запуска. Запрос пользователя не может дать ИИ-помощнику доступ, которого нет у его роли.</p>
        <a class="button button-primary" href="/zashchita-dannyh/">Как защищены данные и ответы <Icon name="arrow" size={20} /></a>
      </div>
      <div class="safety-entry-points">
        <div><strong>Ваш контур или изолированное облако</strong><span>Вариант размещения выбирается для проекта.</span></div>
        <div><strong>Отдельные роли для людей и ИИ</strong><span>Каждому доступны только нужные источники и действия.</span></div>
        <div><strong>Три линии контроля качества</strong><span>Правила, оценка неоднозначности, человек и журнал действий.</span></div>
        <div><strong>1С и банки — по регламенту</strong><span>Юридические лица, базы, расписание и права задаются заранее.</span></div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="signal-chain-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Второй слой</p><h2 id="signal-chain-title">Из данных получается своевременный сигнал.</h2></div><p>Руководителю не нужно читать все операции. Aivel показывает только изменение, которое пересекло согласованную границу или выбилось из обычного.</p></div>
      <div class="working-chain">
        <article><span>01</span><h3>Источники обновились</h3><p>1С, банк, документы, обязательства и обращения в выбранном периметре.</p></article>
        <article><span>02</span><h3>Сработала проверка</h3><p>Правило, прогноз или необычное отклонение связывает изменение с решением.</p></article>
        <article><span>03</span><h3>Появился сигнал</h3><p>Что произошло, почему важно, на чём основано и что сделать сейчас.</p></article>
      </div>
      <div class="demo-entry"><div><p class="section-kicker">Попробовать</p><h3>Задайте вопрос на учебных данных.</h3><p>Демо покажет сигнал, основание, ограничение и следующий шаг.</p></div><button class="button button-primary" type="button" data-open-demo>Открыть демо продукта</button></div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Третий слой</p><h2 id="trust-title">Пять проверок делают ответ пригодным для решения.</h2></div><p>Подробности раскрываются по запросу и не перегружают сам сигнал.</p></div>
      <div class="trust-flow signal-flow">
        {trustSteps.map((step) => <article class="trust-step"><span>{step.number}</span><h3>{step.title}</h3><p>{step.text}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="platform-video-title">
    <div class="container">
      <div class="section-heading"><div><p class="section-kicker">Настоящий продукт</p><h2 id="platform-video-title">Посмотрите, как Aivel выполняет операции и передаёт исключения человеку.</h2></div></div>
      <VideoDemo driveId="13shhsfSNrURD23l5y-2YZDhtITJzx_he" title="Как устроена платформа Aivel" description="Задача поступает в рабочий контур, ИИ-помощник выполняет разрешённые действия, сохраняет историю и передаёт специалисту неоднозначные случаи." />
      <p style="margin-top: 22px;"><a class="text-link" href="https://vkvideo.ru/video-227572578_456239162?list=ln-xzD9oHw5kaCSDL00dW&t=2m52s" target="_blank" rel="noopener">Большой разбор продукта во VK Видео — с 2:52 <Icon name="arrow" size={18} /></a></p>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="details-title">
    <div class="container">
      <div class="section-heading details-heading"><div><p class="section-kicker section-kicker-light">Проверить устройство</p><h2 id="details-title">Данные, права, источники и ограничения — открыто.</h2></div><p>Отдельные страницы дают людям и ИИ-системам устойчивые адреса для проверки фактов о продукте.</p></div>
      <div class="details-grid">
        <a href="/kak-formiruetsya-otvet/"><span>Ответ</span><strong>Как формируется вывод</strong><Icon name="arrow" size={20} /></a>
        <a href="/dannye-i-istochniki/"><span>Основание</span><strong>Данные и источники</strong><Icon name="arrow" size={20} /></a>
        <a href="/1s-i-integratsii/"><span>Связи</span><strong>1С и другие системы</strong><Icon name="arrow" size={20} /></a>
        <a href="/zashchita-dannyh/"><span>Контроль</span><strong>Защита данных</strong><Icon name="arrow" size={20} /></a>
        <a href="/ogranicheniya/"><span>Границы</span><strong>Что Aivel не обещает</strong><Icon name="arrow" size={20} /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mechanics-hero {
    padding-block: clamp(50px, 6vw, 82px);
  }

  .mechanics-hero h1 {
    font-size: clamp(2.9rem, 5vw, 4.8rem);
  }

  .mechanics-aside {
    display: grid;
    gap: 10px;
  }

  .mechanics-aside > div {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 8px;
    align-items: center;
    padding: 10px 0;
    border-top: 1px solid var(--color-border);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .mechanics-aside span,
  .mechanism-number {
    color: var(--color-gold);
    font-size: 0.74rem;
  }

  .mechanism-heading h2,
  .mechanism-heading > p,
  .details-heading h2 {
    color: white;
  }

  .mechanism-heading > p,
  .details-heading > p {
    color: #c3cfde;
  }

  .mechanism-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .mechanism-card {
    display: grid;
    min-height: 215px;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: start;
    padding: 26px;
    color: white;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.15);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .mechanism-card:hover {
    background: rgb(255 255 255 / 0.1);
    border-color: var(--color-gold-soft);
  }

  .mechanism-card h3 {
    margin-bottom: 10px;
    color: white;
  }

  .mechanism-card strong {
    display: block;
    margin-bottom: 10px;
    color: var(--color-gold-soft);
    font-size: 1.35rem;
  }

  .mechanism-card p {
    margin-bottom: 0;
    color: #c3cfde;
  }

  .mechanism-action {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: center;
    margin-top: 28px;
  }

  .text-link-light {
    color: white;
  }

  .working-chain {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .working-chain article {
    min-height: 230px;
    padding: 26px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .safety-entry-section {
    background: var(--color-paper);
  }

  .safety-entry {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(460px, 1.18fr);
    gap: clamp(42px, 8vw, 96px);
    align-items: center;
  }

  .safety-entry > div:first-child p:not(.section-kicker) {
    max-width: 650px;
    font-size: 1.06rem;
  }

  .safety-entry-points {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .safety-entry-points > div {
    min-height: 155px;
    padding: 22px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .safety-entry-points strong,
  .safety-entry-points span {
    display: block;
  }

  .safety-entry-points span {
    margin-top: 10px;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .working-chain span {
    display: block;
    margin-bottom: 46px;
    color: var(--color-gold);
    font-size: 0.76rem;
  }

  .demo-entry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    padding: 26px;
    margin-top: 14px;
    background: var(--color-gold-pale);
    border: 1px solid #ecd49d;
    border-radius: var(--radius-md);
  }

  .demo-entry h3,
  .demo-entry p:last-child {
    margin-bottom: 0;
  }

  .details-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }

  .details-grid a {
    display: flex;
    min-height: 180px;
    flex-direction: column;
    padding: 20px;
    color: white;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .details-grid span {
    color: var(--color-gold-soft);
    font-size: 0.74rem;
  }

  .details-grid strong {
    margin-top: 18px;
  }

  .details-grid svg {
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .safety-entry {
      grid-template-columns: 1fr;
    }

    .details-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    .mechanism-grid,
    .working-chain,
    .safety-entry-points,
    .details-grid {
      grid-template-columns: 1fr;
    }

    .mechanism-card {
      grid-template-columns: auto 1fr;
    }

    .mechanism-card > svg {
      display: none;
    }

    .demo-entry {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoDemo from "../../components/VideoDemo.astro";
import Icon from "../../components/Icon.astro";

const operationSteps = [
  { number: "01", title: "Получить", text: "Документ или данные поступают из разрешённого источника." },
  { number: "02", title: "Проверить", text: "ИИ сверяет реквизиты, правила и связи до совершения действия." },
  { number: "03", title: "Завершить или передать", text: "Типовая операция выполняется. Расхождение уходит специалисту с контекстом." },
  { number: "04", title: "Зафиксировать", text: "Результат появляется в 1С, а каждый шаг остаётся в журнале." }
];

const caseSteps = [
  { label: "Вход", text: "Акт поставщика на 148 тыс. ₽" },
  { label: "Проверка", text: "По договору согласовано 128 тыс. ₽" },
  { label: "Исключение", text: "Расхождение +20 тыс. ₽ — автоматическое проведение остановлено" },
  { label: "Решение человека", text: "Подтвердить допработы или запросить исправленный акт" }
];

const controlAreas = [
  {
    label: "Разрешённая роль",
    title: "ИИ не может выйти за границы операции.",
    text: "Для каждого помощника заранее задаются источники, доступные поля, допустимые действия и условия остановки."
  },
  {
    label: "Исключение человеку",
    title: "Неоднозначность не маскируется под ответ.",
    text: "Неполные данные, расхождение или необходимость профессионального суждения создают задачу специалисту."
  },
  {
    label: "Точность",
    title: "Свободный ответ не заменяет проверку.",
    text: "Результат проходит правила полноты, справочники и контрольные соотношения. Ошибка проверки блокирует операцию."
  },
  {
    label: "Безопасность",
    title: "Данные остаются в согласованном периметре.",
    text: "Размещение — в изолированном российском контуре или внутри контура компании. Права людей и ИИ разделены."
  }
];

const endToEndSteps = [
  "Забрать документ или данные из источника",
  "Распознать и определить операцию",
  "Проверить реквизиты, правила и связи",
  "Создать запись или документ в 1С",
  "Передать исключение специалисту",
  "Сохранить основание и историю действий"
];

const assistantLinks = [
  { href: "/avtomatizatsiya-ucheta/pervichnye-dokumenty/", label: "Первичные документы" },
  { href: "/avtomatizatsiya-ucheta/bankovskie-operatsii/", label: "Банковские операции" },
  { href: "/avtomatizatsiya-ucheta/sverki-s-kontragentami/", label: "Сверки с контрагентами" },
  { href: "/avtomatizatsiya-ucheta/zakrytie-perioda/", label: "Закрытие периода" },
  { href: "/avtomatizatsiya-ucheta/zarplata-i-kadry/", label: "Зарплата и кадры" },
  { href: "/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/", label: "Обращения и задачи" }
];
---

<BaseLayout
  title="Понять, как работает Aivel: операция, контроль и аудиторский след"
  description="Aivel выполняет учётную операцию от получения данных до записи в 1С, передаёт исключения специалисту и сохраняет проверяемую историю действий."
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Понять, как это работает</span>
  </div>

  <header class="page-hero mechanics-hero">
    <div class="container mechanics-hero-grid">
      <div class="mechanics-intro">
        <p class="section-kicker">Механика продукта</p>
        <h1>ИИ выполняет типовую операцию. Человек решает исключение.</h1>
        <p class="lead">Aivel действует только в разрешённом процессе: проверяет данные до операции, останавливается при расхождении и сохраняет основание каждого шага.</p>
        <ol class="operation-flow" aria-label="Этапы выполнения операции">
          {operationSteps.map((step) => (
            <li><span>{step.number}</span><div><h3>{step.title}</h3><p>{step.text}</p></div></li>
          ))}
        </ol>
      </div>

      <article class="exception-case" aria-label="Учебный мини-кейс обработки исключения">
        <header>
          <div><p class="section-kicker">Учебный мини-кейс</p><h2>ИИ заметил расхождение до проведения документа.</h2></div>
          <span class="case-status">Нужна проверка</span>
        </header>
        <ol>
          {caseSteps.map((step, index) => (
            <li><span class="case-number">{String(index + 1).padStart(2, "0")}</span><div><strong>{step.label}</strong><p>{step.text}</p></div></li>
          ))}
        </ol>
        <footer><Icon name="source" size={19} /><p><strong>В журнале останутся:</strong> исходный акт, договор, найденное расхождение, решение специалиста и итоговый документ в 1С.</p></footer>
      </article>
    </div>
  </header>

  <section class="section video-section" aria-labelledby="platform-video-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div><p class="section-kicker">Настоящая демонстрация</p><h2 id="platform-video-title">Первичный документ — от получения до результата в 1С.</h2></div>
        <p>В ролике виден не отдельный этап распознавания, а рабочий путь: данные документа, проверки, учётные признаки и созданное поступление.</p>
      </div>
      <VideoDemo
        driveId="1mjxxrczIp2mPWiIwWw1o2AerElWcS0vB"
        title="Как первичный документ превращается в поступление в 1С"
        description="ИИ получает документ, распознаёт его, заполняет учётные поля и показывает результат в 1С. Специалист подключается только там, где нужна проверка."
        label="Работающий ИИ-помощник"
      />
    </div>
  </section>

  <section class="section section-warm control-section" aria-labelledby="control-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div><p class="section-kicker">Почему можно доверять</p><h2 id="control-title">Роли, проверки и безопасность встроены в процесс.</h2></div>
        <p>Точность обеспечивается не обещанием модели, а ограничениями, проверками и передачей неоднозначного случая человеку.</p>
      </div>
      <div class="control-grid">
        {controlAreas.map((area) => (
          <article class="control-card"><span>{area.label}</span><h3>{area.title}</h3><p>{area.text}</p></article>
        ))}
      </div>
      <div class="audit-trail" aria-labelledby="audit-title">
        <div><p class="section-kicker section-kicker-light">Аудиторский след</p><h3 id="audit-title">Любой результат можно восстановить по шагам.</h3></div>
        <p>Журнал хранит исходные данные, выполненные проверки, изменения, исполнителя, время и итоговый статус. Специалист видит не только исключение, но и причину его появления.</p>
      </div>
    </div>
  </section>

  <section class="section section-dark comparison-section" aria-labelledby="comparison-title">
    <div class="container">
      <div class="section-heading compact-heading comparison-heading">
        <div><p class="section-kicker section-kicker-light">Не только распознавание</p><h2 id="comparison-title">Обычное распознавание закрывает фрагмент. Aivel — процесс целиком.</h2></div>
        <p>Результат Aivel — не набор извлечённых полей, а завершённая операция или подготовленное исключение для специалиста.</p>
      </div>
      <div class="comparison-grid">
        <article class="comparison-card comparison-card-muted">
          <span class="comparison-label">Распознавание документов</span>
          <h3>Из файла — в набор полей.</h3>
          <ol>
            <li><span>01</span>Получить отдельный файл</li>
            <li><span>02</span>Распознать реквизиты</li>
            <li><span>03</span>Передать результат человеку</li>
          </ol>
          <p>Проверка, ввод в учётную систему и разбор расхождений остаются ручными этапами.</p>
        </article>
        <article class="comparison-card comparison-card-aivel">
          <span class="comparison-label">Aivel</span>
          <h3>От источника — до результата в 1С.</h3>
          <ol>
            {endToEndSteps.map((step, index) => (
              <li><span>{String(index + 1).padStart(2, "0")}</span>{step}</li>
            ))}
          </ol>
        </article>
      </div>
      <nav class="assistant-links" aria-label="Демонстрации ИИ-помощников">
        <span>Разобрать отдельный процесс:</span>
        {assistantLinks.map((item) => <a href={item.href}>{item.label}<Icon name="arrow" size={17} /></a>)}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .mechanics-hero {
    padding-block: clamp(40px, 5vw, 68px);
  }

  .mechanics-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(460px, 1.08fr);
    gap: clamp(42px, 6vw, 82px);
    align-items: center;
  }

  .mechanics-intro,
  .exception-case {
    min-width: 0;
  }

  .mechanics-hero h1 {
    max-width: 850px;
    font-size: clamp(2.8rem, 4.7vw, 4.5rem);
  }

  .mechanics-hero .lead {
    max-width: 760px;
  }

  .operation-flow {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 26px 0 0;
    overflow: hidden;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    list-style: none;
  }

  .operation-flow li {
    display: grid;
    min-width: 0;
    grid-template-columns: 30px 1fr;
    gap: 9px;
    padding: 14px;
    background: var(--color-surface);
  }

  .operation-flow > li > span {
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 780;
  }

  .operation-flow h3 {
    margin: 0 0 4px;
    font-size: 0.92rem;
  }

  .operation-flow p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.42;
  }

  .exception-case {
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .exception-case > header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: start;
    padding: 24px;
    color: white;
    background: var(--color-ink);
  }

  .exception-case .section-kicker {
    margin-bottom: 7px;
    color: var(--color-gold-soft);
  }

  .exception-case h2 {
    margin: 0;
    color: white;
    font-size: clamp(1.45rem, 2.5vw, 2.15rem);
  }

  .case-status {
    padding: 7px 10px;
    color: #fff1c7;
    background: rgb(245 201 121 / 0.14);
    border: 1px solid rgb(245 201 121 / 0.28);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 780;
    white-space: nowrap;
  }

  .exception-case > ol {
    display: grid;
    gap: 0;
    padding: 0 24px;
    margin: 0;
    list-style: none;
  }

  .exception-case > ol li {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 10px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .case-number {
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 780;
  }

  .exception-case li strong,
  .exception-case li p {
    display: block;
    margin: 0;
  }

  .exception-case li strong {
    margin-bottom: 3px;
    color: var(--color-ink);
    font-size: 0.78rem;
  }

  .exception-case li p {
    color: var(--color-text);
    font-size: 0.84rem;
    line-height: 1.42;
  }

  .exception-case > footer {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 9px;
    padding: 16px 24px;
    color: var(--color-blue);
    background: var(--color-blue-pale);
  }

  .exception-case > footer p {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .compact-heading {
    margin-bottom: 28px;
  }

  .video-section {
    padding-block: clamp(58px, 7vw, 88px);
  }

  .control-section {
    padding-block: clamp(64px, 8vw, 98px);
  }

  .control-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .control-card {
    min-width: 0;
    padding: 23px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .control-card > span,
  .comparison-label {
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .control-card h3 {
    margin: 26px 0 9px;
    font-size: 1.05rem;
  }

  .control-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .audit-trail {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(28px, 7vw, 90px);
    align-items: end;
    padding: 26px;
    margin-top: 12px;
    color: white;
    background: var(--color-ink);
    border-radius: var(--radius-md);
  }

  .audit-trail h3,
  .audit-trail > p {
    margin-bottom: 0;
    color: white;
  }

  .audit-trail > p {
    color: #c3cfde;
  }

  .comparison-heading h2,
  .comparison-heading > p {
    color: white;
  }

  .comparison-heading > p {
    color: #c3cfde;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 14px;
  }

  .comparison-card {
    min-width: 0;
    padding: clamp(24px, 3vw, 34px);
    border: 1px solid rgb(255 255 255 / 0.15);
    border-radius: var(--radius-md);
  }

  .comparison-card-muted {
    background: rgb(255 255 255 / 0.045);
  }

  .comparison-card-aivel {
    background: rgb(255 255 255 / 0.1);
    border-color: var(--color-gold-soft);
  }

  .comparison-card h3 {
    margin: 24px 0;
    color: white;
  }

  .comparison-card ol {
    display: grid;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .comparison-card li {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 10px;
    padding: 12px 0;
    color: white;
    border-top: 1px solid rgb(255 255 255 / 0.13);
  }

  .comparison-card li span {
    color: var(--color-gold-soft);
    font-size: 0.74rem;
  }

  .comparison-card > p {
    margin: 22px 0 0;
    color: #aebdce;
    font-size: 0.86rem;
  }

  .assistant-links {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    align-items: center;
    padding-top: 24px;
  }

  .assistant-links > span {
    margin-right: 5px;
    color: #b8c5d6;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .assistant-links a {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    gap: 7px;
    padding: 8px 12px;
    color: white;
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 999px;
    font-size: 0.78rem;
    text-decoration: none;
  }

  .assistant-links a:hover {
    border-color: var(--color-gold-soft);
  }

  @media (max-width: 1120px) {
    .mechanics-hero-grid {
      grid-template-columns: 1fr;
    }

    .mechanics-intro,
    .exception-case {
      max-width: 900px;
    }

    .control-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 800px) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .mechanics-hero h1 {
      font-size: clamp(2.4rem, 11.5vw, 3.35rem);
    }

    .mechanics-intro .operation-flow {
      display: none;
    }

    .operation-flow,
    .control-grid,
    .audit-trail {
      grid-template-columns: 1fr;
    }

    .exception-case > header {
      grid-template-columns: 1fr;
    }

    .case-status {
      width: fit-content;
    }

    .assistant-links {
      align-items: stretch;
      flex-direction: column;
    }

    .assistant-links > span,
    .assistant-links a {
      width: 100%;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImportantSignalDemo from "../../components/ImportantSignalDemo.astro";
import AnswerDemo from "../../components/AnswerDemo.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { importantSignals } from "../../data/site";

const questions = (await getCollection("questions")).sort((a, b) => a.data.order - b.data.order);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Важное в бизнесе: сигналы и проверяемые ответы Aivel",
    description:
      "Aivel замечает значимые изменения, объясняет их важность и позволяет задать уточняющий вопрос по тем же данным."
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: importantSignals.map((signal, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: signal.signal
    }))
  }
];
---

<BaseLayout
  title="Важное в бизнесе: сигналы и проверяемые ответы — Aivel"
  description="Aivel вовремя замечает важные изменения, показывает их основание и отвечает на уточняющие вопросы по данным учёта."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Важное</span>
  </div>

  <header class="page-hero unified-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">Одна цепочка от изменения до решения</p>
        <h1>Сначала Aivel замечает важное. Затем вы можете спросить о чём угодно.</h1>
        <p class="lead">Система обращает внимание на значимое изменение, объясняет, почему оно требует решения, и показывает основание. После этого вы уточняете причину, проверяете сценарий или раскрываете цифру до операции.</p>
        <nav class="mode-nav" aria-label="Сценарии работы с важным">
          <a href="#signaly"><span>01</span><strong>Aivel замечает сам</strong></a>
          <a href="#voprosy"><span>02</span><strong>Вы спрашиваете сами</strong></a>
        </nav>
      </div>
      <aside class="page-hero-aside">
        <strong>Проверяемость важнее уверенного тона</strong>
        <p>Сигнал и ответ показывают период, свежесть, источники, расчёт и границу вывода. Если данных недостаточно, Aivel показывает пробел или подключает специалиста.</p>
      </aside>
    </div>
  </header>

  <section class="section section-warm" aria-labelledby="chain-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Как возникает решение</p><h2 id="chain-title">Вопрос — не отдельный продукт, а следующий шаг после сигнала.</h2></div>
        <p>Один и тот же учётный контур помогает сначала не пропустить изменение, а затем разобраться, что именно оно меняет для бизнеса.</p>
      </div>
      <ol class="unified-chain" aria-label="Путь от изменения к проверке результата">
        <li><span>01</span><strong>Изменение</strong><p>В подключённом источнике появляется новый факт, прогноз или отклонение.</p></li>
        <li><span>02</span><strong>Важность</strong><p>Aivel связывает его с согласованной границей, сроком или возможным последствием.</p></li>
        <li><span>03</span><strong>Уточнение</strong><p>Вы спрашиваете о причине, другом сценарии или составе цифры обычными словами.</p></li>
        <li><span>04</span><strong>Решение</strong><p>Получаете следующий шаг, основание и дату повторной проверки.</p></li>
      </ol>
    </div>
  </section>

  <section class="section" id="signaly" aria-labelledby="signals-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Aivel обращает внимание сам</p><h2 id="signals-title">Узнайте о важном до того, как решение опоздает.</h2></div>
        <p>Наблюдение начинается с узкого набора событий, для которых понятны источник, правило важности, получатель и возможное действие.</p>
      </div>
      <ImportantSignalDemo />
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="classes-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">С чего начать наблюдение</p><h2 id="classes-title">Изменения, которые уже влияют на деньги и действия.</h2></div>
        <p>Это не общий поток уведомлений. Каждое событие связано с конкретным решением владельца или руководителя.</p>
      </div>
      <div class="numbered-grid">
        <article class="numbered-card"><h3>Денег может не хватить к обязательствам</h3><p>Прогноз остатка пересекает согласованную границу к дате налогов, зарплаты или крупного платежа.</p><a class="text-link" href="/voprosy/hvatit-li-deneg-na-nalogi-i-zarplatu/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
        <article class="numbered-card"><h3>Значимая оплата задержалась</h3><p>Просрочка покупателя уже влияет на резерв денег или порядок ближайших выплат.</p><a class="text-link" href="/voprosy/kto-zaderzhivaet-oplatu/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
        <article class="numbered-card"><h3>Расходы отклонились от обычного</h3><p>Изменение оказалось сильнее ожидаемого и влияет на прибыльность направления, проекта или клиента.</p><a class="text-link" href="/voprosy/gde-vyrosli-rashody/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
        <article class="numbered-card"><h3>Прибыль и деньги расходятся</h3><p>Прибыль признана, но деньги ушли в задолженность, запасы, займ или другое движение.</p><a class="text-link" href="/voprosy/pochemu-pribyl-est-a-deneg-net/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
        <article class="numbered-card"><h3>Запас денег сокращается</h3><p>Текущий темп обязательных расходов уменьшает время на решение быстрее согласованного плана.</p><a class="text-link" href="/voprosy/na-skolko-mesyatsev-hvatit-deneg/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
        <article class="numbered-card"><h3>Прибыльность клиента снизилась</h3><p>Доходы и связанные расходы изменились так, что цену или состав работ стоит проверить.</p><a class="text-link" href="/voprosy/kakie-klienty-i-proekty-pribylny/">Посмотреть разбор <Icon name="arrow" size={18} /></a></article>
      </div>
    </div>
  </section>

  <section class="section" id="voprosy" aria-labelledby="questions-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Вы спрашиваете сами</p><h2 id="questions-title">Задайте любой вопрос о бизнесе — и проверьте, откуда взялся ответ.</h2></div>
        <p>Вопрос можно задать после сигнала или независимо от него. Aivel отвечает по доступным данным, уточняет смысл, показывает пробел или передаёт вопрос специалисту.</p>
      </div>
      <AnswerDemo />
      <div class="question-divider">
        <p class="section-kicker">Десять частых решений владельца</p>
        <h2>Начните с вопроса, который уже влияет на деньги или рост.</h2>
      </div>
      <div class="question-grid">
        {questions.map((question) => (
          <QuestionCard
            slug={question.id}
            title={question.data.title}
            description={question.data.description}
            categoryLabel={question.data.categoryLabel}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="limits-title">
    <div class="container content-layout">
      <div><p class="section-kicker">Честная граница</p><h2 id="limits-title">Aivel не выдумывает недостающие факты.</h2></div>
      <div class="prose">
        <p>Aivel не гарантирует обнаружение любого события. Одна и та же сумма или задержка может быть критичной для одного бизнеса и обычной для другого, поэтому мы вместе определяем периметр, границы, сроки, получателей и порядок передачи специалисту.</p>
        <p>Если источник не подключён, устарел или расходится с другим, это видно рядом с выводом. Профессиональное суждение остаётся за человеком.</p>
        <p><a class="text-link" href="/kak-rabotaet/">Как устроена вся цепочка <Icon name="arrow" size={18} /></a></p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Ваш контролируемый периметр</p>
      <h2>Что в вашем бизнесе нельзя узнать слишком поздно?</h2>
      <p>Разберём первые события, источники и вопросы, с которых имеет смысл начать.</p>
      <button class="button button-light" type="button" data-open-contact>Определить важные сигналы</button>
    </div>
  </section>
</BaseLayout>

<style>
  .unified-hero {
    padding-bottom: clamp(64px, 8vw, 104px);
  }

  .mode-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 32px;
  }

  .mode-nav a {
    min-height: 72px;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1px solid var(--line, #dfe4e7);
    border-radius: 16px;
    color: inherit;
    background: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .mode-nav a:hover,
  .mode-nav a:focus-visible {
    border-color: var(--ink, #12211d);
    background: #fff;
  }

  .mode-nav span {
    color: var(--accent, #0f766e);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .unified-chain {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin: 36px 0 0;
    padding: 1px;
    border-radius: 22px;
    overflow: hidden;
    background: rgba(19, 41, 34, 0.14);
  }

  .unified-chain li {
    min-height: 220px;
    padding: 28px;
    background: #fff;
  }

  .unified-chain span {
    display: block;
    margin-bottom: 40px;
    color: var(--accent, #0f766e);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .unified-chain strong {
    display: block;
    margin-bottom: 10px;
    font-size: 1.18rem;
  }

  .unified-chain p {
    margin: 0;
  }

  .question-divider {
    max-width: 760px;
    margin: clamp(64px, 8vw, 104px) 0 30px;
  }

  .question-divider h2 {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .unified-chain {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .mode-nav,
    .unified-chain {
      grid-template-columns: 1fr;
    }

    .unified-chain li {
      min-height: auto;
    }

    .unified-chain span {
      margin-bottom: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mode-nav a {
      transition: none;
    }
  }
</style>

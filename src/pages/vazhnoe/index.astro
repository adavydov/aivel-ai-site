---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SignalDeliveryCarousel from "../../components/SignalDeliveryCarousel.astro";
import Icon from "../../components/Icon.astro";
import { signalDeliveryExamples } from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Увидеть важное вовремя — сигналы Aivel",
    description:
      "Aivel сам замечает значимые изменения и присылает короткое проверяемое сообщение в Telegram или по почте."
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: signalDeliveryExamples.map((example, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: example.subject
    }))
  }
];
---

<BaseLayout
  title="Увидеть важное вовремя: сигналы в Telegram и по почте — Aivel"
  description="Aivel сам замечает важные изменения и присылает короткое сообщение: что произошло, почему важно, что сделать и на чём основан вывод."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Увидеть важное</span>
  </div>

  <header class="page-hero signal-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">Aivel замечает сам</p>
        <h1>Важное само приходит к вам — пока ещё можно повлиять.</h1>
        <p class="lead">Короткое сообщение в Telegram или по почте: что произошло, почему это важно, что сделать сейчас и на чём основан вывод. Не нужно открывать новый кабинет или заранее знать правильный вопрос.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#primery-soobshcheniy">Посмотреть сообщения <Icon name="arrow" size={20} /></a>
          <button class="button button-secondary" type="button" data-open-contact data-contact-topic="client">Выбрать первые сигналы</button>
        </div>
      </div>
      <aside class="page-hero-aside signal-hero-aside">
        <strong>Продукт почти не требует интерфейса</strong>
        <ul>
          <li><Icon name="check" size={18} /> Без отдельного кабинета</li>
          <li><Icon name="check" size={18} /> Без заранее сформулированного вопроса</li>
          <li><Icon name="check" size={18} /> С основанием и следующим шагом</li>
        </ul>
      </aside>
    </div>
  </header>

  <section class="section message-demo-section" aria-labelledby="messages-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Так выглядит продукт</p><h2 id="messages-title">Одно понятное сообщение вместо ещё одного сложного кабинета.</h2></div>
        <p>Переключите четыре ситуации. Сигналы приходят сами; для каждого заранее определены получатель, канал и момент, когда ещё можно действовать.</p>
      </div>
      <div id="primery-soobshcheniy">
        <SignalDeliveryCarousel />
      </div>
      <p class="demo-note"><Icon name="shield" size={18} /> Учебные примеры на обезличенных данных. В реальной работе события и границы настраиваются под ваш бизнес.</p>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="fear-map-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Что нельзя узнать поздно</p><h2 id="fear-map-title">Страх превращается в конкретное событие для наблюдения.</h2></div>
        <p>Мы не обещаем следить «за всем». Начинаем с нескольких решений, где цена опоздания понятна владельцу.</p>
      </div>
      <div class="risk-map">
        <article>
          <span>Деньги</span>
          <h3>Хватит ли на обязательства</h3>
          <p>Запас денег, ближайшие налоги и зарплата, задержки крупных оплат и сокращение времени на решение.</p>
        </article>
        <article>
          <span>Прибыль</span>
          <h3>Где незаметно теряется результат</h3>
          <p>Необычный рост расходов, снижение прибыльности клиента или направления, расхождение прибыли и денег.</p>
        </article>
        <article>
          <span>Рост</span>
          <h3>Выдержит ли бизнес следующий шаг</h3>
          <p>Полная стоимость найма, запас денег после решения и условия, при которых рост остаётся безопасным.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="setup-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Как запускается наблюдение</p><h2 id="setup-title">Три шага — и важное приходит само.</h2></div>
        <p>Не нужно переносить всю работу в новую систему. Aivel использует согласованные источники и доставляет вывод туда, где вы уже читаете сообщения.</p>
      </div>
      <ol class="delivery-steps">
        <li><span>01</span><h3>Выбираем первые риски</h3><p>Фиксируем 3–5 событий, которые нельзя узнать поздно, их границы и время для действия.</p></li>
        <li><span>02</span><h3>Подключаем основание</h3><p>Определяем нужные данные, частоту обновления и случаи, которые должен проверить специалист.</p></li>
        <li><span>03</span><h3>Назначаем получателей</h3><p>Сообщение приходит в Telegram или на почту владельцу и тем, кто отвечает за следующий шаг.</p></li>
      </ol>
    </div>
  </section>

  <section class="section section-dark" id="voprosy" aria-labelledby="situation-guides-title">
    <div class="container">
      <div class="section-heading situation-guides-heading">
        <div><p class="section-kicker section-kicker-light">Подробные разборы</p><h2 id="situation-guides-title">Проверьте логику типичных событий.</h2></div>
        <p>Короткое сообщение ведёт к расчёту и источникам. Эти страницы показывают, какие данные нужны и где остаётся профессиональное суждение.</p>
      </div>
      <div class="situation-links">
        {signalDeliveryExamples.map((example) => (
          <a href={example.detailsHref}>
            <span>{example.tab}</span>
            <strong>{example.subject}</strong>
            <Icon name="arrow" size={20} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="trust-title">
    <div class="container trust-layout">
      <div>
        <p class="section-kicker">Коротко — не значит без основания</p>
        <h2 id="trust-title">Сначала суть. Подробности — по ссылке.</h2>
      </div>
      <div class="trust-copy">
        <p>Aivel не гарантирует обнаружение любого события. До запуска мы согласуем источники, границы, сроки и получателей. Если данных недостаточно или они расходятся, автоматический вывод не подменяет проверку специалиста.</p>
        <ul>
          <li><Icon name="source" size={20} /><span><strong>Видно основание</strong> Источники и время обновления находятся рядом с сигналом.</span></li>
          <li><Icon name="shield" size={20} /><span><strong>Факт не смешан с прогнозом</strong> В сообщении понятно, что уже произошло, а что является расчётным сценарием.</span></li>
          <li><Icon name="person" size={20} /><span><strong>Сложное проверяет человек</strong> Неоднозначные случаи передаются специалисту до управленческого решения.</span></li>
        </ul>
        <a class="text-link" href="/kak-rabotaet/">Как устроена вся цепочка <Icon name="arrow" size={18} /></a>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Начать с малого</p>
      <h2>Что в вашем бизнесе нельзя узнать слишком поздно?</h2>
      <p>Определим первые 3–5 сигналов, нужные источники, получателей и следующий шаг для каждого события.</p>
      <button class="button button-light" type="button" data-open-contact data-contact-topic="client">Настроить первые сигналы</button>
    </div>
  </section>
</BaseLayout>

<style>
  .signal-hero {
    padding-bottom: clamp(70px, 9vw, 118px);
  }

  .signal-hero .lead {
    max-width: 790px;
  }

  .signal-hero-aside ul {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 22px 0 0;
    list-style: none;
  }

  .signal-hero-aside li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: var(--color-text);
  }

  .signal-hero-aside li svg {
    flex: 0 0 auto;
    margin-top: 4px;
    color: var(--color-green);
  }

  .message-demo-section {
    padding-top: clamp(72px, 8vw, 116px);
  }

  .demo-note {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    max-width: 760px;
    margin: 18px 0 0;
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  .demo-note svg {
    flex: 0 0 auto;
    margin-top: 2px;
  }

  .risk-map {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .risk-map article {
    min-height: 280px;
    padding: clamp(24px, 3vw, 36px);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .risk-map article > span {
    display: inline-flex;
    margin-bottom: clamp(42px, 6vw, 74px);
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .risk-map h3 {
    margin-bottom: 12px;
  }

  .risk-map p {
    margin: 0;
  }

  .delivery-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 0;
    overflow: hidden;
    background: var(--color-border);
    border-radius: var(--radius-lg);
    list-style: none;
  }

  .delivery-steps li {
    min-height: 310px;
    padding: clamp(24px, 3vw, 38px);
    background: var(--color-surface);
  }

  .delivery-steps li > span {
    display: block;
    margin-bottom: clamp(52px, 7vw, 92px);
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .delivery-steps p {
    margin-bottom: 0;
  }

  .situation-guides-heading h2,
  .situation-guides-heading p {
    color: white;
  }

  .situation-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .situation-links a {
    display: grid;
    min-height: 132px;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px 16px;
    align-items: center;
    padding: 22px;
    color: white;
    background: rgb(255 255 255 / 0.045);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition), border-color var(--transition);
  }

  .situation-links a:hover {
    background: rgb(255 255 255 / 0.08);
    border-color: rgb(245 201 121 / 0.45);
  }

  .situation-links a > span {
    color: var(--color-gold-soft);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .situation-links strong {
    grid-column: 1;
    max-width: 520px;
    line-height: 1.28;
  }

  .situation-links svg {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  .trust-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(42px, 8vw, 120px);
    align-items: start;
  }

  .trust-copy > p {
    margin-bottom: 26px;
    font-size: 1.05rem;
  }

  .trust-copy ul {
    display: grid;
    gap: 10px;
    padding: 0;
    margin: 0 0 26px;
    list-style: none;
  }

  .trust-copy li {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .trust-copy li svg {
    flex: 0 0 auto;
    margin-top: 2px;
    color: var(--color-blue);
  }

  .trust-copy li span {
    color: var(--color-text);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .trust-copy li strong {
    display: block;
    margin-bottom: 3px;
    color: var(--color-ink);
  }

  @media (max-width: 880px) {
    .risk-map,
    .delivery-steps,
    .trust-layout {
      grid-template-columns: 1fr;
    }

    .risk-map article,
    .delivery-steps li {
      min-height: 0;
    }

    .risk-map article > span,
    .delivery-steps li > span {
      margin-bottom: 28px;
    }
  }

  @media (max-width: 620px) {
    .situation-links {
      grid-template-columns: 1fr;
    }

    .situation-links a {
      min-height: 116px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .situation-links a {
      transition: none;
    }
  }
</style>

---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const questions = await getCollection("questions");
  return questions.map((question) => ({ params: { slug: question.id }, props: { question, questions } }));
}

const { question, questions } = Astro.props;
const { Content } = await render(question);
const related = question.data.related
  .map((slug: string) => questions.find((entry: typeof question) => entry.id === slug))
  .filter((entry): entry is NonNullable<typeof entry> => entry !== undefined);

const demoScenarioByQuestion: Record<string, "cash" | "payment" | "expense" | "hiring"> = {
  "chto-izmenilos-za-mesyats": "expense",
  "gde-vyrosli-rashody": "expense",
  "hvatit-li-deneg-na-nalogi-i-zarplatu": "cash",
  "kakie-klienty-i-proekty-pribylny": "expense",
  "kakie-obyazatelstva-vperedi": "cash",
  "kto-zaderzhivaet-oplatu": "payment",
  "mozhno-li-nanyat-sotrudnika": "hiring",
  "na-skolko-mesyatsev-hvatit-deneg": "cash",
  "pochemu-pribyl-est-a-deneg-net": "cash",
  "skolko-deneg-mozhno-vyvesti": "cash"
};
const demoScenario = demoScenarioByQuestion[question.id] || "cash";
const contactTopic = demoScenario === "expense" ? "profit" : demoScenario === "hiring" ? "growth" : "money";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: question.data.title,
  description: question.data.description,
  author: { "@type": "Organization", name: "Aivel" },
  publisher: { "@type": "Organization", name: "Aivel" },
  inLanguage: "ru-RU",
  mainEntityOfPage: `${site.url}/voprosy/${question.id}/`
};
---

<BaseLayout title={`${question.data.title} — разбор ситуации Aivel`} description={question.data.description} schema={schema}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><a href="/vazhnoe/#voprosy">Разборы ситуаций</a><span aria-hidden="true">/</span><span>{question.data.shortTitle}</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">{question.data.categoryLabel}</p>
        <h1>{question.data.title}</h1>
        <p class="lead">{question.data.description}</p>
        <div class="question-answer-lead question-answer-hero">
          <span>Короткий ответ</span>
          <p>{question.data.answerLead}</p>
        </div>
        <a class="button button-primary" href="/vazhnoe/#primery-soobshcheniy">Посмотреть похожий входящий сигнал</a>
      </div>
      <aside class="page-hero-aside">
        <strong>Решение, которое зависит от ответа</strong>
        <p>{question.data.decision}</p>
      </aside>
    </div>
  </header>

  <section class="section">
    <div class="container content-layout">
      <aside class="content-aside" aria-label="Паспорт ответа">
        <div class="content-aside-card">
          <span>Период</span>
          <p>{question.data.period}</p>
        </div>
        <div class="content-aside-card">
          <span>Свежесть</span>
          <p>{question.data.freshness}</p>
        </div>
        <div class="content-aside-card">
          <span>Периметр</span>
          <p>{question.data.scope}</p>
        </div>
        <div class="content-aside-card">
          <span>Aivel замечает сам</span>
          <p>Похожее изменение можно заметить раньше по согласованному правилу.</p>
          <a class="text-link" href="/vazhnoe/#primery-soobshcheniy">Как приходит сигнал <Icon name="arrow" size={17} /></a>
        </div>
        <div class="content-aside-card">
          <span>Проверить основание</span>
          <p>Как Aivel показывает источники, свежесть и границы вывода.</p>
          <a class="text-link" href="/kak-formiruetsya-otvet/">Разобрать основание <Icon name="arrow" size={17} /></a>
        </div>
      </aside>

      <article class="prose">
        <h2>Какие данные нужны</h2>
        <ul>
          {question.data.dataNeeded.map((item: string) => <li>{item}</li>)}
        </ul>

        <Content />

        <h2>Источники сигнала и расчёта</h2>
        <div class="source-stack">
          {question.data.sourceLabels.map((source: string) => <span><Icon name="source" size={16} />{source}</span>)}
        </div>

        <h2>Что нельзя заключить автоматически</h2>
        <div class="notice">
          <Icon name="shield" size={24} />
          <p><strong>Ограничение:</strong> {question.data.limitation}</p>
        </div>
        <p><strong>Роль специалиста.</strong> {question.data.specialist}</p>

        <h2>Как Aivel замечает такую ситуацию после подключения</h2>
        <ol>
          <li>Вместе с клиентом фиксируется событие, граница, период и часть бизнеса.</li>
          <li>Aivel проверяет обновление источников и наличие нужных данных.</li>
          <li>Когда условие срабатывает, система строит воспроизводимый расчёт.</li>
          <li>Неоднозначный вывод передаётся ответственному специалисту.</li>
          <li>Короткий сигнал приходит в Telegram или по почте вместе со следующим шагом.</li>
        </ol>

        <blockquote>
          <p>Пример на сайте не является ответом для вашей компании. Реальный вывод зависит от подключённых источников, периода и состояния учёта.</p>
        </blockquote>

        <button class="button button-primary" type="button" data-open-contact data-contact-topic={contactTopic}>Настроить такой сигнал <Icon name="arrow" size={20} /></button>
      </article>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section section-warm" aria-labelledby="related-title">
      <div class="container">
        <div class="section-heading">
          <div><p class="section-kicker">Следующая ситуация</p><h2 id="related-title">Связанные решения</h2></div>
          <p>Одно важное событие часто связано со следующим узлом — обязательством, прибыльностью или запасом денег.</p>
        </div>
        <div class="question-grid">
          {related.map((entry) => (
            <QuestionCard
              slug={entry.id}
              title={entry.data.title}
              description={entry.data.description}
              categoryLabel={entry.data.categoryLabel}
              compact
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

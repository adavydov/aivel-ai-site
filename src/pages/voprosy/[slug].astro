---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const questions = await getCollection("questions");
  return questions.map((question) => ({ params: { slug: question.id }, props: { question, questions } }));
}

const { question, questions } = Astro.props;
const { Content } = await render(question);
const related = question.data.related
  .map((slug: string) => questions.find((entry: typeof question) => entry.id === slug))
  .filter((entry): entry is NonNullable<typeof entry> => entry !== undefined);

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: question.data.title,
  description: question.data.description,
  author: { "@type": "Organization", name: "Aivel" },
  publisher: { "@type": "Organization", name: "Aivel" },
  inLanguage: "ru-RU",
  mainEntityOfPage: `${site.url}/voprosy/${question.id}/`
};
---

<BaseLayout title={`${question.data.title} — проверяемый ответ Aivel`} description={question.data.description} schema={schema}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><a href="/vazhnoe/#voprosy">Важное и вопросы</a><span aria-hidden="true">/</span><span>{question.data.shortTitle}</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">{question.data.categoryLabel}</p>
        <h1>{question.data.title}</h1>
        <p class="lead">{question.data.description}</p>
      </div>
      <aside class="page-hero-aside">
        <strong>Решение, которое зависит от ответа</strong>
        <p>{question.data.decision}</p>
      </aside>
    </div>
  </header>

  <section class="section">
    <div class="container content-layout">
      <aside class="content-aside" aria-label="Паспорт ответа">
        <div class="content-aside-card">
          <span>Период</span>
          <p>{question.data.period}</p>
        </div>
        <div class="content-aside-card">
          <span>Свежесть</span>
          <p>{question.data.freshness}</p>
        </div>
        <div class="content-aside-card">
          <span>Периметр</span>
          <p>{question.data.scope}</p>
        </div>
        <div class="content-aside-card">
          <span>До вопроса</span>
          <p>Похожее изменение можно заметить раньше по согласованному правилу.</p>
          <a class="text-link" href="/vazhnoe/">Как выглядит сигнал <Icon name="arrow" size={17} /></a>
        </div>
        <div class="content-aside-card">
          <span>Следующий шаг</span>
          <button class="button button-primary" type="button" data-open-contact style="width: 100%;">Обсудить вопрос</button>
        </div>
      </aside>

      <article class="prose">
        <div class="question-answer-lead">
          <span>Короткий ответ</span>
          <p>{question.data.answerLead}</p>
        </div>

        <h2>Какие данные нужны</h2>
        <ul>
          {question.data.dataNeeded.map((item: string) => <li>{item}</li>)}
        </ul>

        <div class="answer-passport" aria-label="Свойства проверяемого ответа">
          <div class="passport-item"><span>Период</span><strong>{question.data.period}</strong></div>
          <div class="passport-item"><span>Свежесть</span><strong>{question.data.freshness}</strong></div>
          <div class="passport-item"><span>Периметр</span><strong>{question.data.scope}</strong></div>
        </div>

        <Content />

        <h2>Источники ответа</h2>
        <div class="source-stack">
          {question.data.sourceLabels.map((source: string) => <span><Icon name="source" size={16} />{source}</span>)}
        </div>

        <h2>Что нельзя заключить автоматически</h2>
        <div class="notice">
          <Icon name="shield" size={24} />
          <p><strong>Ограничение:</strong> {question.data.limitation}</p>
        </div>
        <p><strong>Роль специалиста.</strong> {question.data.specialist}</p>

        <h2>Как этот вопрос решается после подключения</h2>
        <ol>
          <li>Aivel определяет смысл вопроса, период и часть бизнеса.</li>
          <li>Проверяет готовность источников и показывает недостающие данные.</li>
          <li>Строит воспроизводимый расчёт и связывает вывод с основанием.</li>
          <li>Передаёт профессиональное суждение ответственному специалисту.</li>
          <li>Помогает зафиксировать решение и вернуться к результату позже.</li>
        </ol>

        <blockquote>
          <p>Пример на сайте не является ответом для вашей компании. Реальный вывод зависит от подключённых источников, периода и состояния учёта.</p>
        </blockquote>

        <button class="button button-primary" type="button" data-open-contact>Обсудить вопрос и сопровождение <Icon name="arrow" size={20} /></button>
      </article>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section section-warm" aria-labelledby="related-title">
      <div class="container">
        <div class="section-heading">
          <div><p class="section-kicker">Следующий вопрос</p><h2 id="related-title">Связанные решения</h2></div>
          <p>Один ответ часто открывает следующий узел — обязательство, прибыльность или запас денег.</p>
        </div>
        <div class="question-grid">
          {related.map((entry) => (
            <QuestionCard
              slug={entry.id}
              title={entry.data.title}
              description={entry.data.description}
              categoryLabel={entry.data.categoryLabel}
              compact
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { solutions } from "../../data/site";

const questions = (await getCollection("questions")).sort((a, b) => a.data.order - b.data.order);
const bySlug = new Map(questions.map((question) => [question.id, question]));
---

<BaseLayout
  title="Разборы важных ситуаций в бизнесе — Aivel"
  description="Типичные важные ситуации в бизнесе: какие данные позволяют заметить их раньше, как проверить основание и какое решение от них зависит."
  schema={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Разборы важных ситуаций",
    description: "Проверяемые сигналы по данным учёта"
  }}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Разборы ситуаций</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">После важного сигнала</p>
        <h1>Проверьте, как Aivel замечает типичную важную ситуацию.</h1>
        <p class="lead">Выберите событие, которое влияет на деньги или рост. На каждой странице видно, какие данные нужны, как проверить основание и где требуется специалист.</p>
      </div>
      <aside class="page-hero-aside">
        <strong>Справочник, а не отдельный кабинет</strong>
        <p>Эти разборы помогают понять механику. В работе Aivel сообщает о согласованном событии сам — до того, как руководитель догадается искать его в отчётах.</p>
      </aside>
    </div>
  </header>

  <div>
    {solutions.map((solution, index) => {
      const groupQuestions = solution.questionSlugs.map((slug) => bySlug.get(slug)).filter(Boolean);
      return (
        <section class:list={["section", index % 2 === 1 && "section-warm"]} aria-labelledby={`group-${solution.slug}`}>
          <div class="container">
            <div class="section-heading">
              <div>
                <p class="section-kicker">{solution.eyebrow}</p>
                <h2 id={`group-${solution.slug}`}>{solution.title}</h2>
              </div>
              <p>{solution.description}</p>
            </div>
            <div class="question-grid">
              {groupQuestions.map((question) => question && (
                <QuestionCard
                  slug={question.id}
                  title={question.data.title}
                  description={question.data.description}
                  categoryLabel={question.data.categoryLabel}
                />
              ))}
            </div>
            <p style="margin-top: 28px;"><a class="text-link" href={`/resheniya/${solution.slug}/`}>Все о ситуации <Icon name="arrow" size={20} /></a></p>
          </div>
        </section>
      );
    })}
  </div>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Не ждать вопроса</p>
      <h2>Настройте наблюдение до того, как проблема станет очевидной.</h2>
      <p>Выберем первые события, подключим основание и определим, кому отправлять короткий сигнал в Telegram или по почте.</p>
      <button class="button button-light" type="button" data-open-contact data-contact-topic="client">Настроить первые сигналы</button>
    </div>
  </section>
</BaseLayout>

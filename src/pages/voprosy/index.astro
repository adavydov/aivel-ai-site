---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AnswerDemo from "../../components/AnswerDemo.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { solutions } from "../../data/site";

const questions = (await getCollection("questions")).sort((a, b) => a.data.order - b.data.order);
const bySlug = new Map(questions.map((question) => [question.id, question]));
---

<BaseLayout
  title="Вопросы после важного изменения — Aivel"
  description="Десять вопросов владельца бизнеса после важного сигнала: какие данные нужны, как проверить ответ и какое решение от него зависит."
  schema={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Вопросы бизнеса",
    description: "Проверяемые ответы по данным учёта"
  }}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Вопросы бизнеса</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">После важного сигнала</p>
        <h1>Увидели изменение — спросите, что оно значит для решения.</h1>
        <p class="lead">Выберите вопрос, который уже влияет на деньги или рост. На каждой странице видно, какие данные нужны, как проверить основание и где требуется специалист.</p>
      </div>
      <aside class="page-hero-aside">
        <strong>Вопрос остаётся сильной возможностью</strong>
        <p>Aivel может обратить внимание на изменение первым, а затем ответить на уточнение обычными словами на той же учётной основе.</p>
      </aside>
    </div>
  </header>

  <section class="section" aria-labelledby="answer-example-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Проверяемый ответ</p><h2 id="answer-example-title">Не просто объяснение — период, расчёт, источник и граница.</h2></div>
        <p>Подготовленные примеры показывают, как после сигнала раскрыть причину или проверить решение глубже.</p>
      </div>
      <AnswerDemo />
    </div>
  </section>

  <div>
    {solutions.map((solution, index) => {
      const groupQuestions = solution.questionSlugs.map((slug) => bySlug.get(slug)).filter(Boolean);
      return (
        <section class:list={["section", index % 2 === 1 && "section-warm"]} aria-labelledby={`group-${solution.slug}`}>
          <div class="container">
            <div class="section-heading">
              <div>
                <p class="section-kicker">{solution.eyebrow}</p>
                <h2 id={`group-${solution.slug}`}>{solution.title}</h2>
              </div>
              <p>{solution.description}</p>
            </div>
            <div class="question-grid">
              {groupQuestions.map((question) => question && (
                <QuestionCard
                  slug={question.id}
                  title={question.data.title}
                  description={question.data.description}
                  categoryLabel={question.data.categoryLabel}
                />
              ))}
            </div>
            <p style="margin-top: 28px;"><a class="text-link" href={`/resheniya/${solution.slug}/`}>Все о ситуации <Icon name="arrow" size={20} /></a></p>
          </div>
        </section>
      );
    })}
  </div>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Нет вашего вопроса?</p>
      <h2>Спросить можно о чём угодно. Выдумывать ответ нельзя.</h2>
      <p>Aivel даст проверяемый ответ, задаст уточнение, покажет пробел или подключит специалиста. А на странице <a href="/vazhnoe/" style="color: inherit;">важных изменений</a> видно, как такая ситуация может быть замечена раньше.</p>
      <button class="button button-light" type="button" data-open-contact>Обсудить важную ситуацию</button>
    </div>
  </section>
</BaseLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import Icon from "../../components/Icon.astro";
import { solutions } from "../../data/site";

export async function getStaticPaths() {
  const questions = await getCollection("questions");
  return solutions.map((solution) => ({ params: { slug: solution.slug }, props: { solution, questions } }));
}

const { solution, questions } = Astro.props;
const groupQuestions = solution.questionSlugs
  .map((slug: string) => questions.find((question: (typeof questions)[number]) => question.id === slug))
  .filter((question): question is NonNullable<typeof question> => question !== undefined);
---

<BaseLayout title={`${solution.title} — вопросы и решения Aivel`} description={solution.description}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><a href="/resheniya/">Ситуации решений</a><span aria-hidden="true">/</span><span>{solution.title}</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">{solution.eyebrow}</p>
        <h1>{solution.title}</h1>
        <p class="lead">{solution.description}</p>
      </div>
      <aside class="page-hero-aside"><strong>От изменения к действию</strong><p>Aivel помогает заметить событие, а каждый следующий вопрос показывает данные, источник и границу профессионального суждения.</p></aside>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">После сигнала</p><h2>Что нужно уточнить до решения</h2></div>
        <p>Откройте вопрос, чтобы увидеть короткий ответ, паспорт данных и роль специалиста. <a href="/vazhnoe/">Примеры обнаружения</a> показывают предшествующий шаг.</p>
      </div>
      <div class="question-grid">
        {groupQuestions.map((question) => (
          <QuestionCard
            slug={question.id}
            title={question.data.title}
            description={question.data.description}
            categoryLabel={question.data.categoryLabel}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container content-layout">
      <div>
        <p class="section-kicker">Одна услуга вместо новой сборки</p>
        <h2>Вопросы работают только на подготовленной учётной основе.</h2>
      </div>
      <div class="prose">
        <p>Aivel ведёт и сверяет учёт, согласует показатели и показывает свежесть источников. Поэтому следующий вопрос не требует снова собирать таблицу с нуля.</p>
        <p><a class="text-link" href="/buhgalterskoe-soprovozhdenie/">Как устроено сопровождение <Icon name="arrow" size={20} /></a></p>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Ваш вопрос</p>
      <h2>Проверим, какие данные нужны именно вашему бизнесу.</h2>
      <p>Не отправляйте финансовые сведения через открытую форму. Начнём с ситуации и согласуем защищённый способ подключения.</p>
      <button class="button button-light" type="button" data-open-contact>Обсудить вопрос</button>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import BrandWall from "../../components/BrandWall.astro";
import {
  automationResults,
  contentReviewedAt,
  implementationMetrics,
  site
} from "../../data/site";

const assistantPages = [
  { ...automationResults[0], href: "/avtomatizatsiya-ucheta/pervichnye-dokumenty/" },
  { ...automationResults[1], href: "/avtomatizatsiya-ucheta/bankovskie-operatsii/" },
  { ...automationResults[2], href: "/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/" },
  { ...automationResults[3], href: "/avtomatizatsiya-ucheta/sverki-s-kontragentami/" }
] as const;

const outcomeSteps = [
  { label: "Увидеть", text: "что изменилось и когда это потребует решения" },
  { label: "Понять", text: "почему изменение важно именно для вашего бизнеса" },
  { label: "Действовать", text: "по следующему шагу, пока ещё есть выбор" }
] as const;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Результаты Aivel для руководителя и учётной функции",
    description: "Как Aivel помогает вовремя увидеть изменение, понять причину и принять решение — и какие результаты ИИ-помощников уже измерены в учётных процессах.",
    url: `${site.url}/rezultaty/`,
    dateModified: contentReviewedAt.iso,
    inLanguage: "ru-RU"
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "ИИ-помощники Aivel в учётных процессах",
    itemListElement: assistantPages.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      description: `${item.result} ${item.scope}`,
      url: `${site.url}${item.href}`
    }))
  }
];
---

<BaseLayout
  title="Результаты Aivel для руководителя и учётной функции"
  description="Как Aivel помогает вовремя увидеть изменение, понять причину и принять решение — и какие результаты ИИ-помощников уже измерены в учётных процессах."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Результаты</span>
  </div>

  <header class="page-hero results-page-hero">
    <div class="container results-hero-layout">
      <div class="results-hero-copy">
        <p class="section-kicker">Результат для руководителя</p>
        <h1>Увидеть изменение. Понять причину. Успеть действовать.</h1>
        <p class="lead">Aivel превращает данные учёта в короткий проверяемый сигнал: что произошло, почему это важно и какой шаг стоит сделать сейчас.</p>

        <ol class="outcome-steps" aria-label="Какой результат получает руководитель">
          {outcomeSteps.map((step, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span><p><strong>{step.label}</strong>{step.text}</p></li>
          ))}
        </ol>
      </div>

      <article class="decision-case" aria-label="Учебный пример результата для руководителя">
        <header class="case-head">
          <span class="case-mark"><Icon name="mail" size={19} /></span>
          <div><strong>Aivel</strong><span>Сигнал руководителю · сегодня, 09:40</span></div>
          <span class="example-badge">Учебный пример</span>
        </header>
        <div class="case-body">
          <span class="case-label">Требует решения</span>
          <h2>18 июля запас денег снизится ниже безопасной границы.</h2>
          <div class="case-number"><strong>620 тыс. ₽</strong><span>при границе 1 млн ₽</span></div>
          <dl class="case-details">
            <div><dt>Почему</dt><dd>В один день запланированы налоги, зарплата и оплаты поставщикам. Два поступления ещё не подтверждены.</dd></div>
            <div><dt>Что сделать</dt><dd>До 14 июля подтвердить даты поступлений. Если оплаты сдвигаются — перенести необязательную закупку.</dd></div>
            <div><dt>Основание</dt><dd>Остатки банка, календарь обязательств, расчёт зарплаты и подтверждённые поступления.</dd></div>
          </dl>
        </div>
      </article>
    </div>
  </header>

  <section class="section section-warm measured-section" aria-labelledby="measured-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div>
          <p class="section-kicker">Что уже измерено во внедрениях</p>
          <h2 id="measured-title">Надёжный учёт создаёт основу для быстрых решений.</h2>
        </div>
        <p>Результат для руководителя начинается с качественных данных. Ниже — измеренный эффект ИИ-помощников в конкретных учётных процессах.</p>
      </div>

      <div class="metric-grid" aria-label="Измеренные результаты внедрений">
        {implementationMetrics.map((metric) => (
          <article class="metric-card"><strong>{metric.value}</strong><h3>{metric.label}</h3><p>{metric.note}</p></article>
        ))}
      </div>

      <div class="assistants-heading">
        <div><p class="section-kicker">Доказательство по процессам</p><h3>Посмотрите, что именно делает каждый ИИ-помощник.</h3></div>
        <p>На отдельной странице — короткая демонстрация, путь операции и измеренный результат.</p>
      </div>
      <div class="automation-grid" role="list">
        {assistantPages.map((item) => (
          <article class="automation-card" role="listitem">
            <a class="automation-card-link" href={item.href} aria-label={`Открыть страницу ИИ-помощника «${item.title}»`}>
              <span class="automation-eyebrow">ИИ-помощник</span>
              <h3>{item.title}</h3>
              <p class="automation-result">{item.result}</p>
              <p class="automation-scope">{item.scope}</p>
              <span class="automation-cta">Посмотреть процесс <Icon name="arrow" size={20} /></span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section clients-section" aria-labelledby="clients-title">
    <div class="container">
      <div class="section-heading compact-heading">
        <div><p class="section-kicker">Опыт команды</p><h2 id="clients-title">Решения работают в реальных учётных контурах.</h2></div>
        <p>Команда Aivel внедряла решения в этих компаниях. Измеренные показатели выше относятся к отдельным проектам и не приписываются конкретному бренду.</p>
      </div>
      <BrandWall />
      <p class="reference-conclusion"><strong>Главный вывод:</strong> технология уже выполняет значимую часть учётных операций. Это даёт руководителю надёжную основу, чтобы раньше замечать важное и принимать решение по проверяемым данным.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .results-page-hero {
    overflow: hidden;
    padding-block: clamp(44px, 6vw, 76px);
  }

  .results-hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(480px, 1.12fr);
    gap: clamp(40px, 6vw, 82px);
    align-items: center;
  }

  .results-hero-copy,
  .decision-case {
    min-width: 0;
  }

  .results-page-hero h1 {
    max-width: 770px;
    font-size: clamp(3rem, 5vw, 4.7rem);
  }

  .results-page-hero .lead {
    max-width: 700px;
  }

  .outcome-steps {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 28px 0 0;
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .outcome-steps li {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 10px;
    padding: 13px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .outcome-steps > li > span {
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 780;
  }

  .outcome-steps p,
  .outcome-steps strong {
    display: block;
    margin: 0;
  }

  .outcome-steps p {
    color: var(--color-muted);
    font-size: 0.87rem;
    line-height: 1.42;
  }

  .outcome-steps strong {
    margin-bottom: 2px;
    color: var(--color-ink);
    font-size: 0.94rem;
  }

  .decision-case {
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .case-head {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr) auto;
    gap: 11px;
    align-items: center;
    padding: 13px 16px;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-border);
  }

  .case-mark {
    display: grid;
    width: 38px;
    height: 38px;
    color: white;
    background: var(--color-ink);
    border-radius: 10px;
    place-items: center;
  }

  .case-head strong,
  .case-head span {
    display: block;
  }

  .case-head > div > span {
    margin-top: 2px;
    color: var(--color-muted);
    font-size: 0.72rem;
  }

  .example-badge,
  .case-label {
    width: fit-content;
    color: var(--color-blue);
    font-size: 0.68rem;
    font-weight: 780;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  .example-badge {
    padding: 6px 9px;
    background: var(--color-blue-pale);
    border-radius: 999px;
  }

  .case-body {
    padding: clamp(22px, 3vw, 32px);
  }

  .case-label {
    margin-bottom: 9px;
    color: var(--color-red);
  }

  .case-body h2 {
    margin-bottom: 18px;
    font-size: clamp(1.55rem, 2.6vw, 2.35rem);
  }

  .case-number {
    display: flex;
    gap: 13px;
    align-items: baseline;
    padding-bottom: 17px;
    border-bottom: 1px solid var(--color-border);
  }

  .case-number strong {
    color: var(--color-red);
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1;
  }

  .case-number span {
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  .case-details {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .case-details div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .case-details div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .case-details dt {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 780;
    text-transform: uppercase;
  }

  .case-details dd {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .compact-heading {
    margin-bottom: 30px;
  }

  .metric-grid,
  .automation-grid {
    display: grid;
    gap: 14px;
  }

  .metric-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .metric-card,
  .automation-card {
    min-width: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .metric-card {
    padding: 26px;
  }

  .metric-card > strong {
    display: block;
    margin-bottom: 18px;
    color: var(--color-blue);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    letter-spacing: -0.045em;
    line-height: 0.98;
  }

  .metric-card h3 {
    margin: 0 0 10px;
    font-size: 1rem;
    line-height: 1.4;
  }

  .metric-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .assistants-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.56fr);
    gap: 32px;
    align-items: end;
    padding-top: clamp(44px, 6vw, 72px);
    margin: 0 0 22px;
  }

  .assistants-heading h3,
  .assistants-heading .section-kicker,
  .assistants-heading > p {
    margin-bottom: 0;
  }

  .assistants-heading h3 {
    margin-top: 6px;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
  }

  .assistants-heading > p {
    color: var(--color-muted);
  }

  .automation-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .automation-card {
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .automation-card:hover,
  .automation-card:focus-within {
    border-color: var(--color-ink);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .automation-card-link {
    display: flex;
    min-height: 100%;
    padding: 23px;
    color: inherit;
    text-decoration: none;
    flex-direction: column;
  }

  .automation-card-link:focus-visible {
    outline: 3px solid var(--color-gold-soft);
    outline-offset: -5px;
  }

  .automation-eyebrow {
    margin-bottom: 10px;
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .automation-card h3 {
    min-height: 2.6em;
    margin: 0 0 18px;
    font-size: 1.08rem;
  }

  .automation-result {
    margin: 0 0 12px;
    color: var(--color-ink);
    font-size: 0.92rem;
    font-weight: 720;
    line-height: 1.45;
  }

  .automation-scope {
    margin: 0 0 22px;
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .automation-cta {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    color: var(--color-blue);
    font-size: 0.84rem;
    font-weight: 720;
  }

  .reference-conclusion {
    max-width: 940px;
    padding: 20px 22px;
    margin: 26px 0 0;
    color: var(--color-ink-soft);
    background: var(--color-blue-pale);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .reference-conclusion strong {
    color: var(--color-ink);
  }

  @media (max-width: 1100px) {
    .results-hero-layout {
      grid-template-columns: 1fr;
    }

    .results-hero-copy {
      max-width: 880px;
    }

    .decision-case {
      max-width: 860px;
    }

    .automation-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .metric-grid,
    .assistants-heading {
      grid-template-columns: 1fr;
    }

    .assistants-heading {
      gap: 12px;
    }
  }

  @media (max-width: 680px) {
    .results-page-hero h1 {
      font-size: clamp(2.35rem, 11.5vw, 3.25rem);
    }

    .outcome-steps {
      display: none;
    }

    .case-head {
      grid-template-columns: 40px 1fr;
    }

    .example-badge {
      grid-column: 1 / -1;
    }

    .case-number {
      align-items: flex-start;
      flex-direction: column;
      gap: 5px;
    }

    .case-details div {
      grid-template-columns: 1fr;
      gap: 5px;
    }

    .automation-grid {
      grid-template-columns: 1fr;
    }

    .automation-card h3 {
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .automation-card {
      transition: none;
    }

    .automation-card:hover,
    .automation-card:focus-within {
      transform: none;
    }
  }
</style>

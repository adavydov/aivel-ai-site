---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import AccountingFoundationMap from "../../components/AccountingFoundationMap.astro";
import AccountingAgentShowcase from "../../components/AccountingAgentShowcase.astro";
import OneCServiceShowcase from "../../components/OneCServiceShowcase.astro";
---

<BaseLayout
  title="Наладить учёт: бухгалтерия, налоги, кадры и управленческие данные — Aivel"
  description="Aivel ведёт бухгалтерский, налоговый, кадровый и управленческий учёт, автоматизирует операции ИИ-помощниками и обслуживает 1С. Начать можно с экспресс-аудита."
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Наладить учёт с Aivel",
    serviceType: "Бухгалтерский, налоговый, кадровый и управленческий учёт",
    provider: { "@type": "Organization", name: "Aivel" },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Услуги и ИИ-помощники Aivel",
      itemListElement: [
        "Бухгалтерский и налоговый учёт",
        "Зарплата и кадры",
        "Управленческий учёт",
        "ИИ-помощники для учётных операций",
        "Обслуживание 1С",
        "Экспресс-аудит учётного контура"
      ].map((name) => ({ "@type": "Offer", itemOffered: { "@type": "Service", name } }))
    }
  }}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Наладить учёт</span>
  </div>

  <header class="page-hero accounting-hero">
    <div class="container compact-hero">
      <div class="hero-copy">
        <p class="section-kicker">Наладить учёт</p>
        <h1>Чтобы увидеть важное, сначала нужен точный учёт.</h1>
        <p class="lead">Aivel собирает данные из рабочих систем, ИИ-помощники выполняют типовые операции, а специалисты разбирают исключения. Так появляется проверенная база, на которой можно вовремя замечать изменения.</p>
        <div class="hero-actions">
          <button class="button button-primary" type="button" data-open-contact data-contact-topic="client">Записаться на разбор учёта</button>
        </div>
      </div>
      <ol class="hero-chain" aria-label="Как формируется основа">
        <li><span>01</span><strong>Собрать</strong><small>данные из источников</small></li>
        <li><span>02</span><strong>Проверить</strong><small>правила и исключения</small></li>
        <li><span>03</span><strong>Отразить</strong><small>операции в учёте</small></li>
        <li><span>04</span><strong>Увидеть</strong><small>важное изменение</small></li>
      </ol>
    </div>
  </header>

  <section class="section foundation-screen" aria-labelledby="foundation-title">
    <div class="container">
      <div class="foundation-intro">
        <div><p class="section-kicker">Одна цепочка</p><h2 id="foundation-title">От исходных данных — до сигнала руководителю.</h2></div>
        <p>Бухгалтерский и налоговый учёт, зарплата и кадры, управленческие разрезы образуют одну проверяемую основу. Только после этого данные становятся основанием для решения.</p>
      </div>
      <AccountingFoundationMap />
    </div>
  </section>

  <AccountingAgentShowcase />
  <OneCServiceShowcase />

  <section class="section audit-screen" id="ekspress-audit" aria-labelledby="audit-title">
    <div class="container">
      <div class="audit-panel">
        <div class="audit-copy">
          <p class="section-kicker section-kicker-light">Первый шаг</p>
          <h2 id="audit-title">Экспресс-аудит покажет, с какого участка начать.</h2>
          <p>Проверим базу 1С, закрытие периодов, остатки, обязательства, аналитику и обмены. Затем предложим последовательный путь без перестройки всего учёта сразу.</p>
          <button class="button button-light" type="button" data-open-contact data-contact-topic="client">Запросить экспресс-аудит <Icon name="arrow" size={19} /></button>
        </div>
        <ol class="audit-results" aria-label="Что вы получите после экспресс-аудита">
          <li><span>01</span><div><strong>Карта рисков и пробелов</strong><p>Что мешает доверять данным и где проблема влияет на решения.</p></div></li>
          <li><span>02</span><div><strong>Объём восстановления</strong><p>Что исправить в базе, правилах, справочниках и обменах.</p></div></li>
          <li><span>03</span><div><strong>Первый ИИ-помощник</strong><p>Какой участок даст быстрый и измеримый эффект без лишнего риска.</p></div></li>
        </ol>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .accounting-hero {
    padding-block: clamp(50px, 6vw, 82px);
    background: linear-gradient(135deg, #f9f7f1 0%, #eef3f8 100%);
  }

  .compact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(430px, 0.8fr);
    gap: clamp(40px, 7vw, 96px);
    align-items: end;
  }

  .accounting-hero h1 {
    max-width: 900px;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
  }

  .hero-actions {
    margin-top: 28px;
  }

  .hero-chain {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 0;
    overflow: hidden;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    list-style: none;
  }

  .hero-chain li {
    display: grid;
    min-height: 118px;
    align-content: end;
    padding: 18px;
    background: white;
  }

  .hero-chain span {
    align-self: start;
    margin-bottom: 20px;
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 750;
  }

  .hero-chain strong,
  .hero-chain small {
    display: block;
  }

  .hero-chain small {
    margin-top: 3px;
    color: var(--color-muted);
  }

  .foundation-screen {
    padding-block: clamp(56px, 7vw, 88px);
  }

  .foundation-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.55fr);
    gap: 48px;
    align-items: end;
    margin-bottom: 32px;
  }

  .foundation-intro h2,
  .foundation-intro > p {
    margin-bottom: 0;
  }

  .foundation-intro > p {
    max-width: 520px;
  }

  .audit-screen {
    padding-block: clamp(58px, 7vw, 92px);
    scroll-margin-top: var(--header-height);
    background: var(--color-paper);
  }

  .audit-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(390px, 0.95fr);
    gap: clamp(38px, 7vw, 86px);
    align-items: center;
    padding: clamp(30px, 5vw, 64px);
    color: white;
    background: var(--color-ink);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .audit-copy h2,
  .audit-copy p {
    color: white;
  }

  .audit-copy h2 {
    margin-bottom: 16px;
  }

  .audit-copy > p:not(.section-kicker) {
    max-width: 720px;
    color: #c8d2df;
  }

  .audit-copy .button {
    margin-top: 12px;
  }

  .audit-results {
    display: grid;
    gap: 1px;
    padding: 1px;
    margin: 0;
    overflow: hidden;
    background: rgb(255 255 255 / 0.17);
    border: 1px solid rgb(255 255 255 / 0.17);
    border-radius: var(--radius-lg);
    list-style: none;
  }

  .audit-results li {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    gap: 12px;
    padding: 17px 18px;
    background: #18243a;
  }

  .audit-results li > span {
    padding-top: 2px;
    color: var(--color-gold-soft);
    font-size: 0.72rem;
    font-weight: 780;
    letter-spacing: 0.08em;
  }

  .audit-results strong {
    display: block;
    color: white;
    font-size: 0.9rem;
  }

  .audit-results p {
    margin: 4px 0 0;
    color: #b9c5d4;
    font-size: 0.76rem;
    line-height: 1.45;
  }

  @media (max-width: 920px) {
    .compact-hero,
    .foundation-intro,
    .audit-panel {
      grid-template-columns: 1fr;
    }

    .compact-hero {
      align-items: start;
    }
  }

  @media (max-width: 620px) {
    .hero-chain {
      grid-template-columns: 1fr;
    }

    .hero-chain li {
      min-height: 0;
      grid-template-columns: 34px 1fr;
      gap: 0 10px;
      padding: 14px;
    }

    .hero-chain span {
      grid-row: 1 / span 2;
      margin: 4px 0 0;
    }

    .hero-chain strong,
    .hero-chain small {
      grid-column: 2;
    }

    .audit-panel {
      padding: 24px 18px;
      border-radius: var(--radius-lg);
    }

    .audit-copy .button {
      width: 100%;
    }
  }
</style>

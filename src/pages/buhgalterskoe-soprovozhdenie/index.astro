---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import LocalForm from "../../components/LocalForm.astro";

const services = [
  { icon: "document", title: "Бухгалтерский учёт", text: "Первичные документы, операции, закрытие периода, обязательная отчётность и ответы на требования." },
  { icon: "shield", title: "Налоговый учёт", text: "Расчёты, декларации, календарь обязательств и контроль налоговых рисков вместе с ответственным специалистом." },
  { icon: "person", title: "Зарплата и кадры", text: "Начисления, выплаты, кадровые документы, приём, переводы, увольнения и обязательная отчётность." },
  { icon: "chart", title: "Управленческий учёт", text: "Показатели, справочники и разрезы, которые помогают видеть деньги, прибыльность и состояние направлений." },
  { icon: "spark", title: "1С и обмен данными", text: "Поддержка действующей базы, настройка, развитие, внешние обработки и связи с согласованными источниками." },
  { icon: "check", title: "Экспресс-аудит", text: "Быстрая проверка состояния учёта, расхождений, незакрытых периодов и готовности данных к решениям." }
] as const;

const foundationSteps = [
  { number: "01", title: "Операции отражены", text: "Документы, банк, зарплата и обязательства попадают в учёт полностью и вовремя." },
  { number: "02", title: "Основа проверена", text: "Периоды закрыты, остатки сходятся, ошибки и неоднозначные случаи переданы специалисту." },
  { number: "03", title: "Появилась картина", text: "Данные можно разложить по деньгам, направлениям, клиентам, проектам и центрам ответственности." },
  { number: "04", title: "Важное видно раньше", text: "Только после этого Aivel надёжно замечает отклонения и отвечает на вопросы руководителя." }
] as const;
---

<BaseLayout
  title="Учёт как база: бухгалтерия, налоги, кадры и 1С — Aivel"
  description="Aivel ведёт бухгалтерский, налоговый и кадровый учёт, рассчитывает зарплату, ставит управленческий учёт, поддерживает 1С и проводит экспресс-аудит."
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Учёт как база Aivel",
    serviceType: "Бухгалтерский, налоговый, кадровый и управленческий учёт",
    provider: { "@type": "Organization", name: "Aivel" }
  }}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Учёт как база</span>
  </div>

  <header class="page-hero accounting-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">Учёт как база</p>
        <h1>Бухгалтерия, на которой держатся решения.</h1>
        <p class="lead">Важное можно заметить вовремя только тогда, когда документы, обязательства, зарплата и управленческие разрезы отражены корректно. Aivel берёт эту основу на себя — от обязательного учёта до 1С.</p>
        <div class="hero-actions">
          <button class="button button-primary" type="button" data-open-contact data-contact-topic="client">Разобрать состояние учёта</button>
          <a class="button button-secondary" href="#services">Что берём на себя</a>
        </div>
      </div>
      <aside class="page-hero-aside foundation-aside">
        <strong>Одна основа</strong>
        <p>Бухгалтерский и налоговый учёт, зарплата, кадры, управленческие данные и 1С не живут отдельно друг от друга.</p>
        <div><span>Сначала</span><b>корректный учёт</b></div>
        <div><span>Затем</span><b>важные сигналы и ответы</b></div>
      </aside>
    </div>
  </header>

  <section class="section" id="services" aria-labelledby="services-title">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Что берём на себя</p><h2 id="services-title">От обязательного учёта до данных для управления.</h2></div>
        <p>Можно передать весь контур или начать с проверки и одного участка. Состав работ фиксируется после разбора текущей базы и процессов.</p>
      </div>
      <div class="accounting-services">
        {services.map((service) => (
          <article>
            <span class="service-icon"><Icon name={service.icon} size={23} /></span>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="foundation-title">
    <div class="container">
      <div class="section-heading foundation-heading">
        <div><p class="section-kicker section-kicker-light">Как связаны учёт и важное</p><h2 id="foundation-title">Сигналу нужен твёрдый фундамент.</h2></div>
        <p>ИИ не исправляет плохую основу уверенным текстом. Сначала данные приводятся в состояние, которому можно доверять.</p>
      </div>
      <div class="foundation-flow">
        {foundationSteps.map((step) => (
          <article><span>{step.number}</span><h3>{step.title}</h3><p>{step.text}</p></article>
        ))}
      </div>
      <p class="foundation-link"><a class="text-link text-link-light" href="/vazhnoe/">Что Aivel замечает на этой основе <Icon name="arrow" size={18} /></a></p>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="audit-title">
    <div class="container audit-layout">
      <div>
        <p class="section-kicker">Экспресс-аудит</p>
        <h2 id="audit-title">Не обещаем порядок, пока не увидели исходную точку.</h2>
        <p>Проверяем базу 1С, закрытие периодов, остатки, обязательства, аналитику, кадровый контур и обмены. После проверки понятны риски, объём восстановления и порядок перехода.</p>
        <button class="button button-primary" type="button" data-open-contact data-contact-topic="client">Запросить экспресс-аудит</button>
      </div>
      <div class="audit-result">
        <p class="card-label">На выходе</p>
        <ul>
          <li><Icon name="check" size={18} /><span>карта проблем и расхождений;</span></li>
          <li><Icon name="check" size={18} /><span>оценка готовности бухгалтерского и управленческого учёта;</span></li>
          <li><Icon name="check" size={18} /><span>план исправления с очерёдностью;</span></li>
          <li><Icon name="check" size={18} /><span>понятный состав регулярной работы и поддержки 1С.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="one-c-title">
    <div class="container one-c-layout">
      <div class="one-c-mark" aria-hidden="true">1С</div>
      <div>
        <p class="section-kicker">1С не остаётся за скобками</p>
        <h2 id="one-c-title">Поддерживаем систему, в которой работает учёт.</h2>
        <p>Проверяем текущую конфигурацию, права, аналитику и доработки. Если база подходит, сохраняем её и развиваем без ненужной замены. Внешние обработки позволяют отделять автоматизацию от типовой конфигурации и её обновлений.</p>
        <div class="one-c-points">
          <span>Настройка и поддержка</span><span>Доработки и обмены</span><span>Права и аналитика</span><span>Связь с банками и источниками</span>
        </div>
        <a class="text-link" href="/1s-i-integratsii/">Подробнее о 1С и подключениях <Icon name="arrow" size={18} /></a>
      </div>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="model-title">
    <div class="container content-layout service-model">
      <div><p class="section-kicker section-kicker-light">Состав и стоимость</p><h2 id="model-title">Вы платите за реальный контур работы.</h2></div>
      <div class="prose">
        <p>На стоимость влияют число юридических лиц, режимы налогообложения, объём операций, сотрудники, состояние учёта, конфигурация 1С и нужные управленческие разрезы.</p>
        <p>После разбора мы фиксируем, что входит в регулярную работу, что требует восстановления и какие задачи можно автоматизировать.</p>
      </div>
    </div>
  </section>

  <section class="section section-warm">
    <div class="container"><LocalForm mode="client" title="Разберём текущий учёт и предложим понятный следующий шаг" /></div>
  </section>
</BaseLayout>

<style>
  .accounting-hero {
    background: linear-gradient(135deg, #f9f7f1 0%, #eef3f8 100%);
  }

  .foundation-aside {
    display: grid;
    gap: 12px;
  }

  .foundation-aside > div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
  }

  .foundation-aside span {
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  .foundation-aside b {
    text-align: right;
    font-size: 0.86rem;
  }

  .accounting-services {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .accounting-services article {
    min-height: 250px;
    padding: 26px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .service-icon {
    display: grid;
    width: 44px;
    height: 44px;
    margin-bottom: 34px;
    color: var(--color-blue);
    background: #edf4fa;
    border-radius: 12px;
    place-items: center;
  }

  .accounting-services p {
    margin: 0;
  }

  .foundation-heading h2,
  .foundation-heading > p {
    color: white;
  }

  .foundation-heading > p {
    color: #c3cfde;
  }

  .foundation-flow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    background: rgb(255 255 255 / 0.12);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-lg);
  }

  .foundation-flow article {
    min-height: 250px;
    padding: 26px;
    background: #111d33;
  }

  .foundation-flow span {
    display: block;
    margin-bottom: 44px;
    color: var(--color-gold-soft);
    font-size: 0.76rem;
  }

  .foundation-flow h3 {
    color: white;
  }

  .foundation-flow p {
    margin: 0;
    color: #aebdd0;
  }

  .foundation-link {
    margin: 24px 0 0;
  }

  .audit-layout,
  .one-c-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
    gap: clamp(44px, 8vw, 100px);
    align-items: center;
  }

  .audit-result {
    padding: clamp(28px, 5vw, 46px);
    background: white;
    border: 1px solid #eadfcb;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .audit-result ul {
    display: grid;
    gap: 18px;
    padding: 0;
    margin: 24px 0 0;
    list-style: none;
  }

  .audit-result li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
  }

  .audit-result svg {
    color: var(--color-green);
  }

  .one-c-layout {
    grid-template-columns: minmax(260px, 0.56fr) minmax(0, 1.44fr);
  }

  .one-c-mark {
    display: grid;
    min-height: 330px;
    color: #161616;
    background: #ffd83d;
    border-radius: var(--radius-xl);
    font-size: clamp(5rem, 12vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.08em;
    place-items: center;
  }

  .one-c-points {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 24px 0;
  }

  .one-c-points span {
    padding: 9px 12px;
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 650;
  }

  .service-model h2,
  .service-model p {
    color: white;
  }

  .service-model p {
    color: #c3cfde;
  }

  @media (max-width: 920px) {
    .accounting-services {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .foundation-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .audit-layout,
    .one-c-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .accounting-services,
    .foundation-flow {
      grid-template-columns: 1fr;
    }

    .accounting-services article,
    .foundation-flow article {
      min-height: 0;
    }

    .foundation-flow span {
      margin-bottom: 20px;
    }

    .one-c-mark {
      min-height: 220px;
    }
  }
</style>

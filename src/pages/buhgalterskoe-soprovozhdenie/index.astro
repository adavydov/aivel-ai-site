---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import AccountingFoundationMap from "../../components/AccountingFoundationMap.astro";

const services = [
  { icon: "document", title: "Бухгалтерский учёт", text: "Первичные документы, операции, закрытие периода, обязательная отчётность и ответы на требования." },
  { icon: "shield", title: "Налоговый учёт", text: "Расчёты, декларации, календарь обязательств и контроль налоговых рисков вместе с ответственным специалистом." },
  { icon: "person", title: "Зарплата и кадры", text: "Начисления, выплаты, кадровые документы, приём, переводы, увольнения и обязательная отчётность." },
  { icon: "chart", title: "Управленческий учёт", text: "Показатели, справочники и разрезы, которые помогают видеть деньги, прибыльность и состояние направлений." }
] as const;

---

<BaseLayout
  title="Учёт как база: бухгалтерия, налоги, кадры и управленческие данные — Aivel"
  description="Как Aivel собирает данные, выполняет типовые учётные операции, передаёт исключения специалистам и создаёт проверенную основу для важных сигналов."
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Учёт как база Aivel",
    serviceType: "Бухгалтерский, налоговый, кадровый и управленческий учёт",
    provider: { "@type": "Organization", name: "Aivel" }
  }}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Учёт как база</span>
  </div>

  <header class="page-hero accounting-hero">
    <div class="container compact-hero">
      <div class="hero-copy">
        <p class="section-kicker">Учёт как база</p>
        <h1>Чтобы увидеть важное, сначала нужен точный учёт.</h1>
        <p class="lead">Aivel собирает данные из рабочих систем, ИИ-помощники выполняют типовые операции, а специалисты разбирают исключения. Так появляется проверенная база, на которой можно вовремя замечать изменения.</p>
        <div class="hero-actions">
          <button class="button button-primary" type="button" data-open-contact data-contact-topic="client">Записаться на разбор учёта</button>
        </div>
      </div>
      <ol class="hero-chain" aria-label="Как формируется основа">
        <li><span>01</span><strong>Собрать</strong><small>данные из источников</small></li>
        <li><span>02</span><strong>Проверить</strong><small>правила и исключения</small></li>
        <li><span>03</span><strong>Отразить</strong><small>операции в учёте</small></li>
        <li><span>04</span><strong>Увидеть</strong><small>важное изменение</small></li>
      </ol>
    </div>
  </header>

  <section class="section foundation-screen" aria-labelledby="foundation-title">
    <div class="container">
      <div class="foundation-intro">
        <div><p class="section-kicker">Одна цепочка</p><h2 id="foundation-title">От исходных данных — до сигнала руководителю.</h2></div>
        <p>Не отдельная программа поверх беспорядка, а связанный процесс: источник, операция, проверка, учётная база и только затем — важное изменение.</p>
      </div>
      <AccountingFoundationMap />
    </div>
  </section>

  <section class="section section-warm coverage-screen" aria-labelledby="services-title">
    <div class="container coverage-layout">
      <div class="coverage-main">
        <p class="section-kicker">Что входит в основу</p>
        <h2 id="services-title">Весь учёт — в одном проверяемом контуре.</h2>
        <p class="coverage-lead">Можно передать Aivel весь контур или начать с участка, который сильнее всего мешает видеть реальную картину.</p>
        <div class="accounting-services">
          {services.map((service) => (
            <article>
              <span class="service-icon"><Icon name={service.icon} size={23} /></span>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="entry-cards">
        <article class="entry-card audit-card">
          <span class="entry-icon"><Icon name="check" size={22} /></span>
          <div>
            <p class="card-label">Первый шаг к внедрению</p>
            <h3>Экспресс-аудит</h3>
            <p>Проверяем базу 1С, закрытие периодов, остатки, обязательства, аналитику и обмены.</p>
            <strong>На выходе: риски, объём восстановления и первый участок внедрения.</strong>
          </div>
        </article>
        <article class="entry-card one-c-card">
          <span class="one-c-badge" aria-hidden="true">1С</span>
          <div>
            <p class="card-label">Поддерживающая система</p>
            <h3>1С на обслуживании</h3>
            <p>Поддерживаем действующую базу, обновления, права, доработки и обмены.</p>
            <strong>1С — не вид учёта, а система, в которой он ведётся.</strong>
          </div>
        </article>
        <p class="scope-note">Состав работ фиксируем после разбора: что входит в регулярное сопровождение, что требует восстановления и какой участок можно автоматизировать первым.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .accounting-hero {
    padding-block: clamp(50px, 6vw, 82px);
    background: linear-gradient(135deg, #f9f7f1 0%, #eef3f8 100%);
  }

  .compact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(430px, 0.8fr);
    gap: clamp(40px, 7vw, 96px);
    align-items: end;
  }

  .accounting-hero h1 {
    max-width: 900px;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
  }

  .hero-actions {
    margin-top: 28px;
  }

  .hero-chain {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    padding: 1px;
    margin: 0;
    overflow: hidden;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    list-style: none;
  }

  .hero-chain li {
    display: grid;
    min-height: 118px;
    align-content: end;
    padding: 18px;
    background: white;
  }

  .hero-chain span {
    align-self: start;
    margin-bottom: 20px;
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 750;
  }

  .hero-chain strong,
  .hero-chain small {
    display: block;
  }

  .hero-chain small {
    margin-top: 3px;
    color: var(--color-muted);
  }

  .foundation-screen {
    padding-block: clamp(56px, 7vw, 88px);
  }

  .foundation-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.55fr);
    gap: 48px;
    align-items: end;
    margin-bottom: 32px;
  }

  .foundation-intro h2,
  .foundation-intro > p {
    margin-bottom: 0;
  }

  .foundation-intro > p {
    max-width: 520px;
  }

  .coverage-screen {
    padding-block: clamp(56px, 7vw, 88px);
  }

  .coverage-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(340px, 0.65fr);
    gap: clamp(36px, 6vw, 76px);
    align-items: start;
  }

  .coverage-main h2 {
    margin-bottom: 14px;
  }

  .coverage-lead {
    max-width: 720px;
    margin-bottom: 24px;
  }

  .accounting-services {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .accounting-services article {
    display: grid;
    min-height: 150px;
    grid-template-columns: 42px 1fr;
    gap: 0 12px;
    align-content: start;
    padding: 18px;
    background: white;
    border: 1px solid #eadfcb;
    border-radius: var(--radius-md);
  }

  .service-icon {
    display: grid;
    width: 42px;
    height: 42px;
    grid-row: 1 / span 2;
    color: var(--color-blue);
    background: #edf4fa;
    border-radius: 11px;
    place-items: center;
  }

  .accounting-services h3 {
    margin: 2px 0 7px;
    font-size: 1rem;
  }

  .accounting-services p {
    grid-column: 2;
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .entry-cards {
    display: grid;
    gap: 12px;
  }

  .entry-card {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr);
    gap: 14px;
    padding: 20px;
    background: white;
    border: 1px solid #eadfcb;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .entry-icon,
  .one-c-badge {
    display: grid;
    width: 52px;
    height: 52px;
    border-radius: 13px;
    place-items: center;
  }

  .entry-icon {
    color: var(--color-green);
    background: var(--color-green-pale);
  }

  .one-c-badge {
    color: #161616;
    background: #ffd83d;
    font-size: 1.3rem;
    font-weight: 800;
  }

  .entry-card h3 {
    margin: 3px 0 7px;
  }

  .entry-card p {
    margin: 0;
    font-size: 0.86rem;
  }

  .entry-card strong {
    display: block;
    margin-top: 10px;
    color: var(--color-ink-soft);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .scope-note {
    padding: 4px 4px 0;
    margin: 0;
    color: var(--color-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  @media (max-width: 920px) {
    .compact-hero,
    .foundation-intro,
    .coverage-layout {
      grid-template-columns: 1fr;
    }

    .compact-hero {
      align-items: start;
    }
  }

  @media (max-width: 620px) {
    .hero-chain,
    .accounting-services {
      grid-template-columns: 1fr;
    }

    .hero-chain li {
      min-height: 0;
      grid-template-columns: 34px 1fr;
      gap: 0 10px;
      padding: 14px;
    }

    .hero-chain span {
      grid-row: 1 / span 2;
      margin: 4px 0 0;
    }

    .hero-chain strong,
    .hero-chain small {
      grid-column: 2;
    }

    .accounting-services article {
      min-height: 0;
    }

    .entry-card {
      grid-template-columns: 44px minmax(0, 1fr);
      padding: 16px;
    }

    .entry-icon,
    .one-c-badge {
      width: 44px;
      height: 44px;
    }
  }
</style>

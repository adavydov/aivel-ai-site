---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalForm from "../../components/LocalForm.astro";
import Icon from "../../components/Icon.astro";

const scaleFacts = [
  { value: "400+ млн ₽", label: "выручка сети в пересчёте на год" },
  { value: "1 000+", label: "клиентов в партнёрской сети" },
  { value: "3 страны", label: "география клиентов сети" }
];

const expertiseTracks = [
  {
    number: "01",
    title: "География",
    current: "Действующее ядро: Москва и Санкт-Петербург",
    sought: "Ищем сильные команды в новых регионах"
  },
  {
    number: "02",
    title: "Отрасли",
    current: "Уже представлены: медицина, строительство, B2B-услуги, продавцы на торговых площадках",
    sought: "Открыты другие отрасли с глубокой предметной экспертизой"
  },
  {
    number: "03",
    title: "Функции",
    current: "Бухгалтерский и налоговый учёт, зарплата и кадры, управленческий учёт",
    sought: "Расширяем специализации и технологические решения"
  }
];

const technologyFlows = [
  {
    icon: "document" as const,
    title: "Первичные документы",
    flow: ["Получить документ", "Проверить и распознать", "Создать документ в 1С"],
    value: "80%",
    metric: "измеренного потока прошло без ручного участия"
  },
  {
    icon: "chart" as const,
    title: "Банковские операции",
    flow: ["Получить выписку", "Сопоставить платёж", "Заполнить операцию и аналитику в 1С"],
    value: "98%",
    metric: "точности сопоставления на проверенной выборке"
  },
  {
    icon: "check" as const,
    title: "Сверки с контрагентами",
    flow: ["Собрать данные сторон", "Провести сверку", "Передать специалисту только расхождения"],
    value: "до 95%",
    metric: "типовых сверок прошло без участия человека"
  }
];

const nextContours = ["Зарплата и кадры", "Операции торговых площадок", "Внутренний аудит"];

const ownerValue = [
  "обсуждать с клиентом денежный поток и риски до того, как они станут проблемой",
  "объяснять причины изменений по данным, а не собирать отчёт вручную",
  "развивать отраслевую практику и отношения с ключевыми клиентами"
];

const decisionQuestions = [
  "Какой вы хотите видеть свою роль в компании через два–три года?",
  "Какие повторяющиеся процессы сегодня требуют вашего личного контроля?",
  "В чём ваша сильнейшая экспертиза: регион, отрасль или функция?",
  "Какие процессы и данные уже готовы к подключению ИИ-помощников?",
  "Что важнее на следующем этапе: рост, снижение зависимости от владельца или преемственность?"
];

const objections = [
  {
    question: "Что произойдёт с клиентами и командой?",
    answer: "Сначала фиксируются клиенты, команда, договоры, доступы, риски и исходные показатели. Изменения внедряются поэтапно, чтобы не нарушить обслуживание."
  },
  {
    question: "Собственник должен выйти из бизнеса?",
    answer: "Нет. Основной сценарий — собственник продолжает развивать компанию, но меньше занят повторяющимися операциями и больше работает с клиентами, стратегией и финансовыми решениями."
  },
  {
    question: "ИИ заменит бухгалтеров?",
    answer: "ИИ-помощники выполняют типовые действия и передают исключения специалистам. Профессиональное суждение, ответственность и работа со сложными ситуациями остаются у людей."
  },
  {
    question: "Можно сначала посмотреть технологию?",
    answer: "Да. На демонстрации можно увидеть работающих ИИ-помощников, разобрать два–три процесса вашей компании и предварительно оценить применимость технологии без обязательства обсуждать партнёрство."
  },
  {
    question: "Как защищаются данные компании и клиентов?",
    answer: "Источники, доступы, права и порядок обработки данных согласуются до подключения. Действия помощников ограничены ролями и сохраняются в аудиторском следе.",
    href: "/zashchita-dannyh/",
    linkLabel: "Посмотреть принципы защиты данных"
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Партнёрство Aivel для бухгалтерских компаний",
    description: "Технологическое и операционное партнёрство для роста бухгалтерской компании без пропорционального увеличения ручной работы.",
    provider: { "@type": "Organization", name: "Aivel" },
    audience: { "@type": "BusinessAudience", audienceType: "Собственники бухгалтерских компаний" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: objections.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer }
    }))
  }
];
---

<BaseLayout
  title="Aivel для бухгалтерских компаний — технология для новой роли собственника"
  description="Партнёрская сеть Aivel, работающие ИИ-помощники и новая роль собственника бухгалтерской компании: меньше операционной рутины, больше ценности для клиента."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Партнёрам</span>
  </div>

  <header class="page-hero partner-hero">
    <div class="container partner-hero-grid">
      <div class="hero-copy">
        <p class="section-kicker">Собственникам бухгалтерских компаний</p>
        <h1>Расти без новой рутины. <span>Стать финансовым партнёром клиентов.</span></h1>
        <p class="lead">Aivel объединяет сильные бухгалтерские компании и даёт им работающих ИИ-помощников. Команда разбирает исключения, а собственник больше работает с деньгами, рисками и решениями клиентов.</p>
        <div class="hero-actions" aria-label="Следующие шаги">
          <a class="button button-primary" href="#partner-form">Оценить партнёрство</a>
          <a class="button button-secondary" href="#technology">Посмотреть технологию</a>
        </div>
      </div>

      <aside class="opportunity-map" aria-labelledby="opportunity-title">
        <div class="map-heading">
          <p class="section-kicker">Карта возможностей</p>
          <h2 id="opportunity-title">Сеть уже работает. Карта ещё открыта.</h2>
        </div>

        <div class="scale-facts" aria-label="Масштаб партнёрской сети">
          {scaleFacts.map((fact) => (
            <div><strong>{fact.value}</strong><span>{fact.label}</span></div>
          ))}
        </div>

        <div class="expertise-list">
          {expertiseTracks.map((track) => (
            <article>
              <span class="track-number">{track.number}</span>
              <div>
                <h3>{track.title}</h3>
                <p>{track.current}</p>
                <strong>{track.sought}</strong>
              </div>
            </article>
          ))}
        </div>
        <p class="partnership-principle"><strong>Партнёрство с контрольной долей от 51%.</strong> Роль собственника и темп интеграции обсуждаем индивидуально.</p>
      </aside>
    </div>
  </header>

    <section class="section technology-owner" id="technology" aria-labelledby="technology-title">
      <div class="container">
        <div class="section-heading compact-heading">
          <div>
            <p class="section-kicker">От источника до результата</p>
            <h2 id="technology-title">Не распознавание отдельного документа, а завершённая операция в 1С.</h2>
          </div>
          <p>ИИ-помощник проходит весь типовой процесс. Если ситуация выходит за правила, он передаёт её специалисту вместе с данными и историей действий.</p>
        </div>

        <div class="technology-grid">
          {technologyFlows.map((item) => (
            <article class="technology-card" data-reveal>
              <div class="technology-card-head">
                <span class="technology-icon"><Icon name={item.icon} size={24} /></span>
                <h3>{item.title}</h3>
              </div>
              <ol class="operation-flow">
                {item.flow.map((step, index) => (
                  <li>
                    <span>{String(index + 1).padStart(2, "0")}</span>
                    <strong>{step}</strong>
                  </li>
                ))}
              </ol>
              <div class="technology-metric"><strong>{item.value}</strong><span>{item.metric}</span></div>
            </article>
          ))}
        </div>

        <div class="control-layer" aria-label="Контроль качества операций">
          <div><Icon name="spark" size={24} /><span><strong>ИИ выполняет типовой процесс</strong> от получения данных до результата</span></div>
          <Icon class="control-arrow" name="arrow" size={22} />
          <div><Icon name="person" size={24} /><span><strong>Человек разбирает исключения</strong> и принимает профессиональные решения</span></div>
          <Icon class="control-arrow" name="arrow" size={22} />
          <div><Icon name="source" size={24} /><span><strong>Аудиторский след сохраняет</strong> источник, действие, результат и проверку</span></div>
        </div>

        <div class="next-contours">
          <div><p class="section-kicker">Следующие контуры</p><h3>Подключаем новые процессы по той же схеме.</h3></div>
          <ul>{nextContours.map((item) => <li>{item}</li>)}</ul>
        </div>
      </div>

      <div class="owner-shift owner-shift-panel" aria-labelledby="owner-shift-title">
        <div class="container owner-shift-grid">
          <div>
            <p class="section-kicker section-kicker-light">Что получает собственник</p>
            <h2 id="owner-shift-title">ИИ освобождает время. Собственник превращает его в ценность для клиента.</h2>
            <p>Учёт остаётся надёжной основой. Владелец меньше контролирует повторяющееся исполнение и чаще помогает клиенту принимать финансовые решения.</p>
          </div>
          <div class="value-path">
            <div class="value-source"><span>Было</span><strong>операции, переписка, повторная проверка</strong></div>
            <Icon name="arrow" size={26} />
            <div class="value-result">
              <span>Освободившееся время</span>
              <ul>{ownerValue.map((item) => <li><Icon name="check" size={18} />{item}</li>)}</ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section decision-section" aria-labelledby="decision-title">
      <div class="container">
        <div class="section-heading compact-heading">
          <div>
            <h2 id="decision-title">Пять вопросов, которые действительно важно прояснить.</h2>
          </div>
          <p>Они показывают, совпадают ли ваши цели, сильные стороны компании и возможности партнёрской сети.</p>
        </div>
        <ol class="decision-list">
          {decisionQuestions.map((question, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span><strong>{question}</strong></li>
          ))}
        </ol>

        <div class="partner-faq-panel">
          <div class="faq-layout" aria-labelledby="faq-title">
            <div class="faq-intro">
              <p class="section-kicker">Прямые ответы</p>
              <h2 id="faq-title">Частые вопросы.</h2>
              <p>Коротко о клиентах, команде, роли собственника, технологии и данных.</p>
            </div>
            <div class="faq-list">
              {objections.map((item, index) => (
                <details open={index === 0}>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                  {"href" in item && item.href && <a class="text-link" href={item.href}>{item.linkLabel} <Icon name="arrow" size={17} /></a>}
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section final-step" id="partner-form" aria-labelledby="next-step-title">
      <div class="container final-step-grid">
        <div class="final-step-copy">
          <p class="section-kicker">Следующий шаг</p>
          <h2 id="next-step-title">Расскажите о компании — мы оценим точку совпадения.</h2>
          <p>Достаточно указать масштаб, сильную экспертизу и вашу цель. На первом шаге закрытые данные не нужны.</p>
        </div>
        <div class="partner-form-shell">
          <LocalForm mode="partner" title="Короткая анкета о компании" submitLabel="Обсудить партнёрство конфиденциально" />
        </div>
      </div>
    </section>
</BaseLayout>

<style>
  .partner-hero {
    padding-block: clamp(22px, 3vw, 42px) clamp(48px, 6vw, 76px);
  }

  .partner-hero-grid {
    display: grid;
    grid-template-columns: minmax(470px, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(40px, 6vw, 82px);
    align-items: center;
  }

  .partner-hero h1 {
    max-width: 780px;
    font-size: clamp(2.7rem, 4vw, 4.35rem);
  }

  .partner-hero h1 span {
    color: var(--color-gold);
  }

  .partner-hero .lead {
    max-width: 720px;
  }

  .hero-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    max-width: 650px;
    margin-top: 24px;
  }

  .hero-actions .button {
    width: 100%;
    min-height: 54px;
    justify-content: center;
    padding-inline: 20px;
    text-align: center;
  }

  .opportunity-map {
    padding: clamp(24px, 3vw, 36px);
    background: var(--color-ink);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .map-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 1fr);
    gap: 22px;
    align-items: end;
    padding-bottom: 22px;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
  }

  .map-heading .section-kicker {
    margin: 0;
    color: var(--color-gold-soft);
  }

  .map-heading h2 {
    margin: 0;
    color: white;
    font-size: clamp(1.55rem, 2.5vw, 2.35rem);
  }

  .scale-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin-block: 22px;
    overflow: hidden;
    background: rgb(255 255 255 / 0.12);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-md);
  }

  .scale-facts div {
    min-width: 0;
    padding: 18px;
    background: rgb(255 255 255 / 0.04);
  }

  .scale-facts strong,
  .scale-facts span {
    display: block;
  }

  .scale-facts strong {
    margin-bottom: 10px;
    color: var(--color-gold-soft);
    font-size: clamp(1.25rem, 2vw, 1.8rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .scale-facts span {
    color: #b9c6d6;
    font-size: 0.73rem;
    line-height: 1.35;
  }

  .expertise-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .expertise-list article {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: 12px;
    padding: 12px;
    background: rgb(255 255 255 / 0.045);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-sm);
  }

  .track-number {
    color: var(--color-gold-soft);
    font-size: 0.7rem;
    font-weight: 750;
  }

  .expertise-list h3 {
    margin-bottom: 5px;
    color: white;
    font-size: 1rem;
  }

  .expertise-list p,
  .expertise-list strong {
    display: block;
    margin: 0;
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .expertise-list p {
    color: #aebdd0;
  }

  .expertise-list strong {
    margin-top: 4px;
    color: var(--color-gold-soft);
  }

  .partnership-principle {
    padding-top: 15px;
    margin: 16px 0 0;
    color: #aebdd0;
    border-top: 1px solid rgb(255 255 255 / 0.12);
    font-size: 0.74rem;
    line-height: 1.45;
  }

  .partnership-principle strong {
    color: white;
  }

  .compact-heading {
    margin-bottom: 30px;
  }

  .technology-owner {
    padding-top: clamp(64px, 7vw, 92px);
    padding-bottom: 0;
  }

  .technology-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .technology-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    padding: 26px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .technology-card-head {
    display: flex;
    min-height: 48px;
    align-items: center;
    gap: 12px;
  }

  .technology-card-head h3 {
    margin: 0;
    font-size: 1.18rem;
  }

  .technology-icon {
    display: grid;
    width: 46px;
    height: 46px;
    flex: 0 0 46px;
    place-items: center;
    color: var(--color-gold);
    background: var(--color-gold-pale);
    border-radius: 12px;
  }

  .operation-flow {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 24px 0;
    list-style: none;
  }

  .operation-flow li {
    position: relative;
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 10px;
    padding-bottom: 18px;
  }

  .operation-flow li:not(:last-child)::after {
    position: absolute;
    top: 22px;
    bottom: 3px;
    left: 11px;
    width: 1px;
    background: var(--color-border-strong);
    content: "";
  }

  .operation-flow li:last-child {
    padding-bottom: 0;
  }

  .operation-flow span {
    color: var(--color-gold);
    font-size: 0.66rem;
    font-weight: 750;
  }

  .operation-flow strong {
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .technology-metric {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: center;
    padding-top: 18px;
    margin-top: auto;
    border-top: 1px solid var(--color-border);
  }

  .technology-metric strong {
    color: var(--color-gold);
    font-size: clamp(1.7rem, 2.7vw, 2.35rem);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .technology-metric span {
    font-size: 0.72rem;
    line-height: 1.4;
  }

  .control-layer {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 14px;
    align-items: center;
    padding: 22px;
    margin-top: 14px;
    color: white;
    background: var(--color-ink);
    border-radius: var(--radius-lg);
  }

  .control-layer > div {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 10px;
    align-items: start;
  }

  .control-layer > div > svg,
  .control-arrow {
    color: var(--color-gold-soft);
  }

  .control-layer span,
  .control-layer strong {
    display: block;
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .control-layer span {
    color: #b8c5d6;
  }

  .control-layer strong {
    color: white;
  }

  .next-contours {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    gap: 28px;
    align-items: center;
    padding: 20px 24px;
    margin-top: 14px;
    background: var(--color-paper);
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-lg);
  }

  .next-contours h3,
  .next-contours .section-kicker {
    margin-bottom: 0;
  }

  .next-contours h3 {
    margin-top: 5px;
    font-size: 1.05rem;
  }

  .next-contours ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .next-contours li {
    padding: 8px 12px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 650;
  }

  .owner-shift-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(500px, 1.15fr);
    gap: clamp(42px, 7vw, 92px);
    align-items: center;
  }

  .owner-shift-panel {
    width: min(100% - 48px, var(--container));
    padding: clamp(30px, 4vw, 48px);

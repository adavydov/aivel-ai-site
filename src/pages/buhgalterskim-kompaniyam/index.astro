---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalForm from "../../components/LocalForm.astro";
import Icon from "../../components/Icon.astro";

const networkFacts = [
  { value: "1 000", label: "клиентов в партнёрской сети" },
  { value: "400+ млн ₽", label: "выручка сети в пересчёте на год" },
  { value: "30+", label: "разработчиков ИИ, 1С и платформы" },
  { value: "8", label: "сделок за шесть месяцев" }
];

const ownerResults = [
  {
    title: "Свобода от ежедневной операционной рутины",
    text: "Меньше ручного контроля, переписки и повторяющихся случаев, требующих вмешательства руководителя. Внимание владельца остаётся для действительно сложных задач."
  },
  {
    title: "Более высокая роль у клиента",
    text: "Больше времени на денежный поток, налоги, риски и решения — то, за что клиент ценит личное участие владельца."
  },
  {
    title: "Более ценное предложение",
    text: "Учёт остаётся основой, а поверх него появляются своевременные сигналы, разбор причин и финансовые консультации."
  },
  {
    title: "Участие в следующем этапе роста",
    text: "Партнёр получает технологию и общий контур, сохраняя роль в компании и возможность участвовать в её дальнейшем развитии."
  }
];

const objections = [
  {
    question: "Нужно ли продавать компанию целиком?",
    answer: "Нет. Aivel рассматривает структуры с контрольной долей от 51%. Продавать 100% необязательно; точная доля, роль владельца и порядок принятия решений обсуждаются индивидуально."
  },
  {
    question: "Что произойдёт с клиентами и командой?",
    answer: "Первые 30 дней посвящены защите основы: фиксируются клиенты, команда, договоры, доступы, риски и исходные показатели. Изменения внедряются поэтапно, чтобы не нарушить обслуживание."
  },
  {
    question: "Собственник должен выйти из бизнеса?",
    answer: "Нет. Основной сценарий — собственник продолжает развивать компанию, но меньше занят повторяющимися операциями и больше работает с клиентами, стратегией и финансовыми решениями."
  },
  {
    question: "ИИ заменит бухгалтеров?",
    answer: "ИИ-помощники забирают повторяющиеся действия и готовят исключения для проверки. Профессиональное суждение, ответственность и работа со сложными ситуациями остаются у людей."
  },
  {
    question: "Можно ли сначала проверить технологию, а потом обсуждать сделку?",
    answer: "Да. Первый шаг — технологический разбор на 60–90 минут: демонстрация работающих ИИ-помощников, разбор двух–трёх процессов и предварительная оценка эффекта. Обязательства принимать решение о партнёрстве нет."
  },
  {
    question: "Как защищаются данные компании и клиентов?",
    answer: "Доступы, источники, права и порядок обработки данных согласуются до подключения. Подробная схема защиты и договорные условия рассматриваются на технологическом разборе.",
    href: "/zashchita-dannyh/",
    linkLabel: "Посмотреть принципы защиты данных"
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Партнёрство Aivel для бухгалтерских компаний",
    description: "Технологическое и операционное партнёрство для роста бухгалтерской компании без пропорционального увеличения ручной работы.",
    provider: { "@type": "Organization", name: "Aivel" },
    audience: { "@type": "BusinessAudience", audienceType: "Собственники бухгалтерских компаний" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: objections.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer }
    }))
  }
];
---

<BaseLayout
  title="Aivel для бухгалтерских компаний — рост без новой операционной нагрузки"
  description="Работающие ИИ-помощники, общий операционный контур и партнёрская модель Aivel для собственников бухгалтерских компаний."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Бухгалтерским компаниям</span>
  </div>

  <header class="page-hero partner-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">Собственникам бухгалтерских компаний</p>
        <h1>Расти без роста операционной рутины. <span>Стать финансовым партнёром клиентов.</span></h1>
        <p class="lead">Aivel подключает работающих ИИ-помощников, объединяет процессы в общий контур и освобождает собственника от повторяющегося исполнения. Отношения с клиентами остаются у вас — времени на их деньги, риски и развитие становится больше.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/avtomatizatsiya-ucheta/">Посмотреть работающих ИИ-помощников</a>
          <a class="button button-secondary" href="#partner-form">Оценить партнёрство конфиденциально</a>
        </div>
      </div>

      <aside class="page-hero-aside role-aside" aria-label="Переход к новой роли">
        <p class="aside-label">Не выйти из профессии, а подняться на уровень выше</p>
        <div class="role-path">
          <div><span>01</span><strong>Исполнять и контролировать</strong></div>
          <Icon name="arrow" size={22} />
          <div><span>02</span><strong>Управлять системой</strong></div>
          <Icon name="arrow" size={22} />
          <div class="role-path-final"><span>03</span><strong>Помогать клиенту принимать решения</strong></div>
        </div>
      </aside>
    </div>
  </header>

  <section class="section" aria-labelledby="why-now-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Почему присоединяться сейчас</p>
          <h2 id="why-now-title">Основа уже создана. Окно лидерства ещё открыто.</h2>
        </div>
        <p>Партнёр входит не в эксперимент, а в работающий контур — при этом большинство регионов и отраслевых направлений сети ещё формируются.</p>
      </div>

      <div class="why-grid">
        <article class="why-card" data-reveal>
          <span>01</span>
          <h3>Технология и сеть уже работают</h3>
          <p>Есть действующая клиентская база, команда разработки, восемь проведённых сделок и опыт подключения компаний к общему контуру.</p>
        </article>
        <article class="why-card why-card-accent" data-reveal>
          <span>02</span>
          <h3>Позиции лидеров ещё не распределены</h3>
          <p>Сегодня партнёрская география сосредоточена в Москве и Санкт-Петербурге. Новый участник может претендовать на ведущую роль в своём регионе или специализации.</p>
        </article>
        <article class="why-card" data-reveal>
          <span>03</span>
          <h3>Клиентам уже недостаточно только учёта</h3>
          <p>Следующая ценность — вовремя заметить важное, объяснить причину по данным и помочь принять решение. У владельца появляется время именно на эту работу.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="network-map-title">
    <div class="container network-snapshot">
      <div class="network-map" aria-label="География партнёрской сети и клиентов">
        <div class="map-title"><span>Партнёрская сеть</span><strong>Москва и Санкт-Петербург — действующее ядро</strong></div>
        <div class="map-canvas">
          <span class="map-line map-line-one" aria-hidden="true"></span>
          <span class="map-line map-line-two" aria-hidden="true"></span>
          <div class="map-node map-node-main"><span>Москва</span><strong>партнёры</strong></div>
          <div class="map-node map-node-main map-node-spb"><span>Санкт-Петербург</span><strong>партнёры</strong></div>
          <div class="map-node map-node-client map-node-kz"><span>Казахстан</span><strong>клиенты сети</strong></div>
          <div class="map-node map-node-client map-node-uz"><span>Узбекистан</span><strong>клиенты сети</strong></div>
          <div class="map-node map-node-open"><span>Ваш регион</span><strong>окно лидерства открыто</strong></div>
        </div>
        <p>Схема воспроизводит географию из партнёрской презентации; актуальный состав сети подтверждается перед обсуждением сделки.</p>
      </div>

      <div class="segment-map">
        <div><p class="section-kicker">Клиенты сети</p><h2 id="network-map-title">Понятный рынок, на котором уже есть масштаб.</h2></div>
        <div class="segment-price-grid"><article><span>Малый бизнес</span><strong>15–25 тыс. ₽</strong><p>средний месячный платёж за обслуживание в срезе презентации</p></article><article><span>Средний бизнес</span><strong>от 150 тыс. ₽</strong><p>месячный платёж в более сложном контуре</p></article></div>
        <div class="segment-tags" aria-label="Основные услуги и отрасли"><span>Бухгалтерский и налоговый учёт</span><span>Зарплата и кадры</span><span>Казначейство</span><span>Управленческий учёт</span><span>Строительство</span><span>Торговые площадки</span><span>Медицина</span><span>Оптовая торговля</span></div>
      </div>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="growth-title">
    <div class="container growth-layout">
      <div class="growth-copy">
        <p class="section-kicker section-kicker-light">Ловушка линейного роста</p>
        <h2 id="growth-title">Больше клиентов не должно означать больше личного контроля.</h2>
        <p>В обычной модели каждое расширение требует новых бухгалтеров, новых руководителей и ещё одного уровня проверки. Aivel переносит повторяющееся исполнение и часть контроля в систему.</p>
      </div>
      <div class="growth-comparison">
        <article>
          <span>Обычная модель</span>
          <strong>Клиенты → сотрудники → руководители → контроль владельца</strong>
          <p>Выручка растёт вместе с числом ручных операций и ежедневных случаев, требующих вмешательства владельца.</p>
        </article>
        <div class="comparison-arrow" aria-hidden="true"><Icon name="arrow" size={28} /></div>
        <article class="growth-model-new">
          <span>Модель Aivel</span>
          <strong>Клиенты → ИИ и 1С → люди на исключениях → время на клиента</strong>
          <p>Повторяющиеся процессы масштабируются технологией, а доверие и профессиональное суждение остаются у команды.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="role-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Смена роли</p>
          <h2 id="role-title">Собственник движется от исполнения к финансовому консультированию.</h2>
        </div>
        <p>Платформа забирает повторяющиеся действия и часть операционного контроля. Владелец не отдаляется от клиента — он становится ему нужнее.</p>
      </div>

      <div class="role-ladder">
        <article>
          <span>1</span>
          <p class="role-name">Бухгалтер</p>
          <h3>Исполняет и контролирует</h3>
          <ul><li>документы и сроки</li><li>отчётность и ошибки</li><li>случаи, требующие вмешательства</li></ul>
        </article>
        <article>
          <span>2</span>
          <p class="role-name">Управленец</p>
          <h3>Управляет системой</h3>
          <ul><li>команда и процессы</li><li>качество и загрузка</li><li>экономика компании</li></ul>
        </article>
        <article class="role-adviser">
          <span>3</span>
          <p class="role-name">Финансовый партнёр</p>
          <h3>Помогает принимать решения</h3>
          <ul><li>денежный поток</li><li>налоги и риски</li><li>сценарии роста</li></ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="rabotayushchie-pomoshchniki" aria-labelledby="agents-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Работающий продукт</p>
          <h2 id="agents-title">Рутину снимают конкретные ИИ-помощники, а не общее обещание автоматизации.</h2>
        </div>
        <p>Каждый помощник закрывает ограниченный процесс, показывает результат и передаёт человеку исключения, которые требуют профессионального решения.</p>
      </div>

      <div class="agent-grid">
        <a class="agent-card" href="/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/" data-reveal>
          <div class="agent-icon"><Icon name="person" size={26} /></div>
          <p class="agent-state">Работает</p>
          <h3>Коммуникации</h3>
          <p>Собирает обращения, создаёт задачи, назначает исполнителя и контролирует срок.</p>
          <strong>Запрос → задача → исполнитель → результат</strong>
          <small>Посмотреть устройство процесса <Icon name="arrow" size={17} /></small>
        </a>
        <a class="agent-card agent-card-featured" href="/avtomatizatsiya-ucheta/pervichnye-dokumenty/" data-reveal>
          <div class="agent-icon"><Icon name="document" size={26} /></div>
          <p class="agent-state">Работает</p>
          <h3>Первичные документы</h3>
          <p>Распознаёт документ, открывает нужную базу 1С, создаёт документ и заполняет аналитику.</p>
          <strong><b>80%</b> измеренного потока без ручного участия</strong>
          <small>Посмотреть устройство процесса <Icon name="arrow" size={17} /></small>
        </a>
        <a class="agent-card" href="/avtomatizatsiya-ucheta/bankovskie-operatsii/" data-reveal>
          <div class="agent-icon"><Icon name="chart" size={26} /></div>
          <p class="agent-state">Работает</p>
          <h3>Банк</h3>
          <p>Получает выписки, сопоставляет платежи, делит их по договорам и проставляет аналитику.</p>
          <strong><b>98%</b> точности сопоставления на проверенной выборке</strong>
          <small>Посмотреть устройство процесса <Icon name="arrow" size={17} /></small>
        </a>
        <a class="agent-card" href="/avtomatizatsiya-ucheta/sverki-s-kontragentami/" data-reveal>
          <div class="agent-icon"><Icon name="check" size={26} /></div>
          <p class="agent-state">Работает</p>
          <h3>Сверки</h3>
          <p>Закрывает типовые случаи и передаёт специалисту только расхождения.</p>
          <strong>Человек работает с исключениями</strong>
          <small>Посмотреть устройство процесса <Icon name="arrow" size={17} /></small>
        </a>
      </div>

      <div class="agent-next">
        <div><p class="section-kicker">Следующий контур</p><h3>Зарплата, торговые площадки и внутренний аудит</h3></div>
        <p>Эти процессы находятся в развитии. На встрече мы разделяем уже работающие возможности и план внедрения.</p>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="result-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Результат для собственника</p>
          <h2 id="result-title">Технология освобождает время. Партнёр превращает его в новую ценность.</h2>
        </div>
        <p>Смысл партнёрства не в том, чтобы заменить людей программой. Смысл — изменить модель роста и роль собственника.</p>
      </div>
      <div class="numbered-grid">
        {ownerResults.map((item) => (
          <article class="numbered-card" data-reveal><h3>{item.title}</h3><p>{item.text}</p></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-dark" aria-labelledby="proof-title">
    <div class="container">
      <div class="section-heading proof-heading">
        <div>
          <p class="section-kicker section-kicker-light">Подтверждение масштабом</p>
          <h2 id="proof-title">Aivel уже собрал работающую основу партнёрской сети.</h2>
        </div>
        <p>Технология, команда и опыт подключения компаний существуют сегодня — партнёру не нужно создавать их с нуля.</p>
      </div>

      <div class="network-facts">
        {networkFacts.map((fact) => (
          <div><strong>{fact.value}</strong><span>{fact.label}</span></div>
        ))}
      </div>

      <article class="partner-case">
        <div>
          <p class="case-label">Действующий партнёр сети</p>
          <h3>«Задачи и Решения»</h3>
          <p>Собственник продолжает развивать бизнес внутри партнёрской модели Aivel.</p>
        </div>
        <div class="case-facts">
          <div><strong>400+</strong><span>клиентов</span></div>
          <div><strong>35+</strong><span>сотрудников</span></div>
          <div><strong>+127%</strong><span>рост год к году</span></div>
        </div>
      </article>
      <p class="evidence-note">Показатели зафиксированы в партнёрской презентации Aivel и относятся к её срезу, а не к универсальному результату каждой компании. Актуальные дата и состав периметра подтверждаются до обсуждения условий.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="days-title">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Целевой план первых 90 дней</p>
          <h2 id="days-title">Сначала защищаем основу. Затем меняем готовые процессы.</h2>
        </div>
        <p>Срок и состав этапов подтверждаются после проверки 1С, данных, доступов и требуемых доработок. Клиенты, команда и качество обслуживания важнее скорости внедрения.</p>
      </div>

      <div class="integration-timeline">
        <article>
          <div class="timeline-head"><span>01</span><strong>0–30 дней</strong></div>
          <h3>Защищаем базу</h3>
          <p>Фиксируем клиентов, команду, риски, доступы, договоры и исходные показатели. Определяем, что нельзя потерять и где измерять эффект.</p>
        </article>
        <article>
          <div class="timeline-head"><span>02</span><strong>30–90 дней</strong></div>
          <h3>Подключаем выбранных помощников</h3>
          <p>При готовности данных настраиваем связь с 1С и запускаем согласованные процессы: обращения, первичные документы, банк или сверки.</p>
        </article>
        <article>
          <div class="timeline-head"><span>03</span><strong>После запуска</strong></div>
          <h3>Переводим операции в систему</h3>
          <p>Типовые операции переходят в общий контур: нормативы сроков и качества, данные, расчёты и люди на исключениях.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-warm" aria-labelledby="participation-title">
    <div class="container participation-panel">
      <div class="participation-number" aria-label="Доля участия от 51 процента"><span>от</span><strong>51%</strong></div>
      <div>
        <p class="section-kicker">Контрольная доля</p>
        <h2 id="participation-title">Продавать 100% компании необязательно.</h2>

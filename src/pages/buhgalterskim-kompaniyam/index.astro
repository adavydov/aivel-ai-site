---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocalForm from "../../components/LocalForm.astro";
import Icon from "../../components/Icon.astro";

const scaleFacts = [
  { value: "400+ млн ₽", label: "выручка сети в пересчёте на год" },
  { value: "1 000+", label: "клиентов в партнёрской сети" },
  { value: "3 страны", label: "география клиентов сети" }
];

const partnershipSteps = [
  {
    number: "01",
    title: "Вы сохраняете сильное",
    text: "Команду, отношения с клиентами и экспертизу, на которой построена компания."
  },
  {
    number: "02",
    title: "Aivel добавляет масштаб",
    text: "Работающих ИИ-помощников, общую технологическую основу и опыт партнёрской сети."
  },
  {
    number: "03",
    title: "Вместе растим компанию",
    text: "Типовой поток берут помощники, исключения — специалисты, развитие — собственник."
  }
];

const ownerBenefits = [
  {
    icon: "chart" as const,
    title: "Рост без пропорционального найма",
    text: "Больший объём типовых операций проходит через ту же сильную команду."
  },
  {
    icon: "person" as const,
    title: "Меньше личного контроля",
    text: "Исключения, сроки и история действий видны; собственнику не нужно держать процесс в голове."
  },
  {
    icon: "spark" as const,
    title: "Новая ценность для клиента",
    text: "Освободившееся время можно направить на деньги, риски и решения клиента."
  }
];

const implementationProof = [
  { value: "80%", label: "измеренного потока первичных документов прошло без ручного участия" },
  { value: "до 95%", label: "типовых сверок прошло без участия человека" },
  { value: "98%", label: "точности сопоставления банковских операций на проверенной выборке" }
];

const expertiseTracks = [
  {
    title: "Новые регионы",
    current: "Ядро сети — Москва и Санкт-Петербург.",
    sought: "Ищем сильные команды в других регионах."
  },
  {
    title: "Новые отрасли",
    current: "Уже есть медицина, строительство, деловые услуги и продавцы на торговых площадках.",
    sought: "Ищем глубокую экспертизу в других отраслях."
  },
  {
    title: "Новые специализации",
    current: "Есть бухгалтерский и налоговый учёт, зарплата и кадры, управленческий учёт.",
    sought: "Расширяем функциональные практики сети."
  }
];

type PartnerQuestion = {
  question: string;
  answer: string;
  points?: string[];
  steps?: { title: string; text: string }[];
  href?: string;
  linkLabel?: string;
};

const objections: PartnerQuestion[] = [
  {
    question: "Не потеряю ли я контроль и не отстраните ли меня после сделки?",
    answer: "Aivel получает контрольную долю, поэтому прежнего единоличного контроля у собственника не будет. При этом ваша роль и права не остаются на уровне устных договорённостей: до сделки мы подписываем корпоративный договор и другие документы сделки. В них фиксируем права, обязанности и доступ к информации, а также решения, которые каждая сторона принимает самостоятельно или только совместно.",
    points: [
      "Партнёр отвечает за рост, новую выручку, развитие существующей базы и клиентский сервис.",
      "Aivel отвечает за технологии, организацию производственного процесса, его эффективность и целевую рентабельность.",
      "Совместные решения, показатели ответственности и условия изменения роли собственника заранее закрепляются в документах."
    ]
  },
  {
    question: "Как убедиться, что технология действительно работает?",
    answer: "У Aivel уже есть действующие внедрения в бухгалтерских компаниях и у крупных корпоративных клиентов. На проверенных процессах 80% первичных документов прошли без ручного участия, до 95% типовых сверок — без участия человека, а точность сопоставления банковских операций составила 98%. До сделки мы покажем технологию в работе, а по согласованию с действующим клиентом и с соблюдением конфиденциальности можем организовать встречу или посещение внедрения.",
    href: "/buhgalterskoe-soprovozhdenie/#ii-pomoshchniki",
    linkLabel: "Посмотреть ИИ-помощников и результаты"
  },
  {
    question: "Поможет ли Aivel мне расти?",
    answer: "Да. В рамках согласованного плана Aivel будет вкладываться в узнаваемость компании, профессиональную известность партнёра и привлечение через поиск, содержание сайта и рекомендации. Форматы поддержки, бюджет и цели определяем вместе. Но сама сделка не включает гарантированный поток новых клиентов: рост в своей нише, регионе и направлениях услуг остаётся ответственностью партнёра. Мы помогаем в этом, потому что прямо заинтересованы в росте общей компании."
  },
  {
    question: "Как проходит покупка доли и сама сделка?",
    answer: "До детальной проверки нам важно понять компанию и цели собственника. Путь от знакомства до сделки состоит из четырёх понятных этапов.",
    steps: [
      { title: "Анкета и знакомство.", text: "Вы кратко рассказываете о компании, затем мы проводим несколько встреч с собственником." },
      { title: "Предварительное предложение.", text: "По итогам встреч формируем основные условия партнёрства. Они могут уточниться после проверки." },
      { title: "Детальная проверка.", text: "Если основные условия согласованы, проверяем компанию. Обычно это занимает три–четыре недели при наличии полного комплекта данных." },
      { title: "Сделка.", text: "После проверки согласуем окончательные документы, подписываем корпоративный договор и оформляем партнёрство." }
    ]
  },
  {
    question: "Можно ли продать меньше 51% или провести сделку поэтапно?",
    answer: "Меньше 51% на первом этапе — нет: Aivel приобретает только контрольную долю. При этом возможны разные сценарии.",
    points: [
      "Продажа 51% с сохранением активной роли собственника.",
      "Продажа 100% и согласованный выход собственника.",
      "Продажа 51% сейчас и поэтапный выкуп оставшейся доли до 100% по заранее согласованным условиям, срокам и формуле цены."
    ]
  },
  {
    question: "От чего зависит оценка компании?",
    answer: "Оценка отражает не только текущую выручку, но и устойчивость бизнеса. После анкеты мы сможем объяснить предварительный подход и возможный диапазон; окончательную оценку определяем после детальной проверки.",
    points: [
      "качество и устойчивость клиентской базы;",
      "наличие собственного роста;",
      "концентрация выручки на отдельных клиентах;",
      "отток и удержание клиентов;",
      "возможность повышать цены;",
      "остаётся ли собственник после сделки."
    ]
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Партнёрство Aivel для бухгалтерских компаний",
    description: "Партнёрство для роста бухгалтерской компании без пропорционального увеличения штата.",
    provider: { "@type": "Organization", name: "Aivel" },
    audience: { "@type": "BusinessAudience", audienceType: "Собственники бухгалтерских компаний" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: objections.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: [
          item.answer,
          ...(item.points ?? []),
          ...(item.steps?.map((step) => `${step.title} ${step.text}`) ?? [])
        ].join(" ")
      }
    }))
  }
];
---

<BaseLayout
  title="Aivel для бухгалтерских компаний — расти без найма и стать финансовым партнёром"
  description="Партнёрство Aivel для собственников бухгалтерских компаний: расти без пропорционального найма и стать финансовым партнёром для клиента."
  schema={schema}
>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><span>Стать партнёром</span>
  </div>

  <header class="page-hero partner-hero" aria-labelledby="partner-title">
    <div class="container partner-hero-grid">
      <div class="hero-copy">
        <p class="section-kicker">Собственникам бухгалтерских компаний</p>
        <h1 id="partner-title">Расти без найма. <span>Стать финансовым партнёром для клиента.</span></h1>
        <p class="lead">Aivel помогает увеличивать объём обслуживания без пропорционального роста штата: ИИ-помощники выполняют типовые операции, специалисты решают исключения, а собственник развивает клиентов и компанию.</p>
        <div class="hero-actions" aria-label="Следующие шаги">
          <a class="button button-primary" href="#partner-form">Обсудить партнёрство</a>
          <a class="button button-secondary" href="#partnership">Как устроено партнёрство</a>
        </div>
      </div>

      <aside class="value-model" aria-labelledby="value-model-title">
        <p class="section-kicker section-kicker-light">В чём ценность</p>
        <h2 id="value-model-title">Больше клиентов — без такого же роста ручной работы.</h2>
        <div class="value-chain" aria-label="Распределение работы">
          <div>
            <span class="value-icon"><Icon name="spark" size={22} /></span>
            <p><strong>ИИ-помощники</strong><span>выполняют типовой поток</span></p>
          </div>
          <Icon class="value-arrow" name="arrow" size={22} />
          <div>
            <span class="value-icon"><Icon name="person" size={22} /></span>
            <p><strong>Специалисты</strong><span>разбирают исключения</span></p>
          </div>
          <Icon class="value-arrow" name="arrow" size={22} />
          <div>
            <span class="value-icon"><Icon name="chart" size={22} /></span>
            <p><strong>Собственник</strong><span>занимается клиентами и ростом</span></p>
          </div>
        </div>
      </aside>
    </div>
  </header>

  <main>
    <section class="section partnership-section" id="partnership" aria-labelledby="partnership-title">
      <div class="container">
        <div class="section-heading compact-heading">
          <div>
            <p class="section-kicker">В чём суть партнёрства</p>
            <h2 id="partnership-title">Aivel становится совладельцем и усиливает то, что вы уже построили.</h2>
          </div>
          <p>Мы приобретаем контрольную долю от 51%. Вы продолжаете развивать компанию; роль собственника и темп изменений согласуем заранее.</p>
        </div>

        <ol class="partnership-steps">
          {partnershipSteps.map((step) => (
            <li data-reveal>
              <span>{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>

        <div class="partnership-note">
          <Icon name="check" size={22} />
          <p><strong>Не начинаем с перестройки.</strong> Сначала понимаем цели собственника, сильные стороны компании и процессы, которые готовы к усилению.</p>
        </div>
      </div>
    </section>

    <section class="section owner-section" aria-labelledby="owner-title">
      <div class="container owner-shell">
        <div class="owner-copy">
          <p class="section-kicker section-kicker-light">Что получает собственник</p>
          <h2 id="owner-title">Не выход из бизнеса. Новая роль в нём.</h2>
          <p>Меньше времени уходит на контроль повторяющихся операций. Больше — на ключевых клиентов, отраслевую практику и развитие компании.</p>
          <div class="owner-benefits">
            {ownerBenefits.map((benefit) => (
              <article>
                <span><Icon name={benefit.icon} size={22} /></span>
                <div><h3>{benefit.title}</h3><p>{benefit.text}</p></div>
              </article>
            ))}
          </div>
        </div>

        <aside class="technology-proof" aria-labelledby="proof-title">
          <p class="proof-label">За счёт чего это возможно</p>
          <h3 id="proof-title">ИИ ведёт типовой процесс. Человек включается в исключения.</h3>
          <div class="proof-metrics">
            {implementationProof.map((item) => (
              <div><strong>{item.value}</strong><span>{item.label}</span></div>
            ))}
          </div>
          <a class="text-link text-link-light" href="/buhgalterskoe-soprovozhdenie/#ii-pomoshchniki">Посмотреть ИИ-помощников <Icon name="arrow" size={17} /></a>
        </aside>
      </div>
    </section>

    <section class="section timing-section" aria-labelledby="timing-title">
      <div class="container">
        <div class="section-heading compact-heading">
          <div>
            <p class="section-kicker">Почему сейчас</p>
            <h2 id="timing-title">Сеть уже работает. Карта партнёров ещё открыта.</h2>
          </div>
          <p>Основа масштаба создана. Сейчас сильная бухгалтерская компания может усилить сеть своим регионом, отраслью или специализацией.</p>
        </div>

        <div class="scale-facts" aria-label="Масштаб партнёрской сети">
          {scaleFacts.map((fact) => (
            <div><strong>{fact.value}</strong><span>{fact.label}</span></div>
          ))}
        </div>

        <div class="expertise-grid">
          {expertiseTracks.map((track) => (
            <article data-reveal>
              <h3>{track.title}</h3>
              <p>{track.current}</p>
              <strong>{track.sought}</strong>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section faq-section" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <div class="faq-intro">
          <p class="section-kicker">Частые вопросы</p>
          <h2 id="faq-title">Что собственнику важно понять до сделки.</h2>
          <p>О контроле, технологии, росте, порядке сделки, доле и оценке компании.</p>
        </div>
        <div class="faq-list">
          {objections.map((item, index) => (
            <details class="partner-faq-item" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
              {item.points && (
                <ul class="faq-points">
                  {item.points.map((point) => <li><Icon name="check" size={17} /><span>{point}</span></li>)}
                </ul>
              )}
              {item.steps && (
                <ol class="faq-steps">
                  {item.steps.map((step, stepIndex) => (
                    <li>
                      <span class="faq-step-number">{String(stepIndex + 1).padStart(2, "0")}</span>
                      <div><strong>{step.title}</strong><span>{step.text}</span></div>
                    </li>
                  ))}
                </ol>
              )}
              {item.href && <a class="text-link faq-link" href={item.href}>{item.linkLabel} <Icon name="arrow" size={17} /></a>}
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section final-step" id="partner-form" aria-labelledby="next-step-title">
      <div class="container final-step-grid">
        <div class="final-step-copy">
          <p class="section-kicker">Следующий шаг</p>
          <h2 id="next-step-title">Расскажите о компании — найдём точку совпадения.</h2>
          <p>Достаточно указать масштаб, сильную экспертизу и вашу цель. На первом шаге закрытые данные не нужны.</p>
        </div>
        <div class="partner-form-shell">
          <LocalForm mode="partner" title="Короткая анкета о компании" submitLabel="Обсудить партнёрство конфиденциально" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .partner-hero {
    padding-block: clamp(28px, 4vw, 54px) clamp(64px, 8vw, 104px);
  }

  .partner-hero-grid {
    display: grid;
    grid-template-columns: minmax(430px, 0.88fr) minmax(0, 1.12fr);
    gap: clamp(44px, 7vw, 96px);
    align-items: start;
  }

  .partner-hero h1 {
    max-width: 760px;
    font-size: clamp(2.75rem, 4.2vw, 4.7rem);
  }

  .partner-hero h1 span {
    display: block;
    margin-top: 0.14em;
    color: var(--color-gold);
  }

  .partner-hero .lead {
    max-width: 690px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .hero-actions .button {
    min-height: 54px;
    justify-content: center;
    padding-inline: 24px;
  }

  .value-model {
    padding: clamp(28px, 4vw, 44px);
    color: white;
    background: var(--color-ink);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .value-model h2 {
    max-width: 700px;
    margin-bottom: 32px;
    color: white;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
  }

  .value-chain {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 12px;
    align-items: stretch;
  }

  .value-chain > div {
    display: grid;
    min-width: 0;
    align-content: start;
    gap: 16px;
    padding: 18px;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.11);
    border-radius: var(--radius-md);
  }

  .value-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    color: var(--color-gold-soft);
    background: rgb(255 255 255 / 0.07);
    border-radius: 12px;
  }

  .value-chain p,
  .value-chain strong,
  .value-chain span {
    display: block;
    margin: 0;
  }

  .value-chain strong {
    color: white;
    font-size: 0.9rem;
  }

  .value-chain p span {
    margin-top: 6px;
    color: #aebdd0;
    font-size: 0.75rem;
    line-height: 1.45;
  }

  .value-arrow {
    align-self: center;
    color: var(--color-gold-soft);
  }

  .compact-heading {
    margin-bottom: 34px;
  }

  .partnership-section {
    border-top: 1px solid var(--color-border);
  }

  .partnership-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .partnership-steps li {
    min-width: 0;
    padding: clamp(24px, 3vw, 34px);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .partnership-steps li > span {
    display: block;
    margin-bottom: clamp(38px, 5vw, 64px);
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .partnership-steps h3 {
    margin-bottom: 10px;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
  }

  .partnership-steps p {
    margin: 0;
    font-size: 0.9rem;
  }

  .partnership-note {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: start;
    padding: 20px 24px;
    margin-top: 14px;
    background: var(--color-gold-pale);
    border: 1px solid #ead7af;
    border-radius: var(--radius-md);
  }

  .partnership-note svg {
    margin-top: 2px;
    color: var(--color-gold);
  }

  .partnership-note p {
    margin: 0;
    font-size: 0.9rem;
  }

  .owner-section {
    padding-top: 0;
  }

  .owner-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(390px, 0.76fr);
    gap: clamp(40px, 6vw, 78px);
    padding: clamp(34px, 5vw, 62px);
    color: white;
    background: var(--color-ink);
    border-radius: var(--radius-xl);
  }

  .owner-copy > h2 {
    max-width: 720px;
    color: white;
  }

  .owner-copy > p {
    max-width: 720px;
    color: #b7c4d4;
  }

  .owner-benefits {

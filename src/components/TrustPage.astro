---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "./Icon.astro";

interface Step { title: string; text: string; }
interface Link { href: string; label: string; }
interface Props {
  title: string;
  metaTitle: string;
  description: string;
  kicker: string;
  lead: string;
  asideTitle: string;
  asideText: string;
  sectionTitle: string;
  sectionText: string;
  steps: Step[];
  noticeTitle: string;
  noticeText: string;
  related?: Link[];
}

const props = Astro.props;
---

<BaseLayout title={props.metaTitle} description={props.description}>
  <div class="container breadcrumbs" aria-label="Хлебные крошки">
    <a href="/">Главная</a><span aria-hidden="true">/</span><a href="/kak-rabotaet/">Как это работает</a><span aria-hidden="true">/</span><span>{props.kicker}</span>
  </div>
  <header class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="section-kicker">{props.kicker}</p>
        <h1>{props.title}</h1>
        <p class="lead">{props.lead}</p>
      </div>
      <aside class="page-hero-aside"><strong>{props.asideTitle}</strong><p>{props.asideText}</p></aside>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><p class="section-kicker">Порядок работы</p><h2>{props.sectionTitle}</h2></div>
        <p>{props.sectionText}</p>
      </div>
      <div class="numbered-grid">
        {props.steps.map((step) => <article class="numbered-card"><h3>{step.title}</h3><p>{step.text}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section section-warm">
    <div class="narrow">
      <div class="notice">
        <Icon name="shield" size={26} />
        <p><strong>{props.noticeTitle}</strong> {props.noticeText}</p>
      </div>
      {props.related && props.related.length > 0 && (
        <div class="source-stack" aria-label="Связанные страницы">
          {props.related.map((link) => <a href={link.href}><Icon name="arrow" size={16} />{link.label}</a>)}
        </div>
      )}
    </div>
  </section>

  <section class="final-cta">
    <div class="container">
      <p class="section-kicker section-kicker-light">Проверить на своей ситуации</p>
      <h2>Начнём с важного события и состояния источников.</h2>
      <p>Не отправляйте финансовые данные через открытую форму. Сначала согласуем задачу и безопасный способ работы.</p>
      <button class="button button-light" type="button" data-open-contact data-contact-topic="client">Настроить первые сигналы</button>
    </div>
  </section>
</BaseLayout>

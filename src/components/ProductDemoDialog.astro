---
import Icon from "./Icon.astro";
---

<dialog class="product-demo-dialog" data-product-demo aria-labelledby="product-demo-title">
  <div class="product-demo-shell">
    <div class="product-demo-head">
      <div>
        <p class="section-kicker">Демо на учебных данных</p>
        <h2 id="product-demo-title" tabindex="-1">Что вы боитесь узнать слишком поздно?</h2>
        <p>Выберите одну из четырёх ситуаций или опишите похожую. Aivel покажет изменение, основание и действие — без доступа к вашим данным.</p>
      </div>
      <button class="icon-button demo-close" type="button" aria-label="Закрыть демонстрацию" data-close-demo>
        <Icon name="close" size={24} />
      </button>
    </div>

    <div class="product-demo-layout">
      <div class="demo-control-panel">
        <div class="demo-situation-list" aria-label="Примеры ситуаций">
          <button type="button" data-scenario="cash" aria-pressed="true"><span>01</span>Не хватит денег на обязательства</button>
          <button type="button" data-scenario="payment" aria-pressed="false"><span>02</span>Крупный клиент задержит оплату</button>
          <button type="button" data-scenario="expense" aria-pressed="false"><span>03</span>Расходы начнут расти быстрее выручки</button>
          <button type="button" data-scenario="hiring" aria-pressed="false"><span>04</span>Новый найм станет слишком дорогим</button>
        </div>

        <form class="demo-question-form" data-demo-question-form>
          <label for="demo-question">Или спросите своими словами</label>
          <div>
            <input id="demo-question" name="demo-question" placeholder="Например: хватит ли денег на зарплату?" autocomplete="off" aria-describedby="demo-question-hint demo-question-status" />
            <button class="button button-primary" type="submit">Подобрать учебный сценарий</button>
          </div>
          <p id="demo-question-hint">Демо распознаёт только четыре учебных сценария. Закрытые сведения вводить не нужно.</p>
          <p class="demo-question-status" id="demo-question-status" role="status" aria-live="polite" data-demo-question-status></p>
        </form>
      </div>

      <section class="demo-result-panel" data-demo-result-panel>
        <p class="sr-only" aria-live="polite" aria-atomic="true" data-demo-live-status></p>
        <div class="demo-result-status"><Icon name="spark" size={18} /><span data-demo-kind>Прогноз · требует внимания</span></div>
        <div class="demo-result-meta" aria-label="Качество и границы ответа">
          <span><strong>Свежесть</strong><b data-demo-freshness>11 июля, 09:40</b></span>
          <span><strong>Периметр</strong><b data-demo-scope>4 источника</b></span>
          <span><strong>Проверка</strong><b data-demo-review>Нужны подтверждения</b></span>
        </div>
        <h3 data-demo-signal tabindex="-1">18 июля запас денег может снизиться до 620 тыс. ₽ — ниже установленной границы.</h3>
        <div class="demo-result-grid">
          <div><span>Почему важно</span><p data-demo-why>На эту дату приходятся налоги и зарплата. Без двух ожидаемых оплат потребуется перенести необязательную закупку.</p></div>
          <div class="demo-result-metric"><span data-demo-metric-label>Ниже границы</span><strong data-demo-metric>−380 тыс. ₽</strong></div>
        </div>
        <div class="demo-result-action"><Icon name="check" size={20} /><div><span>Что сделать сейчас</span><p data-demo-action>До 14 июля подтвердить сроки двух оплат. Если дата не подтвердится — перенести закупку на 7–10 дней.</p></div></div>
        <details class="demo-result-proof">
          <summary>Проверить расчёт, источники и границу вывода</summary>
          <div>
            <p><strong>Основание:</strong> <span data-demo-basis>банк, налоговый календарь, расчёт зарплаты и выставленные счета.</span></p>
            <p><strong>Граница:</strong> <span data-demo-limit>прогноз учитывает только подключённые источники и подтверждённые даты.</span></p>
          </div>
        </details>
        <div class="demo-result-next">
          <button class="button button-primary" type="button" data-demo-to-contact data-demo-contact-label>Получать такие сигналы</button>
          <a class="text-link" href="/vazhnoe/">Посмотреть другие примеры <Icon name="arrow" size={18} /></a>
        </div>
      </section>
    </div>
  </div>
</dialog>

<style>
  .product-demo-dialog {
    width: min(calc(100% - 32px), 1180px);
    max-height: calc(100dvh - 32px);
    padding: 0;
    overflow: auto;
    color: var(--color-ink);
    background: var(--color-paper);
    border: 0;
    border-radius: var(--radius-xl);
    box-shadow: 0 35px 120px rgb(2 6 23 / 0.42);
  }

  .product-demo-dialog::backdrop {
    background: rgb(2 6 23 / 0.76);
    backdrop-filter: blur(8px);
  }

  .product-demo-shell {
    padding: clamp(24px, 4vw, 48px);
  }

  .product-demo-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 30px;
  }

  .product-demo-head > div {
    min-width: 0;
  }

  .product-demo-head h2 {
    max-width: 820px;
    margin-bottom: 12px;
    font-size: clamp(2rem, 4vw, 3.8rem);
  }

  .product-demo-head h2:focus,
  .demo-result-panel h3:focus {
    outline: none;
  }

  .product-demo-head p:last-child {
    max-width: 760px;
    margin-bottom: 0;
  }

  .demo-close {
    flex: 0 0 auto;
  }

  .product-demo-layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.68fr) minmax(0, 1.32fr);
    gap: 18px;
  }

  .demo-control-panel,
  .demo-result-panel {
    min-width: 0;
    padding: clamp(20px, 3vw, 30px);
    border-radius: var(--radius-lg);
  }

  .demo-control-panel {
    background: #fff;
    border: 1px solid var(--color-border);
  }

  .demo-situation-list {
    display: grid;
    gap: 8px;
  }

  .demo-situation-list button {
    display: grid;
    min-height: 58px;
    grid-template-columns: 30px 1fr;
    gap: 10px;
    align-items: center;
    padding: 12px 14px;
    color: var(--color-ink);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.3;
    text-align: left;
  }

  .demo-situation-list button span {
    color: var(--color-gold);
    font-size: 0.72rem;
  }

  .demo-situation-list button[aria-pressed="true"] {
    background: var(--color-gold-pale);
    border-color: #d9b866;
    box-shadow: 0 0 0 2px rgb(245 201 121 / 0.24);
  }

  .demo-question-form {
    padding-top: 22px;
    margin-top: 22px;
    border-top: 1px solid var(--color-border);
  }

  .demo-question-form label {
    display: block;
    margin-bottom: 8px;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .demo-question-form > div {
    display: grid;
    gap: 8px;
  }

  .demo-question-form input {
    width: 100%;
    min-height: 50px;
    padding: 12px 14px;
    color: var(--color-ink);
    background: #fff;
    border: 1px solid var(--color-border-strong);
    border-radius: 12px;
  }

  .demo-question-form p {
    margin: 8px 0 0;
    color: var(--color-muted);
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .demo-question-form .demo-question-status {
    min-height: 1.4em;
    color: var(--color-blue);
    font-weight: 650;
  }

  .demo-question-form .demo-question-status.is-error {
    color: var(--color-red);
  }

  .demo-result-panel {
    color: white;
    background:
      radial-gradient(circle at 100% 0, rgb(245 201 121 / 0.16), transparent 40%),
      #0b1427;
    border: 1px solid rgb(255 255 255 / 0.1);
  }

  .demo-result-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    color: var(--color-gold-soft);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .demo-result-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 18px;
  }

  .demo-result-meta > span {
    min-width: 0;
    padding: 10px 12px;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 10px;
  }

  .demo-result-meta strong,
  .demo-result-meta b {
    display: block;
  }

  .demo-result-meta strong {
    margin-bottom: 3px;
    color: #91a2bb;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .demo-result-meta b {
    overflow-wrap: anywhere;
    color: white;
    font-size: 0.75rem;
    font-weight: 650;
    line-height: 1.35;
  }

  .demo-result-panel.is-unsupported {
    background:
      radial-gradient(circle at 100% 0, rgb(245 201 121 / 0.13), transparent 40%),
      #111827;
  }

  .demo-result-panel h3 {
    max-width: 760px;
    margin-bottom: 26px;
    color: white;
    font-size: clamp(1.55rem, 2.8vw, 2.5rem);
  }

  .demo-result-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(150px, 0.35fr);
    gap: 12px;
  }

  .demo-result-grid > div {
    min-width: 0;
    padding: 18px;
    background: rgb(255 255 255 / 0.055);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-md);
  }

  .demo-result-grid span,
  .demo-result-action span {
    display: block;
    margin-bottom: 7px;
    color: #91a2bb;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .demo-result-grid p,
  .demo-result-action p {
    margin: 0;
    color: #e1e8f1;
    line-height: 1.5;
  }

  .demo-result-metric {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .demo-result-metric strong {
    color: var(--color-gold-soft);
    font-size: clamp(1.8rem, 3.3vw, 3rem);
    line-height: 1;
  }

  .demo-result-action {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    padding: 18px;
    margin-top: 12px;
    color: var(--color-gold-soft);
    background: rgb(22 101 52 / 0.2);
    border: 1px solid rgb(134 239 172 / 0.2);
    border-radius: var(--radius-md);
  }

  .demo-result-proof {
    margin-top: 12px;
    background: rgb(255 255 255 / 0.04);
    border: 1px solid rgb(255 255 255 / 0.09);
    border-radius: var(--radius-md);
  }

  .demo-result-proof summary {
    min-height: 52px;
    padding: 14px 18px;
    color: white;
    font-size: 0.86rem;
    font-weight: 700;
    cursor: pointer;
  }

  .demo-result-proof > div {
    padding: 0 18px 16px;
  }

  .demo-result-proof p {
    margin: 8px 0 0;
    color: #aebdd0;
    font-size: 0.8rem;
  }

  .demo-result-proof strong {
    color: white;
  }

  .demo-result-next {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 22px;
    align-items: center;
    margin-top: 22px;
  }

  .demo-result-next .button-primary {
    color: var(--color-ink);
    background: var(--color-gold-soft);
  }

  .demo-result-next .text-link {
    color: white;
  }

  @media (max-width: 860px) {
    .product-demo-layout {
      grid-template-columns: 1fr;
    }

    .demo-situation-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .product-demo-dialog {
      width: calc(100% - 12px);
      max-height: calc(100dvh - 12px);
      border-radius: 20px;
    }

    .product-demo-shell {
      padding: 18px;
    }

    .product-demo-head {
      gap: 12px;
      margin-bottom: 20px;
    }

    .product-demo-head h2 {
      font-size: 2rem;
    }

    .product-demo-head p:last-child {
      font-size: 0.9rem;
    }

    .product-demo-dialog[open] .demo-close {
      position: fixed;
      z-index: calc(var(--z-dialog) + 1);
      top: 14px;
      right: 14px;
      color: var(--color-ink);
      background: white;
      box-shadow: var(--shadow-sm);
    }

    .demo-situation-list,
    .demo-result-grid,
    .demo-result-meta {
      grid-template-columns: 1fr;
    }

    .demo-result-next {
      align-items: stretch;
      flex-direction: column;
    }

    .demo-result-next .button {
      width: 100%;
    }
  }
</style>

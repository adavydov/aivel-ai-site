---
import Icon from "./Icon.astro";
import { importantSignals } from "../data/site";
---

<div class="answer-demo important-signal-demo" id="primer-signala" data-answer-demo>
  <div class="demo-tabs" role="tablist" aria-label="Примеры важных изменений">
    {importantSignals.map((signal, index) => (
      <button
        type="button"
        role="tab"
        id={`signal-tab-${signal.id}`}
        aria-controls={`signal-panel-${signal.id}`}
        aria-selected={index === 0 ? "true" : "false"}
        tabindex={index === 0 ? 0 : -1}
        data-demo-tab={signal.id}
      >
        {signal.tab}
      </button>
    ))}
  </div>

  {importantSignals.map((signal, index) => (
    <section
      class="demo-panel"
      role="tabpanel"
      id={`signal-panel-${signal.id}`}
      aria-labelledby={`signal-tab-${signal.id}`}
      hidden={index !== 0}
      data-demo-panel={signal.id}
    >
      <div class="signal-event-row">
        <div class="demo-avatar" aria-hidden="true"><Icon name="spark" size={22} /></div>
        <div>
          <span>Важное изменение · {signal.kind}</span>
          <p>Обнаружено {signal.detectedAt}</p>
        </div>
      </div>

      <div class="demo-answer-grid">
        <div class="demo-answer-main">
          <div class="verified-label"><Icon name="shield" size={18} /> Проверяемый сигнал</div>
          <h3>{signal.signal}</h3>
          <div class="signal-why">
            <span>Почему это важно</span>
            <p>{signal.whyImportant}</p>
          </div>

        </div>

        <aside class="demo-metric" aria-label={`${signal.metricLabel}: ${signal.metric}`}>
          <span>{signal.metricLabel}</span>
          <strong>{signal.metric}</strong>
          <small>по учебным данным</small>
        </aside>
      </div>

      <div class="signal-action-grid">
        <div class="signal-action-card signal-action-primary">
          <span><Icon name="chart" size={18} /> После сигнала — что сделать сейчас</span>
          <p>{signal.action}</p>
        </div>
      </div>

      <details class="signal-proof-details">
        <summary>Проверить расчёт, источники и границу вывода</summary>
        <div class="signal-proof-body">
          <div class="answer-meta">
            <span><strong>Период</strong>{signal.period}</span>
            <span><strong>Свежесть</strong>{signal.freshness}</span>
            <span><strong>Периметр</strong>{signal.scope}</span>
          </div>

          <div class="bridge-table" aria-label="Основание сигнала">
            {signal.bridge.map((item) => (
              <div>
                <span>{item.label}</span>
                <strong class={`tone-${item.tone}`}>{item.value}</strong>
              </div>
            ))}
          </div>

          <div class="signal-action-card">
            <span><Icon name="document" size={18} /> Что уточнить</span>
            <div class="signal-question-list">
              {signal.questions.map((question) => (
                <a href={question.href}>{question.label}<Icon name="arrow" size={16} /></a>
              ))}
            </div>
          </div>

          <div class="signal-evidence-grid">
            <div>
              <span class="signal-block-label"><Icon name="source" size={17} /> Источники</span>
              <div class="source-list">
                {signal.sources.map((source) => <span>{source}</span>)}
              </div>
            </div>
            <div>
              <span class="signal-block-label"><Icon name="person" size={17} /> Роль специалиста</span>
              <p>{signal.specialist}</p>
            </div>
          </div>

          <div class="signal-limit">
            <Icon name="shield" size={20} />
            <p><strong>Граница вывода.</strong> {signal.limitation}</p>
          </div>
        </div>
      </details>

      <div class="demo-compact-footer">
        <p class="demo-disclaimer">Учебный пример на обезличенных данных. Реальный сигнал зависит от подключённых источников и правил важности.</p>
        <button class="button button-small button-light" type="button" data-open-demo data-demo-scenario={signal.id === "cash-buffer" ? "cash" : signal.id === "payment-delay" ? "payment" : "expense"}>Задать свой вопрос</button>
      </div>
    </section>
  ))}
</div>

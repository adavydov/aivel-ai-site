---
interface Props {
  compact?: boolean;
  dark?: boolean;
}

const { compact = false, dark = false } = Astro.props;

const brands = [
  { name: "DDX", image: "/brands/ddx.png", className: "", width: 482, height: 140 },
  { name: "Нефтьмагистраль", image: "/brands/neftmagistral.png", className: "", width: 480, height: 138 },
  { name: "Братья Караваевы", image: "karavaevi", className: "brand-karavaevi", width: 180, height: 48 },
  { name: "Гольфстрим", image: "/brands/golfstrim-official.svg", className: "brand-official-wide", width: 278, height: 80 },
  { name: "ВсеИнструменты.ру", image: "/brands/vseinstrumenti-official.svg", className: "brand-official-wide", width: 411, height: 208 }
];
---

<div class:list={["brand-wall", compact && "brand-wall-compact", dark && "brand-wall-dark"]} aria-label="Компании, с которыми работала команда Aivel">
  {brands.map((brand) => (
    <div class:list={["brand-tile", brand.className]} title={brand.name}>
      {brand.image === "karavaevi" ? (
        <div class="karavaevi-lockup" aria-label="Братья Караваевы">
          <img src="/brands/karavaevi-symbol.svg" width="48" height="48" alt="" loading="lazy" />
          <img src="/brands/karavaevi-wordmark.svg" width="132" height="37" alt="Братья Караваевы" loading="lazy" />
        </div>
      ) : (
        <img src={brand.image} width={brand.width} height={brand.height} alt={brand.name} loading="lazy" />
      )}
    </div>
  ))}
</div>

<style>
  .brand-wall {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .brand-tile {
    display: grid;
    min-height: 108px;
    padding: 18px;
    place-items: center;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .brand-tile > img {
    width: 100%;
    max-width: 190px;
    max-height: 60px;
    object-fit: contain;
  }

  .brand-official-wide > img {
    max-width: 210px;
  }

  .karavaevi-lockup {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .karavaevi-lockup img:first-child {
    width: 38px;
    height: 38px;
  }

  .karavaevi-lockup img:last-child {
    width: min(125px, calc(100% - 48px));
    max-height: 48px;
  }

  .brand-wall-compact .brand-tile {
    min-height: 82px;
    padding: 12px;
  }

  .brand-wall-dark .brand-tile {
    border-color: rgb(255 255 255 / 0.12);
  }

  @media (max-width: 920px) {
    .brand-wall {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

  }

  @media (max-width: 620px) {
    .brand-wall {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 9px;
    }

    .brand-tile {
      min-height: 88px;
      padding: 12px;
    }

    .brand-tile:last-child {
      grid-column: 1 / -1;
    }
  }
</style>

---
import Icon from "./Icon.astro";

const sources = [
  "ЭДО и почта",
  "Банки",
  "ФНС и отчётность",
  "1С и ERP",
  "iiko и другие рабочие системы"
] as const;
---

<div class="foundation-map">
  <ol class="map-flow" aria-label="Как правильные данные становятся основой для решения">
    <li class="map-stage source-stage">
      <span class="stage-number">01</span>
      <h3>Собираем данные</h3>
      <p>Получаем документы и операции из согласованных рабочих источников.</p>
      <ul class="source-list">
        {sources.map((source) => <li>{source}</li>)}
      </ul>
    </li>

    <li class="map-stage operation-stage">
      <span class="stage-number">02</span>
      <span class="stage-icon" aria-hidden="true"><Icon name="spark" size={21} /></span>
      <h3>Выполняем и проверяем</h3>
      <p>ИИ-помощники проводят типовые операции по заданным правилам.</p>
      <div class="human-loop">
        <span aria-hidden="true"><Icon name="person" size={19} /></span>
        <div><strong>Человек — на исключениях</strong><small>проверяет неоднозначное и принимает решение</small></div>
      </div>
    </li>

    <li class="map-stage base-stage">
      <span class="stage-number">03</span>
      <h3>Формируем проверенную базу</h3>
      <p>Каждая запись связана с источником, правилом и подтверждением.</p>
      <div class="base-layers" aria-label="Слои проверенной учётной базы">
        <span>Управленческий учёт</span>
        <span>Зарплата и кадры</span>
        <span>Налоговый учёт</span>
        <span>Бухгалтерский учёт</span>
      </div>
    </li>

    <li class="map-stage important-stage">
      <span class="stage-number">04</span>
      <span class="important-icon" aria-hidden="true"><Icon name="spark" size={22} /></span>
      <h3>Aivel замечает важное</h3>
      <p>Руководитель получает короткий сигнал с причиной и следующим шагом.</p>
      <div class="signal-preview">
        <small>Важное изменение</small>
        <strong>Запас денег опустится ниже согласованной границы</strong>
        <span>Основание можно проверить до решения</span>
      </div>
    </li>
  </ol>

  <p class="map-summary"><Icon name="shield" size={18} /> Правильное решение начинается не с красивого отчёта, а с полной и проверяемой цепочки данных.</p>
</div>

<style>
  .foundation-map {
    display: grid;
    gap: 14px;
  }

  .map-flow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .map-stage {
    position: relative;
    min-width: 0;
    min-height: 310px;
    padding: 22px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .map-stage:not(:last-child)::after {
    position: absolute;
    z-index: 2;
    top: 50%;
    right: -19px;
    display: grid;
    width: 26px;
    height: 26px;
    color: var(--color-ink);
    background: var(--color-gold-soft);
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 9px rgb(15 23 42 / 0.12);
    content: "→";
    font-size: 0.85rem;
    font-weight: 800;
    place-items: center;
    transform: translateY(-50%);
  }

  .map-stage h3 {
    margin: 10px 0 8px;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
  }

  .map-stage > p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .stage-number {
    color: var(--color-gold);
    font-size: 0.76rem;
    font-weight: 760;
    letter-spacing: 0.12em;
  }

  .stage-icon,
  .important-icon {
    display: grid;
    width: 42px;
    height: 42px;
    margin-top: 18px;
    border-radius: 11px;
    place-items: center;
  }

  .stage-icon {
    color: var(--color-blue);
    background: var(--color-blue-pale);
  }

  .source-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    padding: 0;
    margin: 22px 0 0;
    list-style: none;
  }

  .source-list li {
    padding: 7px 9px;
    color: var(--color-ink-soft);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 9px;
    font-size: 0.76rem;
    font-weight: 650;
    line-height: 1.25;
  }

  .human-loop {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 10px;
    align-items: center;
    padding: 11px;
    margin-top: 20px;
    background: var(--color-green-pale);
    border: 1px solid #c7e2d2;
    border-radius: 11px;
  }

  .human-loop > span {
    display: grid;
    width: 38px;
    height: 38px;
    color: var(--color-green);
    background: white;
    border-radius: 9px;
    place-items: center;
  }

  .human-loop strong,
  .human-loop small {
    display: block;
  }

  .human-loop strong {
    font-size: 0.8rem;
  }

  .human-loop small {
    margin-top: 3px;
    color: var(--color-muted);
    font-size: 0.72rem;
    line-height: 1.35;
  }

  .base-layers {
    display: grid;
    gap: 4px;
    margin-top: 20px;
  }

  .base-layers span {
    padding: 7px 10px;
    color: white;
    background: #394c6a;
    border-radius: 6px;
    font-size: 0.76rem;
    font-weight: 650;
    text-align: center;
  }

  .base-layers span:nth-child(2) { background: #324561; }
  .base-layers span:nth-child(3) { background: #283b57; }
  .base-layers span:nth-child(4) { background: var(--color-ink-soft); }

  .important-stage {
    color: white;
    background: var(--color-ink);
    border-color: var(--color-ink);
  }

  .important-stage h3 {
    color: white;
  }

  .important-stage > p {
    color: #c3cfde;
  }

  .important-icon {
    color: var(--color-ink);
    background: var(--color-gold-soft);
  }

  .signal-preview {
    display: grid;
    gap: 6px;
    padding: 13px;
    margin-top: 18px;
    color: var(--color-ink);
    background: white;
    border-radius: 11px;
  }

  .signal-preview small {
    color: var(--color-red);
    font-size: 0.7rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .signal-preview strong {
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .signal-preview span {
    color: var(--color-muted);
    font-size: 0.72rem;
    line-height: 1.4;
  }

  .map-summary {
    display: flex;
    gap: 9px;
    align-items: center;
    padding: 12px 14px;
    margin: 0;
    color: var(--color-green);
    background: var(--color-green-pale);
    border: 1px solid #c7e2d2;
    border-radius: 11px;
    font-size: 0.82rem;
    font-weight: 680;
    line-height: 1.45;
  }

  .map-summary svg {
    flex: 0 0 auto;
  }

  @media (max-width: 1080px) {
    .map-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .map-stage {
      min-height: 280px;
    }

    .map-stage::after {
      display: none !important;
    }
  }

  @media (max-width: 620px) {
    .map-flow {
      grid-template-columns: 1fr;
    }

    .map-stage {
      min-height: 0;
      padding: 18px;
    }

    .map-summary {
      align-items: flex-start;
    }
  }
</style>

---
import Icon from "./Icon.astro";

const sources = [
  "ЭДО",
  "Почта",
  "Банки",
  "ФНС и отчётность",
  "ERP и 1С",
  "iiko и другие транзакционные системы"
] as const;

const helpers = [
  {
    id: "primary",
    icon: "document",
    title: "Первичные документы",
    status: "Работает",
    statusTone: "live",
    metric: "80%",
    metricText: "измеренного потока прошло без ручного участия",
    work: "Распознаёт документ, создаёт его в 1С и заполняет учётные признаки.",
    exception: "Нечитаемые, неполные и нестандартные документы передаются специалисту.",
    trace: "В истории остаются исходный файл, извлечённые поля, проверки и итоговое действие."
  },
  {
    id: "bank",
    icon: "chart",
    title: "Банковские операции",
    status: "Работает",
    statusTone: "live",
    metric: "98%",
    metricText: "точности сопоставления на проверенной выборке",
    work: "Извлекает реквизиты, сопоставляет платёж и заполняет аналитику; умеет разделять платёж.",
    exception: "Неоднозначные назначения и непривычные операции получает бухгалтер.",
    trace: "Можно восстановить выписку, применённое правило, выбранный договор и подтверждение человека."
  },
  {
    id: "reconciliations",
    icon: "check",
    title: "Сверки с контрагентами",
    status: "Работает",
    statusTone: "live",
    metric: "до 95%",
    metricText: "сверок проходило без участия человека",
    work: "Распознаёт акт, создаёт сверку в 1С, проверяет совпадение и выделяет расхождения.",
    exception: "Расхождение или спорная операция сразу передаются специалисту.",
    trace: "Сохраняются акт, данные 1С, результат сравнения и решение по расхождению."
  },
  {
    id: "payroll",
    icon: "person",
    title: "Зарплата и кадры",
    status: "Следующий контур",
    statusTone: "next",
    metric: "Без обещаний в цифрах",
    metricText: "эффект фиксируется только после проверки процесса",
    work: "Целевой контур — подготовка данных для типовых начислений и кадровых операций.",
    exception: "Расчёт, кадровое решение и нестандартный случай подтверждает ответственный специалист.",
    trace: "Для внедрения заранее задаются роли, проверки и перечень решений, доступных помощнику."
  },
  {
    id: "accounting",
    icon: "source",
    title: "Бухгалтерский и налоговый учёт",
    status: "Следующий контур",
    statusTone: "next",
    metric: "Правила до запуска",
    metricText: "границы автоматизации согласуются для каждого участка",
    work: "Целевой контур — типовые операции, календарь обязательств и проверки закрытия периода.",
    exception: "Налоговое суждение и решение с последствиями остаются за ответственным специалистом.",
    trace: "Каждая операция связывается с источником, правилом, версией данных и подтверждением."
  },
  {
    id: "quality",
    icon: "shield",
    title: "Контроль качества",
    status: "Следующий контур",
    statusTone: "next",
    metric: "Проверка, не догадка",
    metricText: "помощник не заменяет профессиональное суждение",
    work: "Целевой контур — проверка полноты, необычных значений и соблюдения согласованных правил.",
    exception: "Помощник подсвечивает риск, а человек устанавливает причину и принимает решение.",
    trace: "В журнале видны проверка, найденное отклонение, исполнитель и результат исправления."
  }
] as const;
---

<div class="foundation-map" data-foundation-map>
  <div class="map-flow" aria-label="Путь данных от источников до важного сигнала">
    <section class="map-stage source-stage" aria-labelledby="sources-title">
      <span class="stage-number">01</span>
      <h3 id="sources-title">Источники</h3>
      <p>Забираем данные по согласованному регламенту.</p>
      <ul class="source-list">
        {sources.map((source) => <li>{source}</li>)}
      </ul>
    </section>

    <div class="flow-arrow" aria-hidden="true"><Icon name="arrow" size={22} /></div>

    <section class="map-stage helper-stage" aria-labelledby="helpers-title">
      <span class="stage-number">02</span>
      <h3 id="helpers-title">ИИ-помощники выполняют операции</h3>
      <p>Выберите помощника — справа появится его роль и граница ответственности.</p>
      <div class="helper-tabs" role="tablist" aria-label="Примеры ИИ-помощников">
        {helpers.map((helper, index) => (
          <button
            class="helper-tab"
            type="button"
            role="tab"
            id={`helper-tab-${helper.id}`}
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`helper-panel-${helper.id}`}
            tabindex={index === 0 ? "0" : "-1"}
            data-helper-tab={helper.id}
          >
            <span class="helper-icon" aria-hidden="true"><Icon name={helper.icon} size={18} /></span>
            <span class="helper-copy">
              <strong>{helper.title}</strong>
              <small class:list={["helper-status", helper.statusTone]}>{helper.status}</small>
            </span>
          </button>
        ))}
      </div>
    </section>

    <div class="flow-arrow" aria-hidden="true"><Icon name="arrow" size={22} /></div>

    <section class="map-stage base-stage" aria-labelledby="base-title">
      <span class="stage-number">03</span>
      <h3 id="base-title">Проверенная база</h3>
      <p>Люди разбирают исключения, а каждое действие остаётся в истории.</p>
      <div class="human-loop">
        <span class="human-icon" aria-hidden="true"><Icon name="person" size={20} /></span>
        <div><strong>Специалист на исключениях</strong><small>проверяет и подтверждает</small></div>
      </div>
      <div class="base-layers" aria-label="Слои проверенной учётной базы">
        <span>Управленческие разрезы</span>
        <span>Зарплата и кадры</span>
        <span>Налоговый учёт</span>
        <span>Бухгалтерский учёт</span>
      </div>
      <p class="trace-note"><Icon name="shield" size={17} /> Аудиторский след сохраняет источник, правило и решение.</p>
      <p class="one-c-note"><b>1С на обслуживании</b> — система, в которой ведётся учёт, а не отдельный его вид.</p>
    </section>

    <div class="flow-arrow" aria-hidden="true"><Icon name="arrow" size={22} /></div>

    <section class="map-stage important-stage" aria-labelledby="important-title">
      <span class="stage-number">04</span>
      <span class="important-icon" aria-hidden="true"><Icon name="spark" size={22} /></span>
      <h3 id="important-title">Aivel замечает важное</h3>
      <p>Проверяет согласованные границы и присылает руководителю короткий сигнал, когда нужно решение.</p>
      <div class="signal-preview">
        <small>Важное изменение</small>
        <strong>Запас денег опустился ниже согласованной границы</strong>
        <span>Основание и следующий шаг — внутри сообщения</span>
      </div>
    </section>
  </div>

  <div class="helper-details" aria-live="polite">
    {helpers.map((helper, index) => (
      <article
        class="helper-panel"
        id={`helper-panel-${helper.id}`}
        role="tabpanel"
        aria-labelledby={`helper-tab-${helper.id}`}
        tabindex="0"
        hidden={index !== 0}
        data-helper-panel={helper.id}
      >
        <div class="metric-block">
          <span class:list={["panel-status", helper.statusTone]}>{helper.status}</span>
          <strong>{helper.metric}</strong>
          <p>{helper.metricText}</p>
        </div>
        <div class="detail-block">
          <span>Что делает</span>
          <p>{helper.work}</p>
        </div>
        <div class="detail-block">
          <span>Когда подключается человек</span>
          <p>{helper.exception}</p>
        </div>
        <div class="detail-block">
          <span>Что можно проверить</span>
          <p>{helper.trace}</p>
        </div>
      </article>
    ))}
  </div>
</div>

<script>
  const maps = document.querySelectorAll<HTMLElement>("[data-foundation-map]");

  maps.forEach((map) => {
    const tabs = Array.from(map.querySelectorAll<HTMLButtonElement>("[data-helper-tab]"));
    const panels = Array.from(map.querySelectorAll<HTMLElement>("[data-helper-panel]"));

    const activate = (nextTab: HTMLButtonElement, moveFocus = false) => {
      const id = nextTab.dataset.helperTab;

      tabs.forEach((tab) => {
        const selected = tab === nextTab;
        tab.setAttribute("aria-selected", String(selected));
        tab.tabIndex = selected ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.helperPanel !== id;
      });

      if (moveFocus) nextTab.focus();
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event) => {
        let nextIndex: number | null = null;

        if (event.key === "ArrowRight" || event.key === "ArrowDown") nextIndex = (index + 1) % tabs.length;
        if (event.key === "ArrowLeft" || event.key === "ArrowUp") nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === "Home") nextIndex = 0;
        if (event.key === "End") nextIndex = tabs.length - 1;

        if (nextIndex !== null) {
          event.preventDefault();
          activate(tabs[nextIndex], true);
        }
      });
    });
  });
</script>

<style>
  .foundation-map {
    display: grid;
    gap: 18px;
  }

  .map-flow {
    display: grid;
    grid-template-columns: minmax(160px, 0.76fr) 28px minmax(270px, 1.28fr) 28px minmax(220px, 1fr) 28px minmax(190px, 0.86fr);
    gap: 8px;
    align-items: stretch;
  }

  .map-stage {
    min-width: 0;
    padding: 22px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .map-stage h3 {
    margin: 10px 0 8px;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
  }

  .map-stage > p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .stage-number {
    color: var(--color-gold);
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.12em;
  }

  .source-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    padding: 0;
    margin: 20px 0 0;
    list-style: none;
  }

  .source-list li {
    padding: 7px 9px;
    color: var(--color-ink-soft);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 9px;
    font-size: 0.76rem;
    font-weight: 650;
    line-height: 1.25;
  }

  .flow-arrow {
    display: grid;
    color: var(--color-gold);
    place-items: center;
  }

  .helper-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-top: 18px;
  }

  .helper-tab {
    display: grid;
    min-width: 0;
    min-height: 64px;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 9px;
    align-items: center;
    padding: 9px;
    color: var(--color-ink);
    text-align: left;
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 11px;
    cursor: pointer;
    transition: background 180ms ease-out, border-color 180ms ease-out, box-shadow 180ms ease-out;
  }

  .helper-tab:hover {
    background: white;
    border-color: var(--color-border-strong);
  }

  .helper-tab[aria-selected="true"] {
    background: var(--color-gold-pale);
    border-color: var(--color-gold);
    box-shadow: inset 0 0 0 1px var(--color-gold);
  }

  .helper-tab:focus-visible,
  .helper-panel:focus-visible {
    outline: 3px solid var(--color-gold-soft);
    outline-offset: 3px;
  }

  .helper-icon {
    display: grid;
    width: 34px;
    height: 34px;
    color: var(--color-blue);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 9px;
    place-items: center;
  }

  .helper-copy {
    display: grid;
    min-width: 0;
    gap: 3px;
  }

  .helper-copy strong {
    font-size: 0.75rem;
    line-height: 1.25;
  }

  .helper-status,
  .panel-status {
    width: fit-content;
    font-size: 0.66rem;
    font-weight: 720;
    line-height: 1.25;
  }

  .helper-status.live,
  .panel-status.live {
    color: var(--color-green);
  }

  .helper-status.next,
  .panel-status.next {
    color: var(--color-blue);
  }

  .human-loop {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 10px;
    align-items: center;
    padding: 10px;
    margin: 16px 0 10px;
    background: var(--color-blue-pale);
    border: 1px solid #cfe5f4;
    border-radius: 11px;
  }

  .human-icon {
    display: grid;
    width: 38px;
    height: 38px;
    color: var(--color-blue);
    background: white;
    border-radius: 9px;
    place-items: center;
  }

  .human-loop strong,
  .human-loop small {
    display: block;
  }

  .human-loop strong {
    font-size: 0.79rem;
  }

  .human-loop small {
    margin-top: 2px;
    color: var(--color-muted);
    font-size: 0.7rem;
  }

  .base-layers {
    display: grid;
    gap: 3px;
  }

  .base-layers span {
    padding: 6px 10px;
    color: white;
    background: var(--color-ink-soft);
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 650;
    text-align: center;
  }

  .base-layers span:nth-child(2) { background: #24344f; }
  .base-layers span:nth-child(3) { background: #2e405e; }
  .base-layers span:nth-child(4) { background: #394c6a; }

  .trace-note,
  .one-c-note {
    margin-top: 10px !important;
    font-size: 0.72rem !important;
  }

  .trace-note {
    display: flex;
    gap: 7px;
    align-items: flex-start;
    color: var(--color-green) !important;
  }

  .trace-note svg {
    flex: 0 0 auto;
    margin-top: 1px;
  }

  .one-c-note {
    padding-top: 9px;
    border-top: 1px solid var(--color-border);
  }

  .important-stage {
    color: white;
    background: var(--color-ink);
    border-color: var(--color-ink);
  }

  .important-stage h3 {
    color: white;
  }

  .important-stage > p {
    color: #c3cfde;
  }

  .important-icon {
    display: grid;
    width: 44px;
    height: 44px;
    margin-top: 16px;
    color: var(--color-ink);
    background: var(--color-gold-soft);
    border-radius: 12px;
    place-items: center;
  }

  .signal-preview {
    display: grid;
    gap: 6px;
    padding: 13px;
    margin-top: 18px;
    color: var(--color-ink);
    background: white;
    border-radius: 11px;
  }

  .signal-preview small {
    color: var(--color-red);
    font-size: 0.67rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .signal-preview strong {
    font-size: 0.8rem;
    line-height: 1.35;
  }

  .signal-preview span {
    color: var(--color-muted);
    font-size: 0.69rem;
    line-height: 1.4;
  }

  .helper-details {
    min-height: 174px;
    padding: 18px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .helper-panel {
    display: grid;
    grid-template-columns: minmax(150px, 0.75fr) repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  .helper-panel[hidden] {
    display: none;
  }

  .helper-panel > div {
    min-width: 0;
    padding: 6px 18px;
    border-left: 1px solid var(--color-border);
  }

  .helper-panel > div:first-child {
    padding-left: 6px;
    border-left: 0;
  }

  .metric-block strong {
    display: block;
    margin: 8px 0 3px;
    color: var(--color-ink);
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    line-height: 1;
  }

  .metric-block p,
  .detail-block p {
    margin: 0;
    font-size: 0.79rem;
    line-height: 1.5;
  }

  .detail-block > span {
    display: block;
    margin-bottom: 8px;
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 1180px) {
    .map-flow {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .flow-arrow {
      display: none;
    }

    .helper-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .helper-panel > div:nth-child(3) {
      border-left: 0;
    }

    .helper-panel > div:nth-child(n + 3) {
      padding-top: 18px;
      margin-top: 12px;
      border-top: 1px solid var(--color-border);
    }
  }

  @media (max-width: 700px) {
    .map-flow,
    .helper-panel {
      grid-template-columns: 1fr;
    }

    .map-stage {
      padding: 18px;
    }

    .helper-tabs {
      grid-template-columns: 1fr;
    }

    .helper-tab {
      min-height: 56px;
    }

    .helper-panel > div,
    .helper-panel > div:first-child,
    .helper-panel > div:nth-child(3) {
      padding: 14px 4px;
      margin: 0;
      border-top: 1px solid var(--color-border);
      border-left: 0;
    }

    .helper-panel > div:first-child {
      padding-top: 4px;
      border-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .helper-tab {
      transition: none;
    }
  }
</style>

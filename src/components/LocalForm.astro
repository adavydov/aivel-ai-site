---
interface Props {
  mode?: "client" | "partner" | "enterprise";
  title?: string;
}

const { mode = "client", title = "Определить важные сигналы и обсудить сопровождение" } = Astro.props;
const submitLabel = mode === "partner"
  ? "Обсудить партнёрство конфиденциально"
  : mode === "enterprise"
    ? "Обсудить задачу в вашем контуре"
    : "Определить важные сигналы";
---

<div class="form-panel">
  <p class="section-kicker">Первый разговор</p>
  <h2 style="font-size: clamp(2rem, 4vw, 3.4rem);">{title}</h2>
  <form class="inline-form" data-local-form data-form-mode={mode} action="mailto:info@aivel.ru" method="post" enctype="text/plain">
    <div class="form-grid">
      <div class="field">
        <label for={`${mode}-name`}>Имя <span aria-hidden="true">*</span></label>
        <input id={`${mode}-name`} name="name" autocomplete="name" aria-describedby={`${mode}-name-error`} required />
        <p class="field-error" id={`${mode}-name-error`} data-error-for={`${mode}-name`}></p>
      </div>
      <div class="field">
        <label for={`${mode}-channel`}>Телефон или почта <span aria-hidden="true">*</span></label>
        <input id={`${mode}-channel`} name="channel" autocomplete="off" placeholder="+7 900 000-00-00 или name@company.ru" aria-describedby={`${mode}-channel-error`} required />
        <p class="field-error" id={`${mode}-channel-error`} data-error-for={`${mode}-channel`}></p>
      </div>

      {mode === "client" && (
        <>
          <div class="field">
            <label for="client-size">Сложность бизнеса</label>
            <select id="client-size" name="size">
              <option>Одна компания, до 20 сотрудников</option>
              <option>Одна компания, больше 20 сотрудников</option>
              <option>Несколько юридических лиц</option>
              <option>Не уверен — хочу обсудить</option>
            </select>
          </div>
          <div class="field">
            <label for="client-accounting">Как ведётся учёт</label>
            <select id="client-accounting" name="accounting">
              <option>Внешний бухгалтер</option>
              <option>Своя бухгалтерия</option>
              <option>Веду самостоятельно</option>
              <option>Нужно восстановление</option>
            </select>
          </div>
        </>
      )}

      {mode === "partner" && (
        <>
          <div class="field">
            <label for="partner-clients">Клиентов в компании</label>
            <select id="partner-clients" name="clients">
              <option>До 50</option>
              <option>50–150</option>
              <option>150–500</option>
              <option>Больше 500</option>
            </select>
          </div>
          <div class="field">
            <label for="partner-goal">Будущая роль владельца</label>
            <select id="partner-goal" name="goal">
              <option>Продолжать рост и больше консультировать</option>
              <option>Снизить зависимость фирмы от меня</option>
              <option>Обсудить преемственность</option>
            </select>
          </div>
        </>
      )}

      {mode === "enterprise" && (
        <>
          <div class="field">
            <label for="enterprise-role">Ваша роль</label>
            <select id="enterprise-role" name="role">
              <option>Финансовый директор</option>
              <option>Главный бухгалтер</option>
              <option>Руководитель ИТ</option>
              <option>Руководитель преобразований</option>
              <option>Другая роль</option>
            </select>
          </div>
          <div class="field">
            <label for="enterprise-system">Учётная система</label>
            <select id="enterprise-system" name="system">
              <option>1С</option>
              <option>Несколько систем</option>
              <option>Другая система</option>
            </select>
          </div>
        </>
      )}
    </div>

    <div class="field">
      <label for={`${mode}-situation`}>Коротко опишите ситуацию</label>
      <textarea id={`${mode}-situation`} name="situation" rows="4" aria-describedby={`${mode}-help`}></textarea>
      <p class="field-help" id={`${mode}-help`}>Не указывайте ИНН, суммы, документы, имена контрагентов и другие закрытые сведения.</p>
    </div>

    <label class="consent-row">
      <input id={`${mode}-consent`} type="checkbox" name="consent" aria-describedby={`${mode}-consent-error`} required />
      <span>Согласен подготовить обращение. Данные будут переданы только после отправки письма из моей почтовой программы.</span>
    </label>
    <p class="field-error consent-error" id={`${mode}-consent-error`} data-error-for={`${mode}-consent`}></p>

    <div class="form-actions">
      <button class="button button-primary" type="submit" data-submit-button>
        <span>{submitLabel}</span><span class="button-loader" aria-hidden="true"></span>
      </button>
      <p>После проверки появится ссылка на подготовленное письмо. Сайт сам ничего не отправляет.</p>
    </div>
    <div class="form-status" role="status" aria-live="polite" data-form-status></div>
  </form>
</div>

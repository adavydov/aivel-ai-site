---
type QuestionKey = "cause" | "impact" | "action";

type Scenario = {
  id: string;
  label: string;
  calmDate: string;
  calmDateTime: string;
  signalDate: string;
  signalDateTime: string;
  title: string;
  summary: string;
  changed: string;
  why: string;
  action: string;
  sources: readonly { label: string; value: string; source: string; updated: string }[];
  calculation: string;
  rule: string;
  questions: readonly { key: QuestionKey; label: string; answer: string }[];
};

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
const rootId = "v2-cfo-sandbox";

const scenarios: readonly Scenario[] = [
  {
    id: "it-services",
    label: "ИТ и услуги",
    calmDate: "11 августа",
    calmDateTime: "2026-08-11",
    signalDate: "12 августа",
    signalDateTime: "2026-08-12",
    title: "Через 12 дней может не хватить 2,4 млн ₽ на зарплату и налоги.",
    summary: "Оплата от «Горизонта» сдвинулась на две недели, а обязательные выплаты остались на прежней дате.",
    changed: "Ожидаемые 5,8 млн ₽ придут не 12, а 26 августа.",
    why: "До даты зарплаты и налогов других подтверждённых поступлений недостаточно.",
    action: "Сегодня подтвердить новую дату оплаты и подготовить источник ещё 2,4 млн ₽.",
    sources: [
      { label: "Деньги на счетах", value: "3,1 млн ₽", source: "выписки двух банков", updated: "сегодня, 10:15" },
      { label: "Зарплата и налоги", value: "5,5 млн ₽", source: "расчёт зарплаты и календарь платежей", updated: "сегодня, 10:06" },
      { label: "Оплата «Горизонта»", value: "5,8 млн ₽, новая дата — 26 августа", source: "письмо клиента и реестр ожидаемых оплат", updated: "сегодня, 09:42" }
    ],
    calculation: "3,1 млн ₽ на счетах − 5,5 млн ₽ обязательных выплат = −2,4 млн ₽.",
    rule: "Ситуация важна, если прогнозный остаток становится отрицательным до обязательной выплаты зарплаты или налогов.",
    questions: [
      { key: "cause", label: "Кто задержал оплату?", answer: "Оплату задерживает «Горизонт». В письме от 09:42 клиент перенёс платёж на 26 августа — на 14 дней позже плана." },
      { key: "impact", label: "Что будет, если ничего не делать?", answer: "Без действий 24 августа прогнозный остаток составит −2,4 млн ₽. После оплаты 26 августа разрыв закроется, но зарплата и налоги уже будут просрочены." },
      { key: "action", label: "Что можно перенести?", answer: "Можно перенести платёж за оборудование на 1,1 млн ₽. Это уменьшит разрыв, но останется ещё 1,3 млн ₽ — понадобится второе решение." }
    ]
  },
  {
    id: "trade-delivery",
    label: "Торговля и доставка",
    calmDate: "12 августа",
    calmDateTime: "2026-08-12",
    signalDate: "13 августа",
    signalDateTime: "2026-08-13",
    title: "Доходность направления «Доставка» за две недели снизилась с 24% до 16%.",
    summary: "Расход на одну доставку вырос на 18%, а цены для клиентов не изменились.",
    changed: "Средняя стоимость доставки выросла с 640 до 755 ₽ за заказ.",
    why: "При текущем объёме направление недополучит около 1,2 млн ₽ валовой прибыли за месяц.",
    action: "Проверить три убыточных маршрута и новый тариф перевозчика до следующей отгрузки.",
    sources: [
      { label: "Выручка направления", value: "8,6 млн ₽ за 14 дней", source: "система заказов", updated: "сегодня, 08:30" },
      { label: "Расходы на доставку", value: "3,2 млн ₽ за 14 дней", source: "акты перевозчика и первичные документы", updated: "вчера, 19:10" },
      { label: "Объём", value: "4 238 заказов", source: "система заказов", updated: "сегодня, 08:30" }
    ],
    calculation: "Доходность направления рассчитана по выручке, прямой себестоимости и расходам на доставку: 24% в прошлые две недели, 16% — сейчас.",
    rule: "Ситуация важна, если доходность направления падает больше чем на 5 процентных пунктов и эффект превышает 500 тыс. ₽ в месяц.",
    questions: [
      { key: "cause", label: "Из-за чего выросла доставка?", answer: "Главное изменение связано с перевозчиком «Экспресс-Логистика»: его тариф вырос на 17% с 1 августа." },
      { key: "impact", label: "Какой эффект за месяц?", answer: "Если условия не изменить, валовая прибыль направления за месяц будет примерно на 1,2 млн ₽ ниже обычной." },
      { key: "action", label: "С чего начать?", answer: "Сначала пересмотреть три маршрута с отрицательной доходностью. На них приходится 62% ухудшения, поэтому это даст самый быстрый эффект." }
    ]
  },
  {
    id: "project-business",
    label: "Проектный бизнес",
    calmDate: "13 августа",
    calmDateTime: "2026-08-13",
    signalDate: "14 августа",
    signalDateTime: "2026-08-14",
    title: "47% просроченной задолженности теперь приходится на одного клиента.",
    summary: "Компания «Альта» пропустила вторую согласованную дату оплаты; сумма выросла до 4,6 млн ₽.",
    changed: "Доля одного клиента в просроченной задолженности выросла с 29% до 47%.",
    why: "Один платёж начал определять запас денег всей компании.",
    action: "Согласовать с «Альтой» график погашения и временно остановить новый необеспеченный объём.",
    sources: [
      { label: "Долг «Альты»", value: "4,6 млн ₽", source: "сверка с клиентом и учётная система", updated: "сегодня, 11:20" },
      { label: "Вся просроченная задолженность", value: "9,8 млн ₽", source: "оборотная ведомость", updated: "сегодня, 07:45" },
      { label: "Следующая обещанная дата", value: "не подтверждена", source: "переписка ответственного менеджера", updated: "сегодня, 11:03" }
    ],
    calculation: "4,6 млн ₽ ÷ 9,8 млн ₽ просроченной задолженности = 47%.",
    rule: "Ситуация важна, если на одного клиента приходится больше 35% просроченного долга или его задержка нарушает минимальный запас денег.",
    questions: [
      { key: "cause", label: "Кто задержал оплату?", answer: "Оплату задерживает «Альта». Это вторая пропущенная дата; новой подтверждённой даты в переписке пока нет." },
      { key: "impact", label: "Что будет до конца месяца?", answer: "Если 4,6 млн ₽ не поступят до конца месяца, запас денег станет на 1,6 млн ₽ ниже установленного минимума." },
      { key: "action", label: "Как снизить риск?", answer: "Можно остановить новый необеспеченный объём для «Альты» и согласовать два частичных платежа. Это снизит дальнейший рост риска." }
    ]
  },
  {
    id: "complex-accounting",
    label: "Сложный учёт",
    calmDate: "14 августа",
    calmDateTime: "2026-08-14",
    signalDate: "15 августа",
    signalDateTime: "2026-08-15",
    title: "До закрытия периода два дня, но 19 операций на 3,8 млн ₽ ещё не подтверждены.",
    summary: "По операциям нет документов или согласованной статьи учёта, поэтому отчётность может быть искажена.",
    changed: "За день число незавершённых операций снизилось только с 23 до 19.",
    why: "Без разбора исключений закрытие задержится минимум на два рабочих дня.",
    action: "Назначить владельцев пяти крупнейших исключений: на них приходится 82% суммы.",
    sources: [
      { label: "Незавершённые операции", value: "19 на 3,8 млн ₽", source: "журнал закрытия периода", updated: "сегодня, 12:00" },
      { label: "Без первичных документов", value: "11 операций", source: "реестр первичных документов", updated: "сегодня, 11:55" },
      { label: "Без статьи учёта", value: "8 операций", source: "очередь исключений", updated: "сегодня, 11:58" }
    ],
    calculation: "Пять крупнейших исключений составляют 3,1 млн ₽ из 3,8 млн ₽, то есть 82% неподтверждённой суммы.",
    rule: "Ситуация важна, если до закрытия меньше трёх дней, а незавершённые операции могут изменить отчётность больше чем на 1 млн ₽.",
    questions: [
      { key: "cause", label: "Что блокирует закрытие?", answer: "Пять крупнейших исключений закреплены за закупками, складом и руководителем направления «Доставка»." },
      { key: "impact", label: "Что будет, если не успеть?", answer: "Отчётность выйдет минимум на два рабочих дня позже, а доходность направлений останется предварительной." },
      { key: "action", label: "С чего начать?", answer: "Сначала разобрать пять операций на 3,1 млн ₽. Остальные 14 операций меньше по сумме и не блокируют предварительный отчёт." }
    ]
  }
];
---

<section class="v2-game" id={rootId} data-v2-cfo-game aria-labelledby={`${rootId}-title`}>
  <header class="v2-game__intro">
    <h1 id={`${rootId}-title`}>Посмотрите, что Aivel <span class="v2-accent-word">сообщит руководителю.</span></h1>
    <p>Aivel сам замечает изменение, объясняет, почему оно важно, и показывает, что сделать сейчас.</p>
    <p class="v2-game__notice" role="note">Данные учебные. Вопросы остаются в вашем браузере.</p>
  </header>

  <div class="v2-game__recognition">
    <div class="v2-game__industries" role="tablist" aria-label="Выберите тип бизнеса">
      {scenarios.map((scenario, index) => (
        <button
          type="button"
          role="tab"
          id={`${rootId}-tab-${scenario.id}`}
          aria-controls={`${rootId}-panel-${scenario.id}`}
          aria-selected={index === 0 ? "true" : "false"}
          tabindex={index === 0 ? 0 : -1}
          data-scenario-select={scenario.id}
        >
          {scenario.label}
        </button>
      ))}
    </div>

    <div class="v2-game__workspace">
      {scenarios.map((scenario, index) => {
        const panelId = `${rootId}-panel-${scenario.id}`;
        const signalId = `${panelId}-signal-title`;
        const basisId = `${panelId}-basis`;
        const answerId = `${panelId}-answer`;
        const questionId = `${panelId}-question`;

        return (
          <article
            class="v2-game__scene"
            id={panelId}
            role="tabpanel"
            aria-labelledby={`${rootId}-tab-${scenario.id}`}
            data-scenario-panel={scenario.id}
            hidden={index !== 0}
          >
            <div class="v2-game__calm" data-calm-state>
              <time datetime={scenario.calmDateTime}>{scenario.calmDate}</time>
              <p class="v2-game__status">Aivel наблюдает за изменениями</p>
              <h2>Пока всё спокойно.</h2>
              <p>Новых ситуаций, требующих решения руководителя, нет.</p>
              <button class="v2-game__next" type="button" data-next-day>Следующий день</button>
            </div>

            <div class="v2-game__signal" data-signal-state hidden>
              <time datetime={scenario.signalDateTime}>{scenario.signalDate}</time>
              <p class="v2-game__status">Aivel заметил важное</p>
              <h2 id={signalId}>{scenario.title}</h2>
              <p class="v2-game__summary">{scenario.summary}</p>

              <dl class="v2-game__facts">
                <div><dt>Что изменилось</dt><dd>{scenario.changed}</dd></div>
                <div><dt>Почему важно</dt><dd>{scenario.why}</dd></div>
                <div><dt>Что сделать сейчас</dt><dd>{scenario.action}</dd></div>
              </dl>

              <button
                class="v2-game__basis-button"
                type="button"
                aria-expanded="false"
                aria-controls={basisId}
                data-basis-button
              >
                <span data-basis-closed>Показать основание</span>
                <span data-basis-open hidden>Скрыть основание</span>
              </button>

              <section class="v2-game__basis" id={basisId} data-basis hidden aria-label="Основание сигнала">
                <h3>Откуда взялся вывод</h3>
                <dl class="v2-game__sources">
                  {scenario.sources.map((source) => (
                    <div>
                      <dt>{source.label}: {source.value}</dt>
                      <dd>{source.source}; обновлено {source.updated}</dd>
                    </div>
                  ))}
                </dl>
                <div class="v2-game__proof-row"><strong>Расчёт</strong><p>{scenario.calculation}</p></div>
                <div class="v2-game__proof-row"><strong>Правило важности</strong><p>{scenario.rule}</p></div>
              </section>

              <section class="v2-game__dialog" aria-labelledby={`${panelId}-dialog-title`}>
                <h3 id={`${panelId}-dialog-title`}>Уточнить сигнал</h3>
                <div class="v2-game__prompts" aria-label="Готовые вопросы">
                  {scenario.questions.map((question) => (
                    <button type="button" data-question-key={question.key}>{question.label}</button>
                  ))}
                </div>

                <form class="v2-game__form" data-question-form>
                  <label for={questionId}>Или задайте короткий вопрос</label>
                  <div>
                    <input
                      id={questionId}
                      name="question"
                      type="text"
                      maxlength="180"
                      autocomplete="off"
                      aria-describedby={answerId}
                      placeholder="Например: какой главный риск?"
                      data-question-input
                    />
                    <button type="submit">Спросить</button>
                  </div>
                </form>

                <div class="v2-game__answer" id={answerId} role="status" aria-live="polite" aria-atomic="true" data-answer data-state="empty">
                  Выберите готовое уточнение или задайте короткий вопрос.
                </div>

                <div hidden aria-hidden="true" data-answer-bank>
                  {scenario.questions.map((question) => <p data-answer-copy={question.key}>{question.answer}</p>)}
                  <p data-answer-default>Выберите готовое уточнение или задайте короткий вопрос.</p>
                  <p data-answer-empty>Напишите вопрос или выберите одно из трёх готовых уточнений.</p>
                  <p data-answer-limit>В этой учебной версии я отвечаю только на три уточнения выше. Выберите ближайшее — Aivel не будет придумывать ответ.</p>
                </div>
              </section>

              <a class="v2-button v2-game__cta" href={ctaHref}>Записаться на показ на своих данных</a>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  <p class="v2-game__live" role="status" aria-live="polite" aria-atomic="true" data-live-status></p>
</section>

<script>
  import "../../scripts/v2-cfo-game.ts";
</script>

<style>
  .v2-game {
    --game-ink: var(--v2-ink, #0f1722);
    --game-soft-ink: var(--v2-ink-soft, rgb(15 23 34 / 82%));
    --game-quiet: var(--v2-quiet, rgb(15 23 34 / 48%));
    --game-line: var(--v2-line, rgb(15 23 34 / 10%));
    --game-surface: var(--v2-surface, #fcfdff);
    width: 100%;
    color: var(--game-ink);
  }

  .v2-game [hidden] {
    display: none !important;
  }

  .v2-game__intro h1 {
    max-width: 900px;
    margin: 0;
    font-size: 3.75rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .v2-game__intro > p:first-of-type {
    max-width: 760px;
    margin: 20px 0 0;
    color: var(--game-soft-ink);
    font-size: 1.125rem;
    line-height: 1.625;
  }

  .v2-game__notice {
    margin: 12px 0 0;
    color: var(--game-quiet);
    font-size: 0.8125rem;
    line-height: 1.55;
  }

  .v2-game__recognition {
    display: grid;
    grid-template-columns: minmax(220px, 320px) minmax(0, 1fr);
    gap: 48px;
    margin-top: 32px;
  }

  .v2-game__industries {
    display: grid;
    align-content: start;
  }

  .v2-game__industries button {
    min-height: 48px;
    padding: 8px 0;
    color: var(--game-soft-ink);
    border: 0;
    background: transparent;
    font-size: 1.125rem;
    line-height: 1.35;
    text-align: left;
    cursor: pointer;
  }

  .v2-game__industries button:hover,
  .v2-game__industries button[aria-selected="true"] {
    color: var(--game-ink);
  }

  .v2-game__industries button[aria-selected="true"] {
    font-weight: 650;
  }

  .v2-game__workspace {
    min-width: 0;
  }

  .v2-game__scene {
    min-width: 0;
    padding: 32px;
    border: 1px solid var(--game-line);
    border-radius: 16px;
    background: var(--game-surface);
  }

  .v2-game__calm {
    display: flex;
    min-height: 292px;
    flex-direction: column;
    align-items: flex-start;
  }

  .v2-game time,
  .v2-game__status {
    color: var(--game-quiet);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .v2-game__status {
    margin: 22px 0 0;
  }

  .v2-game__calm h2,
  .v2-game__signal h2 {
    margin: 8px 0 0;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.12;
  }

  .v2-game__calm > p:last-of-type,
  .v2-game__summary {
    margin: 12px 0 0;
    color: var(--game-soft-ink);
    line-height: 1.6;
  }

  .v2-game__next,
  .v2-game__form button {
    min-height: 46px;
    padding: 12px 20px;
    color: #fff;
    border: 1px solid var(--game-ink);
    border-radius: 8px;
    background: var(--game-ink);
    font-weight: 650;
    cursor: pointer;
  }

  .v2-game__next {
    margin-top: auto;
  }

  .v2-game__facts {
    margin: 24px 0 0;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__facts > div {
    padding: 16px 0;
    border-bottom: 1px solid var(--game-line);
  }

  .v2-game__facts dt {
    margin-bottom: 5px;
    color: var(--game-quiet);
    font-size: 0.75rem;
    font-weight: 650;
  }

  .v2-game__facts dd,
  .v2-game__sources dd {
    margin: 0;
    color: var(--game-soft-ink);
    line-height: 1.55;
  }

  .v2-game__basis-button {
    margin-top: 16px;
    padding: 5px 0;
    color: var(--game-ink);
    border: 0;
    border-bottom: 1px solid currentColor;
    background: transparent;
    font-weight: 650;
    cursor: pointer;
  }

  .v2-game__basis {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__basis h3,
  .v2-game__dialog h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.4;
  }

  .v2-game__sources {
    margin: 16px 0 0;
  }

  .v2-game__sources > div + div {
    margin-top: 14px;
  }

  .v2-game__sources dt {
    font-size: 0.875rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .v2-game__sources dd {
    margin-top: 3px;
    color: var(--game-quiet);
    font-size: 0.8125rem;
  }

  .v2-game__proof-row {
    margin-top: 18px;
  }

  .v2-game__proof-row strong {
    font-size: 0.8125rem;
  }

  .v2-game__proof-row p {
    margin: 5px 0 0;
    color: var(--game-soft-ink);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .v2-game__dialog {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__prompts {
    display: grid;
    gap: 8px;
    margin-top: 14px;
  }

  .v2-game__prompts button {
    padding: 10px 12px;
    color: var(--game-ink);
    border: 1px solid var(--game-line);
    border-radius: 8px;
    background: transparent;
    line-height: 1.35;

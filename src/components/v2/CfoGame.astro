---
const titleId = `v2-cfo-game-${Math.random().toString(36).slice(2, 9)}`;
const basisId = `${titleId}-basis`;
const answerId = `${titleId}-answer`;
---

<section class="v2-game" data-v2-cfo-game aria-labelledby={titleId}>
  <header class="v2-game__intro">
    <p class="v2-game__eyebrow">Учебная демонстрация</p>
    <div>
      <h1 id={titleId}>Один рабочий день с финансовым помощником</h1>
      <p>
        Время идёт, в бизнесе происходят события. Помощник сам замечает то, что требует вашего
        внимания, и показывает основание вывода.
      </p>
    </div>
  </header>

  <div class="v2-game__notice" role="note">
    <strong>Учебная компания «Север».</strong>
    <span>Все данные и названия вымышлены. Введённые вопросы никуда не отправляются.</span>
  </div>

  <div class="v2-game__scene">
    <div class="v2-game__bar">
      <div>
        <span class="v2-game__bar-label">Сегодня</span>
        <time datetime="2026-08-12" data-game-date>12 августа</time>
      </div>
      <span class="v2-game__progress" data-game-progress>День 2 из 5</span>
    </div>

    <div class="v2-game__layout">
      <aside class="v2-game__timeline" aria-label="История учебных событий">
        <p>История</p>
        <ol data-history>
          <li>11 августа — всё спокойно</li>
          <li aria-current="step">
            12 августа — через 12 дней может не хватить денег на зарплату и налоги
          </li>
        </ol>
      </aside>

      <div class="v2-game__conversation">
        <article class="v2-game__message" aria-labelledby={`${titleId}-signal`}>
          <p class="v2-game__sender" data-signal-kicker>Финансовый помощник заметил важное</p>
          <h2 id={`${titleId}-signal`} data-signal-title>
            Через 12 дней может не хватить 2,4 млн ₽ на зарплату и налоги.
          </h2>
          <p class="v2-game__summary" data-signal-summary>
            Оплата от «Горизонта» сдвинулась на две недели, а обязательные выплаты остались на
            прежней дате.
          </p>

          <div data-signal-detail>
            <dl class="v2-game__facts">
              <div>
                <dt>Что изменилось</dt>
                <dd data-signal-changed>Ожидаемые 5,8 млн ₽ придут не 12, а 26 августа.</dd>
              </div>
              <div>
                <dt>Почему это важно</dt>
                <dd data-signal-why>
                  До даты зарплаты и налогов других подтверждённых поступлений недостаточно.
                </dd>
              </div>
              <div>
                <dt>Когда проявится</dt>
                <dd data-signal-horizon>Риск возникнет 24 августа — через 12 дней.</dd>
              </div>
            </dl>

            <div class="v2-game__action">
              <span>Что сделать сейчас</span>
              <p data-signal-action>
                Сегодня подтвердить новую дату оплаты и подготовить источник ещё 2,4 млн ₽.
              </p>
            </div>

            <button
              class="v2-game__basis-button"
              type="button"
              aria-expanded="true"
              aria-controls={basisId}
              data-basis-button
            >
              Скрыть основание
            </button>

            <div class="v2-game__basis" id={basisId} data-basis>
              <h3>Откуда взялся вывод</h3>
              <dl class="v2-game__sources" data-source-list>
                <div class="v2-game__source">
                  <dt>Деньги на счетах: 3,1 млн ₽</dt>
                  <dd>выписки двух банков; обновлено сегодня, 10:15</dd>
                </div>
                <div class="v2-game__source">
                  <dt>Зарплата и налоги: 5,5 млн ₽</dt>
                  <dd>расчёт зарплаты и календарь платежей; обновлено сегодня, 10:06</dd>
                </div>
                <div class="v2-game__source">
                  <dt>Оплата «Горизонта»: 5,8 млн ₽, новая дата — 26 августа</dt>
                  <dd>письмо клиента и реестр ожидаемых оплат; обновлено сегодня, 09:42</dd>
                </div>
              </dl>
              <div class="v2-game__proof">
                <div>
                  <h4>Расчёт</h4>
                  <p data-calculation>
                    3,1 млн ₽ на счетах − 5,5 млн ₽ обязательных выплат = −2,4 млн ₽.
                  </p>
                </div>
                <div>
                  <h4>Правило важности</h4>
                  <p data-rule>
                    Ситуация важна, если прогнозный остаток становится отрицательным до
                    обязательной выплаты зарплаты или налогов.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </article>

        <section class="v2-game__dialog" aria-labelledby={`${titleId}-dialog`} data-dialog>
          <div>
            <p class="v2-game__dialog-label" id={`${titleId}-dialog`}>Можно уточнить</p>
            <div class="v2-game__prompts" aria-label="Готовые вопросы">
              <button type="button" data-question-key="payer">Кто задержал оплату?</button>
              <button type="button" data-question-key="consequence">
                Что будет, если ничего не делать?
              </button>
              <button type="button" data-question-key="move">Что можно перенести?</button>
            </div>
          </div>

          <form class="v2-game__form" data-question-form>
            <label for={`${titleId}-question`}>Или задайте короткий вопрос</label>
            <div>
              <input
                id={`${titleId}-question`}
                name="question"
                type="text"
                maxlength="180"
                autocomplete="off"
                aria-describedby={answerId}
                placeholder="Например: какой главный риск?"
                data-question-input
              />
              <button type="submit">Спросить</button>
            </div>
          </form>

          <div
            class="v2-game__answer"
            id={answerId}
            role="status"
            aria-live="polite"
            aria-atomic="true"
            data-answer
            data-state="empty"
          >
            Выберите готовое уточнение или задайте короткий вопрос.
          </div>
        </section>

        <div class="v2-game__controls">
          <button
            class="v2-game__next"
            type="button"
            aria-label="Перейти к следующему учебному дню"
            data-next-day
          >
            Следующий день
          </button>
          <p>Четыре дня — четыре разных типа сигнала.</p>
        </div>
      </div>
    </div>
  </div>

  <p class="v2-game__live" role="status" aria-live="polite" aria-atomic="true" data-live-status>
  </p>
</section>

<script>
  import "../../scripts/v2-cfo-game.ts";
</script>

<style>
  .v2-game {
    --game-ink: var(--v2-ink, #102a43);
    --game-muted: var(--v2-muted, #59697a);
    --game-line: var(--v2-line, #d9e0e6);
    --game-paper: var(--v2-paper, #ffffff);
    --game-soft: var(--v2-soft, #f3f5f5);
    --game-accent: var(--v2-accent, #c7842d);
    --game-accent-dark: var(--v2-accent-dark, #8b5616);
    color: var(--game-ink);
  }

  .v2-game__intro {
    display: grid;
    grid-template-columns: minmax(9rem, 0.28fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: start;
    max-width: 70rem;
    margin-bottom: clamp(1.75rem, 5vw, 3.5rem);
  }

  .v2-game__eyebrow,
  .v2-game__sender,
  .v2-game__dialog-label,
  .v2-game__bar-label {
    margin: 0;
    color: var(--game-accent-dark);
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .v2-game__intro h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 5.5rem);
    font-weight: 620;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .v2-game__intro h1 + p {
    max-width: 42rem;
    margin: 1.35rem 0 0;
    color: var(--game-muted);
    font-size: clamp(1.02rem, 2vw, 1.24rem);
    line-height: 1.55;
  }

  .v2-game__notice {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    max-width: 70rem;
    margin: 0 0 1rem;
    color: var(--game-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .v2-game__notice strong {
    color: var(--game-ink);
  }

  .v2-game__scene {
    overflow: hidden;
    max-width: 70rem;
    border: 1px solid var(--game-line);
    border-radius: clamp(1.25rem, 3vw, 1.75rem);
    background: var(--game-paper);
    box-shadow: 0 1.6rem 4rem rgb(16 42 67 / 9%);
  }

  .v2-game__bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    min-height: 4.7rem;
    padding: 0.85rem clamp(1rem, 3vw, 2rem);
    border-bottom: 1px solid var(--game-line);
  }

  .v2-game__bar > div {
    display: grid;
    gap: 0.15rem;
  }

  .v2-game__bar time {
    font-size: 1rem;
    font-weight: 700;
  }

  .v2-game__progress {
    color: var(--game-muted);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .v2-game__layout {
    display: grid;
    grid-template-columns: minmax(12rem, 0.34fr) minmax(0, 1fr);
  }

  .v2-game__timeline {
    padding: clamp(1.25rem, 3vw, 2rem);
    border-right: 1px solid var(--game-line);
    background: var(--game-soft);
  }

  .v2-game__timeline > p {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    font-weight: 750;
  }

  .v2-game__timeline ol {
    display: grid;
    gap: 0.85rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .v2-game__timeline :global(li) {
    position: relative;
    padding-left: 1rem;
    color: var(--game-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .v2-game__timeline :global(li::before) {
    position: absolute;
    top: 0.42rem;
    left: 0;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--game-line);
    content: "";
  }

  .v2-game__timeline :global(li[aria-current="step"]) {
    color: var(--game-ink);
    font-weight: 700;
  }

  .v2-game__timeline :global(li[aria-current="step"]::before) {
    background: var(--game-accent);
  }

  .v2-game__conversation {
    min-width: 0;
    padding: clamp(1rem, 4vw, 3rem);
  }

  .v2-game__message {
    max-width: 44rem;
  }

  .v2-game__message h2 {
    margin: 0.65rem 0 0;
    font-size: clamp(1.55rem, 3.5vw, 2.65rem);
    font-weight: 620;
    letter-spacing: -0.035em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .v2-game__summary {
    max-width: 40rem;
    margin: 1rem 0 0;
    color: var(--game-muted);
    font-size: 1rem;
    line-height: 1.58;
  }

  .v2-game__facts {
    display: grid;
    gap: 0;
    margin: 1.6rem 0 0;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__facts > div {
    display: grid;
    grid-template-columns: minmax(8.5rem, 0.34fr) minmax(0, 1fr);
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--game-line);
  }

  .v2-game__facts dt,
  .v2-game__facts dd {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .v2-game__facts dt {
    color: var(--game-muted);
  }

  .v2-game__facts dd {
    font-weight: 650;
  }

  .v2-game__action {
    margin: 1rem 0;
    padding: 1rem 1.1rem;
    border-left: 3px solid var(--game-accent);
    border-radius: 0 0.75rem 0.75rem 0;
    background: color-mix(in srgb, var(--game-accent) 9%, var(--game-paper));
  }

  .v2-game__action span {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--game-accent-dark);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .v2-game__action p {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .v2-game button,
  .v2-game input {
    font: inherit;
  }

  .v2-game button {
    min-height: 2.75rem;
    cursor: pointer;
  }

  .v2-game button:focus-visible,
  .v2-game input:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--game-accent) 55%, white);
    outline-offset: 3px;
  }

  .v2-game__basis-button {
    padding: 0.55rem 0;
    border: 0;
    border-bottom: 1px solid currentColor;
    background: transparent;
    color: var(--game-accent-dark);
    font-size: 0.9rem;
    font-weight: 750;
  }

  .v2-game__basis {
    margin-top: 1rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid var(--game-line);
    border-radius: 1rem;
    background: var(--game-soft);
  }

  .v2-game__basis[hidden],
  [data-signal-detail][hidden],
  .v2-game__dialog[hidden] {
    display: none;
  }

  .v2-game__basis h3 {
    margin: 0 0 1rem;
    font-size: 1.05rem;
  }

  .v2-game__sources {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  :global(.v2-game__source) {
    display: grid;
    grid-template-columns: minmax(10rem, 0.46fr) minmax(0, 1fr);
    gap: 0.75rem;
  }

  :global(.v2-game__source dt),
  :global(.v2-game__source dd) {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  :global(.v2-game__source dt) {
    font-weight: 700;
  }

  :global(.v2-game__source dd) {
    color: var(--game-muted);
  }

  .v2-game__proof {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__proof h4 {
    margin: 0 0 0.35rem;
    color: var(--game-muted);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .v2-game__proof p {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .v2-game__dialog {
    display: grid;
    gap: 1.25rem;
    max-width: 44rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--game-line);
  }

  .v2-game__prompts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.7rem;
  }

  .v2-game__prompts button {
    min-height: 2.75rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--game-line);
    border-radius: 0.7rem;
    background: var(--game-paper);
    color: var(--game-ink);
    font-size: 0.82rem;
    font-weight: 650;
  }

  .v2-game__prompts button:hover {
    border-color: var(--game-accent);
  }

  .v2-game__form label {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--game-muted);
    font-size: 0.78rem;
  }

  .v2-game__form > div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
  }

  .v2-game__form input {
    min-width: 0;
    min-height: 2.75rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--game-line);
    border-radius: 0.7rem;
    background: var(--game-paper);
    color: var(--game-ink);
  }

  .v2-game__form button,
  .v2-game__next {
    padding: 0.6rem 1rem;
    border: 1px solid var(--game-ink);
    border-radius: 0.7rem;
    background: var(--game-ink);
    color: white;
    font-weight: 750;
  }

  .v2-game__answer {
    overflow-wrap: anywhere;
    min-height: 3.5rem;
    padding: 0.9rem 1rem;
    border-radius: 0.8rem;
    background: var(--game-soft);
    font-size: 0.87rem;
    line-height: 1.55;
  }

  .v2-game__answer[data-state="empty"] {
    color: var(--game-muted);
  }

  .v2-game__answer[data-state="limited"] {
    border-left: 3px solid var(--game-accent);
  }

  .v2-game__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: center;
    justify-content: space-between;
    max-width: 44rem;
    margin-top: 1.5rem;
  }

  .v2-game__next {
    min-width: 10rem;
    background: var(--game-accent);
    border-color: var(--game-accent);
    color: #1d1a15;
  }

  .v2-game__controls p {
    margin: 0;
    color: var(--game-muted);
    font-size: 0.78rem;
  }

  .v2-game__live {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 760px) {
    .v2-game__intro {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .v2-game__intro h1 {
      max-width: 15ch;
      font-size: clamp(2.2rem, 13vw, 3.8rem);
    }

    .v2-game__layout {
      display: block;
    }

    .v2-game__timeline {
      padding: 0.8rem 1rem;
      border-right: 0;
      border-bottom: 1px solid var(--game-line);
    }

    .v2-game__timeline > p {
      margin-bottom: 0.55rem;
    }

    .v2-game__timeline ol {
      display: flex;
      gap: 0.45rem;
      overflow-x: auto;
      padding-bottom: 0.2rem;
      scrollbar-width: thin;
    }

    .v2-game__timeline :global(li) {
      flex: 0 0 8.5rem;
      padding: 0.5rem 0.6rem;
      border: 1px solid var(--game-line);
      border-radius: 0.65rem;
      background: var(--game-paper);
      font-size: 0.68rem;
    }

    .v2-game__timeline :global(li::before) {
      display: none;
    }

    .v2-game__conversation {
      padding: 1.15rem;
    }

    .v2-game__facts > div,
    :global(.v2-game__source),
    .v2-game__proof {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    :global(.v2-game__source) {
      padding-bottom: 0.65rem;
      border-bottom: 1px solid var(--game-line);
    }

    .v2-game__proof {
      gap: 1rem;
    }

    .v2-game__form > div {
      grid-template-columns: 1fr;
    }

    .v2-game__form button,
    .v2-game__next {
      width: 100%;
    }

    .v2-game__controls {
      align-items: stretch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .v2-game *,
    .v2-game *::before,
    .v2-game *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>

---
import { v2Navigation } from "../../data/v2";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/v2/") return pathname === "/v2/" || pathname.startsWith("/v2/primer/");
  return pathname.startsWith(href);
};
---

<aside class="v2-sidebar" aria-label="Навигация Aivel 2.0">
  <a class="v2-side-brand" href="/v2/" aria-label="Aivel 2.0 — главная">
    <span>AIVEL</span>
    <small>2.0</small>
  </a>

  <nav class="v2-side-nav" aria-label="Основные разделы">
    {v2Navigation.map((item) => (
      <a
        class="v2-side-link"
        href={item.href}
        aria-current={isActive(item.href) ? "page" : undefined}
        aria-label={item.label}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          {item.id === "important" && (
            <>
              <path d="M2.8 12s3.4-5.5 9.2-5.5 9.2 5.5 9.2 5.5-3.4 5.5-9.2 5.5S2.8 12 2.8 12Z" />
              <circle cx="12" cy="12" r="2.7" />
            </>
          )}
          {item.id === "accounting" && (
            <>
              <ellipse cx="12" cy="5.5" rx="7.8" ry="3" />
              <path d="M4.2 5.5v6c0 1.7 3.5 3 7.8 3s7.8-1.3 7.8-3v-6" />
              <path d="M4.2 11.5v6c0 1.7 3.5 3 7.8 3s7.8-1.3 7.8-3v-6" />
            </>
          )}
          {item.id === "cases" && (
            <>
              <path d="M5 3.5h10l4 4v13H5z" />
              <path d="M15 3.5v4h4M8.5 12l2.1 2.1 4.9-5" />
            </>
          )}
          {item.id === "partner" && (
            <>
              <path d="M8.3 11.1 11 8.5a2.4 2.4 0 0 1 3.3 0l1.2 1.1" />
              <path d="m3.1 9.2 3.2-3.1 3.1 3.1-3.2 3.2zM20.9 9.2l-3.2-3.1-3.1 3.1 3.2 3.2z" />
              <path d="m7.2 11.5 5.2 5.1c.7.7 1.8.7 2.5 0l3-3M9.1 13.4l-1.3 1.3M11 15.3l-1.2 1.2" />
            </>
          )}
        </svg>
        <span>{item.label}</span>
      </a>
    ))}
  </nav>
</aside>

---
import { v2Navigation } from "../../data/v2";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/v2/") return pathname === "/v2/" || pathname.startsWith("/v2/primer/");
  if (href === "/v2/avtomatizatsiya-bek-ofisa/") {
    return pathname.startsWith(href) || pathname.startsWith("/v2/ii-agenty/");
  }
  return pathname.startsWith(href);
};

const shortLabels: Record<string, string> = {
  important: "Важное",
  accounting: "Учёт",
  enterprise: "ИИ",
  partner: "Партнёрам"
};
---

<aside class="v2-sidebar" aria-label="Навигация Aivel 2.0">
  <a class="v2-side-brand" href="/v2/" aria-label="Aivel 2.0 — главная">
    <span>Aivel</span>
    <small>AI</small>
  </a>

  <nav class="v2-side-nav" aria-label="Основные разделы">
    {v2Navigation.map((item) => (
      <a
        class="v2-side-link"
        href={item.href}
        aria-current={isActive(item.href) ? "page" : undefined}
        aria-label={item.label}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          {item.id === "important" && (
            <>
              <path d="M3 12h3l2.1-5.2 3.8 10.4 2.4-6.1H21" />
            </>
          )}
          {item.id === "accounting" && (
            <>
              <path d="M5 3.5h14v17H5zM8 8h8M8 12h3M8 16h3M14.5 12h1.5M14.5 16h1.5" />
            </>
          )}
          {item.id === "enterprise" && (
            <>
              <rect x="7" y="7" width="10" height="10" rx="2" />
              <path d="M9.5 1.8v3M14.5 1.8v3M9.5 19.2v3M14.5 19.2v3M1.8 9.5h3M1.8 14.5h3M19.2 9.5h3M19.2 14.5h3M10 10h4v4h-4z" />
            </>
          )}
          {item.id === "partner" && (
            <>
              <path d="M8.3 11.1 11 8.5a2.4 2.4 0 0 1 3.3 0l1.2 1.1" />
              <path d="m3.1 9.2 3.2-3.1 3.1 3.1-3.2 3.2zM20.9 9.2l-3.2-3.1-3.1 3.1 3.2 3.2z" />
              <path d="m7.2 11.5 5.2 5.1c.7.7 1.8.7 2.5 0l3-3M9.1 13.4l-1.3 1.3M11 15.3l-1.2 1.2" />
            </>
          )}
        </svg>
        <span>{shortLabels[item.id]}</span>
      </a>
    ))}
  </nav>
</aside>

---
interface Pain {
  readonly title: string;
  readonly text: string;
}

interface Props {
  pains: readonly Pain[];
}

const { pains } = Astro.props;
---

<div class="v2-recognition" data-pain-recognition>
  <div class="v2-recognition__tabs" role="tablist" aria-label="Ситуации в бизнесе">
    {pains.map((pain, index) => (
      <button
        class="v2-recognition__tab"
        id={`v2-pain-tab-${index + 1}`}
        type="button"
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        aria-controls={`v2-pain-panel-${index + 1}`}
        tabindex={index === 0 ? 0 : -1}
      >
        {pain.title}
      </button>
    ))}
  </div>

  <div class="v2-recognition__panels">
    {pains.map((pain, index) => (
      <article
        class="v2-recognition__card"
        id={`v2-pain-panel-${index + 1}`}
        role="tabpanel"
        aria-labelledby={`v2-pain-tab-${index + 1}`}
        hidden={index !== 0}
      >
        <h3>{pain.title}</h3>
        <p>{pain.text}</p>
      </article>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-pain-recognition]").forEach((recognition) => {
    const tabs = Array.from(recognition.querySelectorAll<HTMLButtonElement>("[role='tab']"));
    const panels = Array.from(recognition.querySelectorAll<HTMLElement>("[role='tabpanel']"));

    const activate = (activeTab: HTMLButtonElement) => {
      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      panels.forEach((panel) => {
        panel.hidden = panel.id !== activeTab.getAttribute("aria-controls");
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowDown", "ArrowUp", "ArrowRight", "ArrowLeft", "Home", "End"].includes(event.key)) return;

        event.preventDefault();
        let nextIndex = index;

        if (event.key === "Home") nextIndex = 0;
        else if (event.key === "End") nextIndex = tabs.length - 1;
        else if (event.key === "ArrowDown" || event.key === "ArrowRight") nextIndex = (index + 1) % tabs.length;
        else nextIndex = (index - 1 + tabs.length) % tabs.length;

        const nextTab = tabs[nextIndex];
        nextTab.focus();
        activate(nextTab);
      });
    });
  });
</script>

---
import { v2Clients } from "../../data/v2";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={["v2-brands", compact && "v2-brands--compact"]} aria-label="Опыт внедрений">
  {v2Clients.map((client) => (
    <figure>
      <img src={client.src} alt={client.name} loading="lazy" decoding="async" />
      <figcaption>{client.name}</figcaption>
    </figure>
  ))}
</div>

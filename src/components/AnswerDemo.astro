---
import Icon from "./Icon.astro";
import { demoAnswers } from "../data/site";
---

<div class="answer-demo" id="primer-otveta" data-answer-demo>
  <div class="demo-tabs" role="tablist" aria-label="Примеры вопросов">
    {demoAnswers.map((answer, index) => (
      <button
        type="button"
        role="tab"
        id={`tab-${answer.id}`}
        aria-controls={`panel-${answer.id}`}
        aria-selected={index === 0 ? "true" : "false"}
        tabindex={index === 0 ? 0 : -1}
        data-demo-tab={answer.id}
      >
        {answer.tab}
      </button>
    ))}
  </div>

  {demoAnswers.map((answer, index) => (
    <section
      class="demo-panel"
      role="tabpanel"
      id={`panel-${answer.id}`}
      aria-labelledby={`tab-${answer.id}`}
      hidden={index !== 0}
      data-demo-panel={answer.id}
    >
      <div class="demo-question-row">
        <div class="demo-avatar" aria-hidden="true">А</div>
        <div>
          <span>Вопрос владельца</span>
          <p>{answer.question}</p>
        </div>
      </div>

      <div class="demo-answer-grid">
        <div class="demo-answer-main">
          <div class="verified-label"><Icon name="shield" size={18} /> Проверяемый ответ</div>
          <h3>{answer.headline}</h3>
          <p>{answer.explanation}</p>

          <div class="answer-meta">
            <span><strong>Период</strong>{answer.period}</span>
            <span><strong>Свежесть</strong>{answer.freshness}</span>
            <span><strong>Периметр</strong>{answer.scope}</span>
          </div>
        </div>

        <aside class="demo-metric" aria-label={`${answer.metricLabel}: ${answer.metric}`}>
          <span>{answer.metricLabel}</span>
          <strong>{answer.metric}</strong>
          <small>по учебным данным</small>
        </aside>
      </div>

      <div class="bridge-table" aria-label="Как сформирован ответ">
        {answer.bridge.map((item) => (
          <div>
            <span>{item.label}</span>
            <strong class={`tone-${item.tone}`}>{item.value}</strong>
          </div>
        ))}
      </div>

      <div class="demo-details-grid">
        <details>
          <summary><Icon name="source" size={18} /> Источники</summary>
          <div class="source-list">
            {answer.sources.map((source) => <span>{source}</span>)}
          </div>
        </details>
        <details>
          <summary><Icon name="document" size={18} /> Что учесть</summary>
          <p>{answer.limitation}</p>
        </details>
        <details>
          <summary><Icon name="chart" size={18} /> Следующий шаг</summary>
          <p>{answer.nextStep}</p>
        </details>
      </div>

      <p class="demo-disclaimer">Пример на обезличенных учебных данных. Ответ для вашей компании зависит от подключённых источников и состояния учёта.</p>
    </section>
  ))}
</div>

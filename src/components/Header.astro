---
import Icon from "./Icon.astro";
import { navigation } from "../data/site";

const path = Astro.url.pathname;
const isActive = (href: string) => href === "/" ? path === "/" : path.startsWith(href);
const isPartnerPage = path.startsWith("/buhgalterskim-kompaniyam/");
const isAccountingPage = path.startsWith("/buhgalterskoe-soprovozhdenie/");
const isEnterprisePage = [
  "/krupnym-kompaniyam/",
  "/avtomatizatsiya-ucheta/",
  "/zashchita-dannyh/",
  "/1s-i-integratsii/"
].some((prefix) => path.startsWith(prefix));

const contactCta = isPartnerPage
  ? { label: "Обсудить партнёрство", topic: "partner" }
  : isAccountingPage
    ? { label: "Запросить аудит", topic: "client" }
    : isEnterprisePage
      ? { label: "Обсудить внедрение", topic: "enterprise" }
      : null;
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a class="brand brand-surface" href="/" aria-label="Aivel — на главную">
      <img class="brand-logo" src="/aivel-wordmark-light.png" width="114" height="20" alt="Aivel" />
    </a>

    <nav class="desktop-nav" aria-label="Основная навигация">
      {navigation.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      {contactCta ? (
        <button class="button button-small button-primary header-cta" type="button" data-open-contact data-contact-topic={contactCta.topic}>
          {contactCta.label}
        </button>
      ) : (
        <button class="button button-small button-primary header-cta" type="button" data-open-demo>
          Попробовать демо
        </button>
      )}
      <button
        class="icon-button mobile-menu-button"
        type="button"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-menu-button
      >
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden data-mobile-menu>
    <nav class="container" aria-label="Мобильная навигация">
      {navigation.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
      ))}
      {contactCta ? (
        <button class="button button-primary" type="button" data-open-contact data-contact-topic={contactCta.topic}>{contactCta.label}</button>
      ) : (
        <button class="button button-primary" type="button" data-open-demo>Попробовать демо</button>
      )}
    </nav>
  </div>
</header>

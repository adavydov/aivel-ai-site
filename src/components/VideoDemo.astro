---
import Icon from "./Icon.astro";

interface Props {
  driveId: string;
  title: string;
  description: string;
  label?: string;
}

const {
  driveId,
  title,
  description,
  label = "Настоящая демонстрация"
} = Astro.props;

const previewUrl = `https://drive.google.com/file/d/${driveId}/preview`;
const viewUrl = `https://drive.google.com/file/d/${driveId}/view`;
---

<article class="video-demo">
  <div class="video-demo-frame">
    <iframe
      src={previewUrl}
      title={title}
      loading="lazy"
      allow="autoplay; encrypted-media"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
    ></iframe>
  </div>
  <div class="video-demo-copy">
    <p class="card-label">{label}</p>
    <h3>{title}</h3>
    <p>{description}</p>
    <a class="text-link" href={viewUrl} target="_blank" rel="noopener">
      Открыть ролик отдельно <Icon name="arrow" size={18} />
    </a>
    <small>Ролик загружается с Google Диска.</small>
  </div>
</article>

<style>
  .video-demo {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.55fr);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .video-demo-frame {
    min-width: 0;
    aspect-ratio: 16 / 9;
    background: var(--color-navy);
  }

  .video-demo-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-demo-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(26px, 4vw, 44px);
  }

  .video-demo-copy h3 {
    margin: 8px 0 14px;
    font-size: clamp(1.45rem, 2.5vw, 2.1rem);
  }

  .video-demo-copy p:not(.card-label) {
    margin-bottom: 22px;
  }

  .video-demo-copy small {
    display: block;
    margin-top: 18px;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .video-demo {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Icon from "./Icon.astro";

const layers = [
  {
    area: "accounting",
    number: "01",
    icon: "document",
    title: "Проверенный слой учёта",
    description: "Операции, остатки и обязательства с известным источником и периодом.",
    items: ["Операции", "Остатки", "Обязательства"]
  },
  {
    area: "knowledge",
    number: "02",
    icon: "source",
    title: "Знания о компании и связях",
    description: "Aivel понимает, как связаны компании, подразделения, проекты и контрагенты.",
    items: ["Юрлица", "Проекты", "Договоры"]
  },
  {
    area: "context",
    number: "03",
    icon: "chart",
    title: "Контекст бизнеса",
    description: "Планы, сезонность, приоритеты и согласованные границы важности.",
    items: ["Планы", "Сезонность", "Границы"]
  }
] as const;
---

<section class="mechanics-screen" id="kak-aivel-ponimaet-vazhnost" aria-labelledby="mechanics-title">
  <div class="container mechanics-shell">
    <header class="mechanics-heading" data-reveal>
      <div>
        <p class="section-kicker">02 · Как появляется сигнал</p>
        <h2 id="mechanics-title">Не просто находит отклонение — понимает его смысл.</h2>
      </div>
      <p>
        Одна и та же цифра может быть обычной для одной компании и критичной для другой.
        Поэтому Aivel сопоставляет данные, устройство компании и контекст бизнеса.
      </p>
    </header>

    <ol class="mechanics-map" aria-label="Пять шагов от учётных данных до сигнала руководителю" data-reveal>
      {layers.map((layer) => (
        <li class:list={["mechanics-stage", "layer-stage", `${layer.area}-stage`]}>
          <span class="stage-number">{layer.number}</span>
          <span class="stage-icon" aria-hidden="true"><Icon name={layer.icon} size={20} /></span>
          <div class="stage-copy">
            <h3>{layer.title}</h3>
            <p>{layer.description}</p>
            <ul class="stage-tags" aria-label={`Что входит в слой «${layer.title}»`}>
              {layer.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </li>
      ))}

      <li class="mechanics-stage agent-stage">
        <span class="stage-number">04</span>
        <span class="agent-mark" aria-hidden="true"><Icon name="spark" size={28} /></span>
        <div>
          <p class="stage-eyebrow">ИИ-агент Aivel</p>
          <h3>Сопоставляет три слоя</h3>
          <p>Находит значимое изменение, формулирует сигнал и объясняет, почему он важен именно сейчас.</p>
        </div>
        <ul class="agent-result" aria-label="Что делает ИИ-агент">
          <li><Icon name="check" size={16} /> Сверяет с границами</li>
          <li><Icon name="check" size={16} /> Учитывает связи</li>
          <li><Icon name="check" size={16} /> Сохраняет основания</li>
        </ul>
      </li>

      <li class="mechanics-stage delivery-stage">
        <span class="stage-number">05</span>
        <div class="delivery-head">
          <div>
            <p class="stage-eyebrow">Сигнал для руководителя</p>
            <h3>Важное приходит само</h3>
          </div>
          <div class="delivery-channels" aria-label="Каналы доставки: почта и Telegram">
            <span><Icon name="mail" size={17} /> Почта</span>
            <span><Icon name="message" size={17} /> Telegram</span>
          </div>
        </div>

        <blockquote class="signal-preview">
          <span>Важное изменение</span>
          <strong>Запас денег 18 июля снизится до 620 тыс. ₽ — ниже согласованной границы 1 млн ₽.</strong>
          <p>В этот день запланированы налоги и зарплата, а два поступления пока не подтверждены.</p>
        </blockquote>

        <div class="clarification" aria-label="Пример уточнения данных по сигналу">
          <span class="clarification-label">Можно уточнить</span>
          <p><Icon name="message" size={17} /> Какие поступления пока не подтверждены?</p>
          <small>Aivel отвечает в контексте этого сигнала и показывает связанные данные.</small>
        </div>
      </li>
    </ol>
  </div>
</section>

<style>
  .mechanics-screen {
    display: grid;
    min-height: calc(100svh - var(--header-height));
    padding-block: clamp(48px, 6vw, 76px);
    align-items: center;
    background:
      radial-gradient(circle at 78% 18%, rgb(245 201 121 / 0.18), transparent 24rem),
      var(--color-warm);
    border-block: 1px solid #efe7d8;
  }

  .mechanics-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.62fr);
    gap: clamp(32px, 6vw, 88px);
    align-items: end;
    margin-bottom: clamp(28px, 4vw, 44px);
  }

  .mechanics-heading h2 {
    max-width: 820px;
    margin-bottom: 0;
    font-size: clamp(2.25rem, 4.2vw, 4.1rem);
  }

  .mechanics-heading > p {
    max-width: 500px;
    margin: 0;
    font-size: clamp(1rem, 1.35vw, 1.08rem);
    line-height: 1.58;
  }

  .mechanics-map {
    --map-gap: clamp(34px, 4vw, 56px);
    display: grid;
    grid-template-areas:
      "accounting agent delivery"
      "knowledge agent delivery"
      "context agent delivery";
    grid-template-columns: minmax(250px, 0.9fr) minmax(270px, 0.9fr) minmax(330px, 1.18fr);
    grid-template-rows: repeat(3, minmax(108px, auto));
    gap: 10px var(--map-gap);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .mechanics-stage {
    position: relative;
    min-width: 0;
    border-radius: var(--radius-md);
  }

  .accounting-stage { grid-area: accounting; }
  .knowledge-stage { grid-area: knowledge; }
  .context-stage { grid-area: context; }

  .layer-stage {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    padding: 18px;
    background: rgb(255 255 255 / 0.86);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .layer-stage::after,
  .agent-stage::after {
    position: absolute;
    z-index: 0;
    top: 50%;
    right: calc(var(--map-gap) * -1);
    width: var(--map-gap);
    height: 1px;
    background: linear-gradient(90deg, var(--color-border-strong), var(--color-gold-soft));
    content: "";
  }

  .layer-stage::before,
  .agent-stage::before {
    position: absolute;
    z-index: 1;
    top: calc(50% - 4px);
    right: calc(var(--map-gap) * -1 - 1px);
    width: 8px;
    height: 8px;
    background: var(--color-gold);
    border: 2px solid var(--color-warm);
    border-radius: 50%;
    content: "";
  }

  .stage-number {
    position: absolute;
    top: 12px;
    right: 13px;
    color: var(--color-gold);
    font-size: 0.68rem;
    font-variant-numeric: tabular-nums;
    font-weight: 750;
    letter-spacing: 0.08em;
  }

  .stage-icon {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    color: var(--color-blue);
    background: var(--color-blue-pale);
    border: 1px solid rgb(7 89 133 / 0.14);
    border-radius: 12px;
  }

  .stage-copy h3,
  .agent-stage h3,
  .delivery-stage h3 {
    margin: 0;
    font-size: clamp(1.02rem, 1.45vw, 1.28rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .stage-copy > p {
    margin: 6px 0 10px;
    font-size: 0.78rem;
    line-height: 1.42;
  }

  .stage-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .stage-tags li {
    padding: 4px 7px;
    color: var(--color-ink-soft);
    background: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.67rem;
    font-weight: 650;
    line-height: 1.2;
  }

  .agent-stage {
    grid-area: agent;
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: center;
    padding: clamp(24px, 3vw, 36px);
    color: white;
    background:
      radial-gradient(circle at 80% 12%, rgb(245 201 121 / 0.18), transparent 11rem),
      var(--color-ink);
    border: 1px solid rgb(255 255 255 / 0.1);
    box-shadow: var(--shadow-lg);
  }

  .agent-stage .stage-number {
    color: var(--color-gold-soft);
  }

  .agent-mark {
    display: grid;
    width: 54px;
    height: 54px;
    place-items: center;
    margin-bottom: 26px;
    color: var(--color-ink);
    background: var(--color-gold-soft);
    border-radius: 17px;
  }

  .stage-eyebrow {
    margin-bottom: 7px;
    color: var(--color-gold);
    font-size: 0.7rem;
    font-weight: 750;
    letter-spacing: 0.09em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .agent-stage .stage-eyebrow {
    color: var(--color-gold-soft);
  }

  .agent-stage h3 {
    color: white;
    font-size: clamp(1.45rem, 2.4vw, 2.1rem);
  }

  .agent-stage > div > p:last-child {
    margin: 13px 0 0;
    color: #cbd5e1;
    font-size: 0.9rem;
    line-height: 1.52;
  }

  .agent-result {
    display: grid;
    gap: 9px;
    padding: 18px 0 0;
    margin: 24px 0 0;
    border-top: 1px solid rgb(255 255 255 / 0.14);
    list-style: none;
  }

  .agent-result li {
    display: flex;
    gap: 8px;
    align-items: center;
    color: #e2e8f0;
    font-size: 0.8rem;
    line-height: 1.35;
  }

  .agent-result svg {
    flex: 0 0 auto;
    color: var(--color-gold-soft);
  }

  .delivery-stage {
    grid-area: delivery;
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: center;
    padding: clamp(22px, 3vw, 34px);
    background: white;
    border: 1px solid #dfc98f;
    box-shadow: var(--shadow-sm);
  }

  .delivery-head {
    display: grid;
    gap: 14px;
  }

  .delivery-channels {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .delivery-channels span {
    display: inline-flex;
    min-height: 30px;
    gap: 6px;
    align-items: center;
    padding: 5px 9px;
    color: var(--color-blue);
    background: var(--color-blue-pale);
    border: 1px solid rgb(7 89 133 / 0.14);
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 680;
  }

  .signal-preview {
    padding: 17px 18px;
    margin: 18px 0 12px;
    background: var(--color-gold-pale);
    border: 1px solid #ecd49d;
    border-radius: var(--radius-sm);
  }

  .signal-preview span,
  .signal-preview strong {
    display: block;
  }

  .signal-preview span {
    margin-bottom: 6px;
    color: var(--color-gold);
    font-size: 0.66rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .signal-preview strong {
    color: var(--color-ink);
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .signal-preview p {
    margin: 8px 0 0;
    font-size: 0.75rem;
    line-height: 1.45;
  }

  .clarification {
    padding: 14px 15px;
    background: var(--color-blue-pale);
    border: 1px solid rgb(7 89 133 / 0.14);
    border-radius: var(--radius-sm);
  }

  .clarification-label {
    display: block;
    margin-bottom: 6px;
    color: var(--color-blue);
    font-size: 0.66rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .clarification p {
    display: flex;
    gap: 7px;
    align-items: center;
    margin: 0 0 5px;
    color: var(--color-ink);
    font-size: 0.82rem;
    font-weight: 680;
    line-height: 1.4;
  }

  .clarification p svg {
    flex: 0 0 auto;
    color: var(--color-blue);
  }

  .clarification small {
    display: block;
    color: var(--color-muted);
    font-size: 0.7rem;
    line-height: 1.42;
  }

  @media (max-width: 1080px) {
    .mechanics-map {
      --map-gap: 34px;
      grid-template-columns: minmax(230px, 0.9fr) minmax(240px, 0.9fr) minmax(300px, 1.15fr);
    }

    .layer-stage {
      grid-template-columns: 36px minmax(0, 1fr);
      padding: 15px;
    }

    .stage-icon {
      width: 35px;
      height: 35px;
    }
  }

  @media (max-width: 920px) {
    .mechanics-screen {
      min-height: auto;
      padding-block: 72px;
    }

    .mechanics-heading {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .mechanics-heading > p {
      max-width: 680px;
    }

    .mechanics-map {
      display: grid;
      grid-template-areas:
        "accounting"
        "knowledge"
        "context"
        "agent"
        "delivery";
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto;
      gap: 34px;
    }

    .layer-stage,
    .agent-stage,
    .delivery-stage {
      min-height: auto;
    }

    .layer-stage::after,
    .agent-stage::after {
      top: auto;
      right: 50%;
      bottom: -34px;
      width: 1px;
      height: 34px;
      background: linear-gradient(180deg, var(--color-border-strong), var(--color-gold-soft));
    }

    .layer-stage::before,
    .agent-stage::before {
      top: auto;
      right: calc(50% - 4px);
      bottom: -35px;
    }

    .agent-stage {
      padding: 30px;
    }

    .agent-mark {
      margin-bottom: 20px;
    }
  }

  @media (max-width: 520px) {
    .mechanics-screen {
      padding-block: 56px;
    }

    .mechanics-heading {
      margin-bottom: 28px;
    }

    .mechanics-heading h2 {
      font-size: clamp(2.1rem, 10.5vw, 2.85rem);
    }

    .layer-stage {
      grid-template-columns: 40px minmax(0, 1fr);
      padding: 17px 15px;
    }

    .stage-icon {
      width: 40px;
      height: 40px;
    }

    .stage-copy h3 {
      padding-right: 24px;
      font-size: 1.08rem;
    }

    .stage-copy > p,
    .agent-stage > div > p:last-child {
      font-size: 0.86rem;
    }

    .stage-tags li {
      font-size: 0.72rem;
    }

    .agent-stage,
    .delivery-stage {
      padding: 24px 20px;
    }

    .signal-preview strong {
      font-size: 0.96rem;
    }

    .signal-preview p,
    .clarification small {
      font-size: 0.78rem;
    }

    .clarification p {
      align-items: flex-start;
      font-size: 0.88rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mechanics-screen *,
    .mechanics-screen *::before,
    .mechanics-screen *::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

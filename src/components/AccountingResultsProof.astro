---
import Icon from "./Icon.astro";
import { automationResults, implementationMetrics } from "../data/site";

const assistantPages = [
  { ...automationResults[0], href: "/avtomatizatsiya-ucheta/pervichnye-dokumenty/" },
  { ...automationResults[1], href: "/avtomatizatsiya-ucheta/bankovskie-operatsii/" },
  { ...automationResults[2], href: "/avtomatizatsiya-ucheta/kommunikatsii-s-klientami/" },
  { ...automationResults[3], href: "/avtomatizatsiya-ucheta/sverki-s-kontragentami/" }
] as const;
---

<section class="section accounting-results" id="rezultaty-vnedreniy" aria-labelledby="accounting-results-title">
  <div class="container">
    <div class="section-heading results-heading">
      <div>
        <p class="section-kicker">Что уже измерено во внедрениях</p>
        <h2 id="accounting-results-title">Результат виден в цифрах и в каждой операции.</h2>
      </div>
      <p>Совокупные показатели дают масштаб эффекта, а страницы процессов показывают, из каких действий он складывается.</p>
    </div>

    <div class="metric-grid" aria-label="Измеренные результаты внедрений">
      {implementationMetrics.map((metric) => (
        <article class="metric-card">
          <strong>{metric.value}</strong>
          <h3>{metric.label}</h3>
          <p>{metric.note}</p>
        </article>
      ))}
    </div>

    <div class="process-heading">
      <div>
        <p class="section-kicker">Доказательство по процессам</p>
        <h3>Посмотрите операцию целиком.</h3>
      </div>
      <p>На каждой странице — демонстрация, роль ИИ-помощника, точка передачи человеку и измеренный результат.</p>
    </div>

    <div class="process-grid" role="list">
      {assistantPages.map((item) => (
        <article class="process-card" role="listitem">
          <a href={item.href} aria-label={`Открыть страницу ИИ-помощника «${item.title}»`}>
            <span class="process-eyebrow">ИИ-помощник</span>
            <h3>{item.title}</h3>
            <p class="process-result">{item.result}</p>
            <p class="process-scope">{item.scope}</p>
            <span class="process-link">Посмотреть процесс <Icon name="arrow" size={19} /></span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .accounting-results {
    padding-block: clamp(58px, 7vw, 92px);
    scroll-margin-top: var(--header-height);
    background: var(--color-paper);
    border-top: 1px solid var(--color-border);
  }

  .results-heading {
    margin-bottom: 28px;
  }

  .metric-grid,
  .process-grid {
    display: grid;
    gap: 12px;
  }

  .metric-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .metric-card,
  .process-card {
    min-width: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .metric-card {
    padding: clamp(20px, 2.5vw, 28px);
  }

  .metric-card > strong {
    display: block;
    margin-bottom: 16px;
    color: var(--color-blue);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    letter-spacing: -0.045em;
    line-height: 0.98;
  }

  .metric-card h3 {
    margin: 0 0 9px;
    font-size: 1rem;
    line-height: 1.4;
  }

  .metric-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .process-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.56fr);
    gap: 30px;
    align-items: end;
    padding-top: clamp(38px, 5vw, 60px);
    margin-bottom: 20px;
  }

  .process-heading h3,
  .process-heading .section-kicker,
  .process-heading > p {
    margin-bottom: 0;
  }

  .process-heading h3 {
    margin-top: 5px;
    font-size: clamp(1.75rem, 3vw, 2.55rem);
  }

  .process-heading > p {
    color: var(--color-muted);
  }

  .process-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .process-card {
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .process-card:hover,
  .process-card:focus-within {
    border-color: var(--color-ink);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .process-card > a {
    display: flex;
    min-height: 100%;
    padding: 21px;
    color: inherit;
    text-decoration: none;
    flex-direction: column;
  }

  .process-card > a:focus-visible {
    outline: 3px solid var(--color-gold-soft);
    outline-offset: -5px;
  }

  .process-eyebrow {
    margin-bottom: 9px;
    color: var(--color-gold);
    font-size: 0.68rem;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .process-card h3 {
    min-height: 2.6em;
    margin: 0 0 16px;
    font-size: 1.04rem;
  }

  .process-result {
    margin: 0 0 10px;
    color: var(--color-ink);
    font-size: 0.88rem;
    font-weight: 720;
    line-height: 1.45;
  }

  .process-scope {
    margin: 0 0 18px;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .process-link {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    color: var(--color-blue);
    font-size: 0.82rem;
    font-weight: 720;
  }

  @media (max-width: 1080px) {
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .metric-grid,
    .process-heading {
      grid-template-columns: 1fr;
    }

    .process-heading {
      gap: 10px;
    }
  }

  @media (max-width: 620px) {
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-card h3 {
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-card {
      transition: none;
    }

    .process-card:hover,
    .process-card:focus-within {
      transform: none;
    }
  }
</style>

---
interface Props {
  name: "arrow" | "check" | "menu" | "close" | "source" | "shield" | "person" | "chart" | "document" | "spark" | "mail" | "message";
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  {name === "arrow" && <path d="M5 12h14m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />}
  {name === "check" && <path d="m5 12.5 4.2 4.2L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />}
  {name === "menu" && <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />}
  {name === "close" && <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />}
  {name === "source" && <>
    <path d="M7 3.5h7l3 3V20.5H7z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
    <path d="M14 3.5v3h3M9.5 11h5M9.5 14.5h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
  </>}
  {name === "shield" && <>
    <path d="M12 3 19 6v5.3c0 4.4-2.8 7.7-7 9.7-4.2-2-7-5.3-7-9.7V6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
    <path d="m8.8 12 2.1 2.1 4.4-4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
  </>}
  {name === "person" && <>
    <circle cx="12" cy="8" r="3.3" stroke="currentColor" stroke-width="1.6" />
    <path d="M5.5 20c.6-4 2.8-6 6.5-6s5.9 2 6.5 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
  </>}
  {name === "chart" && <>
    <path d="M4 20V4M4 20h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
    <path d="m7 15 3.5-4 3 2 4.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </>}
  {name === "document" && <>
    <rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.6" />
    <path d="M8.5 8h7M8.5 12h7M8.5 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
  </>}
  {name === "spark" && <>
    <path d="M12 3.5c.7 4.4 2.1 5.8 6.5 6.5-4.4.7-5.8 2.1-6.5 6.5-.7-4.4-2.1-5.8-6.5-6.5 4.4-.7 5.8-2.1 6.5-6.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
    <path d="M18.5 15.5c.3 2 1 2.7 3 3-2 .3-2.7 1-3 3-.3-2-1-2.7-3-3 2-.3 2.7-1 3-3Z" fill="currentColor" />
  </>}
  {name === "mail" && <>
    <rect x="3.5" y="5" width="17" height="14" rx="2.2" stroke="currentColor" stroke-width="1.6" />
    <path d="m5 7 7 5.2L19 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
  </>}
  {name === "message" && <>
    <path d="M5.2 5.2h13.6v10.2H11l-4.3 3.4v-3.4H5.2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
    <path d="M8.2 9h7.6M8.2 12h5.3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
  </>}
</svg>

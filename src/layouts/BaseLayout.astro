---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactDialog from "../components/ContactDialog.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = site.title,
  description = site.description,
  image = "/social-card.svg",
  noindex = false,
  schema
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${site.url}/#organization`,
    name: site.name,
    url: site.url,
    email: "info@aivel.ru",
    description: site.description
  },
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f172a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Aivel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).toString()} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Перейти к содержанию</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <ContactDialog />
    <script is:inline src="/site.js" defer></script>
  </body>
</html>

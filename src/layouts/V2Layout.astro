---
import "../styles/v2.css";
import V2Sidebar from "../components/v2/V2Sidebar.astro";
import V2Footer from "../components/v2/V2Footer.astro";
import { v2Site } from "../data/v2";

interface Props {
  title: string;
  description?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  image?: string;
}

const {
  title,
  description = v2Site.description,
  schema,
  image = "/social-card.svg"
} = Astro.props;

const siteRoot = v2Site.url.replace(/\/$/, "");
const canonical = `${siteRoot}${Astro.url.pathname}`;
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${v2Site.url}/#organization`,
    name: v2Site.name,
    url: v2Site.url,
    email: v2Site.email,
    description: v2Site.description
  },
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Aivel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteRoot}${image}`} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)} />
  </head>
  <body class="v2-body">
    <a class="v2-skip-link" href="#main-content">Перейти к содержанию</a>
    <div class="v2-app-shell">
      <V2Sidebar />
      <div class="v2-content">
        <main id="main-content" tabindex="-1">
          <slot />
        </main>
        <V2Footer />
      </div>
    </div>
  </body>
</html>
